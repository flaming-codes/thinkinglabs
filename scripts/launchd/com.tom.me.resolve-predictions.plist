<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tom.me.resolve-predictions</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-lc</string>
        <string>source ~/.zshrc &gt;/dev/null 2&gt;&amp;1 || true; exec pnpm resolve-predictions</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__REPO_ROOT__</string>

    <!--
        resolve-predictions calls the OpenAI API (gpt-4.1, balanced tier).
        Set OPENAI_API_KEY in your launchd environment before loading this plist:

            launchctl setenv OPENAI_API_KEY <your-key>

        Alternatively, add an EnvironmentVariables dict below — but do NOT bake the key
        into this file or commit it to version control.

        Without the key, the agent runs with --no-llm and produces zero proposals.
    -->
    <key>EnvironmentVariables</key>
    <dict>
        <!-- Add OPENAI_API_KEY here only if you cannot use launchctl setenv. -->
    </dict>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>10</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/tom/Library/Logs/me/resolve-predictions.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/tom/Library/Logs/me/resolve-predictions.err.log</string>
</dict>
</plist>
