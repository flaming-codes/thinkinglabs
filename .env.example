# LLM — provider
# Set to "ollama" to route calls through Ollama instead of OpenAI.
# LLM_PROVIDER=openai

# LLM — API keys (set the one that matches LLM_PROVIDER)
# - OPENAI_API_KEY is required when LLM_PROVIDER is unset or "openai".
# - OLLAMA_API_KEY is required when LLM_PROVIDER=ollama.
# `pnpm brain-diff:scored` and `pnpm artifacts:scored` fail fast if the active
# provider's key is missing. Use `pnpm artifacts` / `pnpm artifacts:offline` for
# offline local generation.
OPENAI_API_KEY=
# OLLAMA_API_KEY=

# LLM — model selection (optional; defaults shown; applied to whichever provider is active)
# LLM_MODEL_FAST=gpt-4.1-mini      # Ollama default: glm-5.1:cloud
# LLM_MODEL_BALANCED=gpt-4.1       # Ollama default: glm-5.1:cloud
# LLM_MODEL_DEEP=gpt-4.1           # Ollama default: glm-5.1:cloud

# LLM — Ollama endpoint (only relevant when LLM_PROVIDER=ollama)
# Use http://localhost:11434/v1 for a local daemon instead of the cloud.
# OLLAMA_BASE_URL=https://ollama.com/v1

# LLM — performance
# LLM_TIMEOUT_MS=60000

# Historical note: the M3-era brain-diff pipeline used ANTHROPIC_API_KEY; the M6 SDK
# refactor (ADR-007) replaced it with the LLM_PROVIDER + OPENAI_API_KEY/OLLAMA_API_KEY
# scheme above. Anthropic is no longer wired in.

# Background agents
# DORMANT_THRESHOLD_DAYS=60

# Site
# SITE_URL=https://tom.wild.as   # canonical public URL; consumed by astro.config.mjs, structured-data check, feed builders, and MCP handlers

# MCP server
# THINKINGLABS_MCP_REPO_ROOT=   # defaults to process.cwd()

# Build / test determinism (freeze "now" for reproducible local runs)
# BUILD_NOW_ISO=
# FRESHNESS_NOW_ISO=
