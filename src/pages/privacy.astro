---
import AppShell from "../frontend/thinkinglabs-ui/components/AppShell.astro";
import ThinkinglabsUiPage from "../layouts/ThinkinglabsUiPage.astro";
---

<ThinkinglabsUiPage
  title="Privacy — thinkinglabs"
  description="thinkinglabs does not track visitors. No analytics, no cookies, no fingerprinting."
>
  <AppShell activeNav="Index" hideSelectedHud>
    <article class="tl-privacy-page">
      <header class="tl-privacy-hero">
        <div class="tl-privacy-hero-copy">
          <p class="tl-privacy-kicker">Privacy</p>
          <h1>Quiet by default.</h1>
          <p class="tl-privacy-lede">
            thinkinglabs is static, public, and deliberately uninterested in identifying
            readers. The site is built to publish work, not to observe the people reading it.
          </p>
        </div>

        <aside class="tl-privacy-promises" aria-label="Privacy summary">
          <p>No analytics</p>
          <p>No cookies</p>
          <p>No fingerprinting</p>
          <p>No reader profiles</p>
        </aside>
      </header>

      <section class="tl-privacy-section" aria-labelledby="privacy-site-title">
        <p class="tl-privacy-section-index">01</p>
        <div class="tl-privacy-copy">
          <p class="tl-privacy-kicker">Site behavior</p>
          <h2 id="privacy-site-title">The page does not try to identify you.</h2>
          <p>
            thinkinglabs is static HTML generated from a public markdown repository. There is no
            analytics product sitting behind the pages, no cookie banner because there are no site
            cookies to accept, and no client-side fingerprinting script trying to infer who you
            are.
          </p>
          <p>
            The site does not write to localStorage, sessionStorage, IndexedDB, or any other
            browser storage API. It does not include pixels, embedded trackers, or third-party SDKs
            that quietly assemble a profile of your reading habits.
          </p>
        </div>
      </section>

      <section class="tl-privacy-section" aria-labelledby="privacy-logs-title">
        <p class="tl-privacy-section-index">02</p>
        <div class="tl-privacy-copy">
          <p class="tl-privacy-kicker">Infrastructure</p>
          <h2 id="privacy-logs-title">Hosts may keep ordinary operational logs.</h2>
          <p>
            The hosting layer may keep ordinary operational request logs, such as an IP address,
            path, timestamp, user agent, or status code. Those records are the kind of transient
            plumbing hosts use for abuse mitigation and debugging. They are not read, joined, sold,
            or used by this site to identify readers.
          </p>
        </div>
      </section>

      <section class="tl-privacy-section" aria-labelledby="privacy-external-title">
        <p class="tl-privacy-section-index">03</p>
        <div class="tl-privacy-copy">
          <p class="tl-privacy-kicker">External places</p>
          <h2 id="privacy-external-title">Other domains have their own rules.</h2>
          <p>
            Links to other domains leave this site. Once you follow one, your browser is
            interacting with that domain and its own policies apply. The privacy promise here is
            intentionally narrow: while you are reading thinkinglabs pages, the site itself is not
            trying to observe you.
          </p>
        </div>
      </section>
    </article>
  </AppShell>
</ThinkinglabsUiPage>

<style>
  .tl-privacy-page {
    display: grid;
    gap: clamp(6rem, 13vh, 10rem);
    width: min(100%, var(--tl-layout-page));
    margin-inline: auto;
    padding:
      clamp(7rem, 13vh, 10rem)
      max(var(--tl-space-8), var(--tl-safe-right))
      clamp(8rem, 16vh, 12rem)
      max(var(--tl-space-8), var(--tl-safe-left));
    color: var(--tl-ink);
  }

  .tl-privacy-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(11rem, 18rem);
    gap: clamp(3rem, 9vw, 9rem);
    align-items: end;
    min-height: min(620px, calc(var(--tl-viewport-height) - 8rem));
  }

  .tl-privacy-hero-copy,
  .tl-privacy-promises,
  .tl-privacy-copy {
    display: grid;
  }

  .tl-privacy-hero h1,
  .tl-privacy-copy h2 {
    margin: 0;
    color: var(--tl-ink);
    font-weight: 430;
    letter-spacing: 0;
  }

  .tl-privacy-hero-copy {
    gap: clamp(1.1rem, 2vw, 1.8rem);
    max-width: 50rem;
  }

  .tl-privacy-hero h1 {
    max-width: 9.5ch;
    font-size: clamp(54px, 9vw, 118px);
    line-height: 0.9;
  }

  .tl-privacy-lede {
    max-width: 36rem;
    margin: 0;
    color: var(--tl-prose-ink);
    font-size: clamp(17px, 1.6vw, 21px);
    font-weight: 390;
    line-height: 1.66;
    letter-spacing: 0;
  }

  .tl-privacy-promises {
    gap: 0.8rem;
    justify-self: end;
    padding-bottom: clamp(0rem, 4vh, 3rem);
  }

  .tl-privacy-section {
    display: grid;
    grid-template-columns: minmax(7rem, 0.34fr) minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 7rem);
    align-items: start;
  }

  .tl-privacy-kicker,
  .tl-privacy-section-index,
  .tl-privacy-promises p {
    margin: 0;
    color: var(--tl-subtle);
    font-size: var(--tl-type-metadata-size);
    font-weight: 560;
    line-height: 1.2;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .tl-privacy-promises p {
    color: var(--tl-muted);
    text-align: right;
    text-transform: none;
    letter-spacing: 0;
  }

  .tl-privacy-copy {
    gap: 1.75rem;
    max-width: 45rem;
  }

  .tl-privacy-copy h2 {
    max-width: 18ch;
    font-size: clamp(27px, 3vw, 41px);
    line-height: 1.08;
  }

  .tl-privacy-copy p {
    margin: 0;
    color: var(--tl-prose-ink);
    font-size: clamp(17px, 1.4vw, 19px);
    font-weight: 390;
    line-height: 1.74;
    letter-spacing: 0;
  }

  .tl-privacy-copy .tl-privacy-kicker {
    color: var(--tl-subtle);
  }

  @media (max-width: 900px) {
    .tl-privacy-page {
      gap: 6.5rem;
      padding-top: 7rem;
    }

    .tl-privacy-hero,
    .tl-privacy-section {
      grid-template-columns: 1fr;
    }

    .tl-privacy-hero {
      gap: 3.2rem;
      min-height: auto;
    }

    .tl-privacy-promises {
      justify-self: start;
      padding-bottom: 0;
    }

    .tl-privacy-promises p {
      text-align: left;
    }
  }

  @media (max-width: 620px) {
    .tl-privacy-page {
      gap: 5.4rem;
      padding:
        6rem
        max(var(--tl-space-8), var(--tl-safe-right))
        7rem
        max(var(--tl-space-8), var(--tl-safe-left));
    }

    .tl-privacy-hero-copy {
      gap: 1.35rem;
    }

    .tl-privacy-hero h1 {
      max-width: 8.5ch;
    }

    .tl-privacy-copy {
      gap: 1.45rem;
    }

    .tl-privacy-promises {
      gap: 0.65rem;
    }
  }
</style>
