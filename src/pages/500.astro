---
import AppShell from "../frontend/thinkinglabs-ui/components/AppShell.astro";
import ThinkinglabsUiPage from "../layouts/ThinkinglabsUiPage.astro";
---

<ThinkinglabsUiPage
  title="Something broke — thinkinglabs"
  description="An unexpected error happened while serving this page."
  robots="noindex"
>
  <AppShell activeNav="Index">
    <section class="tl-page-head is-spacious">
      <p class="tl-mono">500</p>
      <h1>Something broke.</h1>
    </section>

    <article class="tl-error-prose tl-prose-body">
      <p class="tl-error-lede">An unexpected error happened.</p>

      <p>
        The server could not finish rendering this page. The cause is on this side, not yours.
        Reloading sometimes helps; otherwise the index below is the safe way back into the site.
      </p>

      <p class="tl-error-actions">
        <a href="/">Back to the index</a>
      </p>
    </article>
  </AppShell>
</ThinkinglabsUiPage>

<style>
  .tl-error-prose {
    width: var(--tl-center);
    margin: -4vh auto 18vh;
  }

  .tl-error-lede {
    max-width: 18ch;
    color: var(--tl-ink);
    font-size: var(--tl-type-display-lg);
    font-weight: var(--tl-type-heading-weight);
    line-height: 0.96;
    letter-spacing: var(--tl-type-track-tight);
  }

  .tl-error-prose a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .tl-error-actions {
    margin-top: clamp(2.5rem, 6vh, 4rem);
  }

  @media (max-width: 767px) {
    .tl-error-prose {
      width: min(100% - 40px, var(--tl-layout-center));
      margin-top: -2vh;
    }
  }
</style>
