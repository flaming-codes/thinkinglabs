---
import heroImage from "@/assets/error.png";
import EntityDetail from "../frontend/thinkinglabs-ui/components/EntityDetail.astro";
import ThinkinglabsUiPage from "../layouts/ThinkinglabsUiPage.astro";
---

<ThinkinglabsUiPage
  title="Something broke — thinkinglabs"
  description="An unexpected error happened while serving this page."
  robots="noindex"
  allowScroll
>
  <EntityDetail
    title="Something broke"
    heroAlt="Something broke"
    heroImage={heroImage}
    dates={[{ label: "Error 500" }]}
  >
    <p>
      The server could not finish rendering this page. The cause is on this
      side, not yours. Reloading sometimes helps; otherwise the index is the
      safe way back into the site.
    </p>
    <p><a class="tl-token-link" href="/">Back to the index</a></p>
  </EntityDetail>
</ThinkinglabsUiPage>
