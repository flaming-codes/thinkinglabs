---
import { getCollection } from "astro:content";
import QuestionsListingPageComposition from "../../frontend/thinkinglabs-ui/pages/QuestionsListingPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { mapQuestionsView } from "../../lib/thinkinglabs-ui.ts";
import { listStructuredData } from "../../lib/structured-data.ts";

const entries = await getCollection("questions");
const view = mapQuestionsView({ entries });
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title="Questions — Tom"
  description="Open questions I'm stuck on."
  structuredData={listStructuredData(
    Astro.url,
    site,
    "Questions",
    entries.map((q) => ({ id: q.id, name: q.data.question, url: `/questions/${q.id}` })),
  )}
>
  <QuestionsListingPageComposition view={view} />
</ThinkinglabsUiPage>
