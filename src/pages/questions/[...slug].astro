---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import QuestionDetailPageComposition from "../../frontend/thinkinglabs-ui/pages/QuestionDetailPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { loadContact } from "../../lib/contact.ts";
import { questionStructuredData } from "../../lib/structured-data.ts";
import { buildClaimLookup, buildTitleLookup, mapQuestionDetail } from "../../lib/thinkinglabs-ui.ts";

export const getStaticPaths = (async () => {
  const items = await getCollection("questions");
  return items.map((q) => ({ params: { slug: q.id }, props: { entry: q } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const { Content } = await render(entry);
const contact = loadContact();
const email = contact.channels.find((channel) => channel.type === "email");
const [claims, projects] = await Promise.all([getCollection("claims"), getCollection("projects")]);
const lookups = buildTitleLookup({ claims, projects });
const claimLookup = buildClaimLookup(claims);
const responseAction = email?.type === "email" ? `mailto:${email.address}` : "/contact";
const question = mapQuestionDetail({ entry, lookups, claimLookup, responseAction });
const site = Astro.site ?? new URL(Astro.url.origin);
---
<ThinkinglabsUiPage
  title={entry.data.question.slice(0, 60)}
  description={entry.data.context ?? entry.data.question}
  structuredData={questionStructuredData(entry, Astro.url, site)}
  ogType="article"
  allowScroll
>
  <QuestionDetailPageComposition question={question}>
    <Content />
  </QuestionDetailPageComposition>
</ThinkinglabsUiPage>
