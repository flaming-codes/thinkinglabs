---
import { getCollection } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { resolve } from "node:path";
import ThoughtDetailPageComposition from "../../frontend/thinkinglabs-ui/pages/ThoughtDetailPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { walkFileHistory } from "../../lib/git.ts";
import { getKindStaticPaths } from "../../lib/route-helpers.ts";
import {
  buildClaimLookup,
  buildTitleLookup,
  mapThoughtDetail,
  mapThoughtHistory,
} from "../../lib/thinkinglabs-ui.ts";
import { thoughtStructuredData } from "../../lib/structured-data.ts";

export const getStaticPaths = (async () => {
  return getKindStaticPaths("thoughts");
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const [claims, inputs] = await Promise.all([getCollection("claims"), getCollection("inputs")]);
const cwd = resolve(".");
const history = mapThoughtHistory(walkFileHistory(cwd, `content/thoughts/${entry.id}.md`));
const lookups = buildTitleLookup({ claims, inputs });
const claimLookup = buildClaimLookup(claims);
const thought = mapThoughtDetail({ entry, lookups, claimLookup, history });
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title={`${entry.data.title} — Thoughts`}
  description={`Thought: ${entry.data.title}`}
  structuredData={thoughtStructuredData(entry, Astro.url, site)}
  ogType="article"
>
  <ThoughtDetailPageComposition thought={thought} />
</ThinkinglabsUiPage>
