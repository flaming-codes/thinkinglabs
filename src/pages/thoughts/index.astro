---
import { getCollection } from "astro:content";
import ThoughtsListingPageComposition from "../../frontend/thinkinglabs-ui/pages/ThoughtsListingPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { mapThoughtSummaries } from "../../lib/thinkinglabs-ui.ts";
import { listStructuredData } from "../../lib/structured-data.ts";

const items = await getCollection("thoughts");
const thoughts = mapThoughtSummaries(items);
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title="Thoughts — Tom"
  description="Long-form prose, by recency."
  structuredData={listStructuredData(
    Astro.url,
    site,
    "Thoughts",
    items.map((thought) => ({ id: thought.id, name: thought.data.title, url: `/thoughts/${thought.id}` })),
  )}
>
  <ThoughtsListingPageComposition thoughts={thoughts} />
</ThinkinglabsUiPage>
