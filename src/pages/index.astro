---
import Base from "../layouts/Base.astro";
import { LISTING_KINDS } from "../lib/surfaces.ts";
---
<Base title="Tom — wild.as" description="Personal thinking surface and structured public operating layer.">
  <h1>Tom's thinking surface</h1>
  <p>
    See {LISTING_KINDS.map((k, i) => (
      <>
        {i > 0 ? ", " : null}
        <a href={`/${k}`}>{k}</a>
      </>
    ))}.
  </p>
  <p class="meta">
    The site is one renderer over a markdown source tree. Structured surfaces live alongside human pages — see <a href="/llms.txt">llms.txt</a>.
  </p>
</Base>
