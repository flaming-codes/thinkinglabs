---
import ThinkinglabsUiPage from "../layouts/ThinkinglabsUiPage.astro";
import PageShell from "../frontend/thinkinglabs-ui/components/PageShell.astro";
import SiteNav from "../frontend/thinkinglabs-ui/components/SiteNav.astro";

// Links to the entity index pages, surfaced in the scrollable right column.
const ENTITY_INDEXES = [
  { href: "/now", label: "now" },
  { href: "/thoughts", label: "thoughts" },
  { href: "/claims", label: "claims" },
  { href: "/predictions", label: "predictions" },
  { href: "/decisions", label: "decisions" },
  { href: "/experiments", label: "experiments" },
  { href: "/observations", label: "observations" },
  { href: "/changed-my-mind", label: "changed my mind" },
  { href: "/questions", label: "questions" },
  { href: "/projects", label: "projects" },
  { href: "/posts", label: "posts" },
  { href: "/about", label: "about" },
  { href: "/contact", label: "contact" },
] as const;
---

<ThinkinglabsUiPage
  title="thinkinglabs"
  description="Personal thinking surface and structured public operating layer."
  allowScroll
>
  <PageShell class="pb-2!">
    <SiteNav />

    {
      /*
      Fixed hero: the left-half image and the title stay pinned to the viewport
      while the right column scrolls past. pointer-events-none lets clicks reach
      the scrollable links underneath the right (image-free) half.
    */
    }
    <div class="fixed inset-0 p-2 pointer-events-none">
      <img
        src="/images/index.png"
        alt="Screenshot of thinkinglabs home page"
        class="h-full w-1/2 object-cover"
      />
      <h1 class="absolute top-1/2 -translate-y-1/2 left-4">thinkinglabs</h1>
    </div>

    {/* Scrollable right column: secondary paragraph + entity index links. */}
    <div
      class="relative ml-auto flex min-h-dvh w-1/2 flex-col px-2 text-xs items-end"
    >
      <p class="max-w-xs h-dvh flex flex-col justify-center">
        Personal thinking surface and structured public operating layer.
      </p>
      <nav class="self-start">
        <ul>
          {
            ENTITY_INDEXES.map((entry) => (
              <li>
                <a href={entry.href}>{entry.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </PageShell>
</ThinkinglabsUiPage>
