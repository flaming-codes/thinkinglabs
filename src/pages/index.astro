---
import { getCollection } from "astro:content";
import HomePageComposition from "../frontend/thinkinglabs-ui/pages/HomePageComposition.astro";
import ThinkinglabsUiPage from "../layouts/ThinkinglabsUiPage.astro";
import { mapHomeKinds } from "../lib/thinkinglabs-ui.ts";

const [claims, thoughts, inputs, projects, predictions, changedMyMind, decisions, questions, posts] =
  await Promise.all([
    getCollection("claims"),
    getCollection("thoughts"),
    getCollection("inputs"),
    getCollection("projects"),
    getCollection("predictions"),
    getCollection("changed-my-mind"),
    getCollection("decisions"),
    getCollection("questions"),
    getCollection("posts"),
  ]);

const counts = {
  claims: claims.length,
  thoughts: thoughts.length,
  inputs: inputs.length,
  projects: projects.length,
  predictions: predictions.length,
  "changed-my-mind": changedMyMind.length,
  decisions: decisions.length,
  questions: questions.length,
  posts: posts.length,
};

const kinds = mapHomeKinds(counts);
---

<ThinkinglabsUiPage
  title="thinkinglabs"
  description="Personal thinking surface and structured public operating layer."
>
  <HomePageComposition kinds={kinds} />
</ThinkinglabsUiPage>
