---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import ChangedMyMindDetailPageComposition from "../../frontend/thinkinglabs-ui/pages/ChangedMyMindDetailPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { changedMyMindStructuredData } from "../../lib/structured-data.ts";
import {
  buildClaimLookup,
  buildTitleLookup,
  mapChangedMyMindDetail,
} from "../../lib/thinkinglabs-ui.ts";

export const getStaticPaths = (async () => {
  const items = await getCollection("changed-my-mind");
  return items.map((c) => ({ params: { slug: c.id }, props: { entry: c } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const { Content } = await render(entry);
const claims = await getCollection("claims");
const lookups = buildTitleLookup({ claims });
const claimLookup = buildClaimLookup(claims);
const flip = mapChangedMyMindDetail({ entry, lookups, claimLookup });
const site = Astro.site ?? new URL(Astro.url.origin);
---
<ThinkinglabsUiPage
  title={entry.data.title}
  description={`${entry.data.used_to_believe} → ${entry.data.now_believe}`}
  structuredData={changedMyMindStructuredData(entry, Astro.url, site)}
  ogType="article"
  allowScroll
>
  <ChangedMyMindDetailPageComposition flip={flip}>
    <Content />
  </ChangedMyMindDetailPageComposition>
</ThinkinglabsUiPage>
