---
import { getCollection } from "astro:content";
import ChangedMyMindListingPageComposition from "../../frontend/thinkinglabs-ui/pages/ChangedMyMindListingPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { mapChangedMyMindView } from "../../lib/thinkinglabs-ui.ts";
import { listStructuredData } from "../../lib/structured-data.ts";

const entries = await getCollection("changed-my-mind");
const claims = await getCollection("claims");
const view = mapChangedMyMindView({ entries, claims });
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title="Changed my mind — Tom"
  description="Belief revisions, by date."
  allowScroll
  structuredData={listStructuredData(
    Astro.url,
    site,
    "Changed my mind",
    entries.map((c) => ({ id: c.id, name: c.data.title, url: `/changed-my-mind/${c.id}` })),
  )}
>
  <ChangedMyMindListingPageComposition view={view} />
</ThinkinglabsUiPage>
