---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import EmptyState from "../../components/EmptyState.astro";
import StatusPill from "../../components/StatusPill.astro";
import { formatDate } from "../../lib/route-helpers.ts";
import { byDateDesc } from "../../lib/sort.ts";
import { listStructuredData } from "../../lib/structured-data.ts";

const items = byDateDesc(await getCollection("decisions"), "date");
const site = Astro.site ?? new URL(Astro.url.origin);
function trunc(s: string | undefined, n: number): string {
  if (!s) return "";
  return s.length > n ? `${s.slice(0, n).trim()}…` : s;
}
---
<Base
  title="Decisions — Tom"
  description="ADR-style public decisions."
  structuredData={listStructuredData(
    Astro.url,
    site,
    "Decisions",
    items.map((d) => ({ id: d.id, name: d.data.decision, url: `/decisions/${d.id}` })),
  )}
>
  <h1>Decisions</h1>
  {items.length === 0 ? <EmptyState /> : (
    <ul class="list">
      {items.map((d) => (
        <li>
          <a href={`/decisions/${d.id}`}>{d.data.decision}</a> <StatusPill status={d.data.status} />
          <div class="meta">{formatDate(d.data.date)} · chose {d.data.chosen}</div>
          {d.data.why ? <div class="meta">{trunc(d.data.why, 160)}</div> : null}
        </li>
      ))}
    </ul>
  )}
</Base>
