---
import { getCollection } from "astro:content";
import DecisionsListingPageComposition from "../../frontend/thinkinglabs-ui/pages/DecisionsListingPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { mapDecisionsView } from "../../lib/thinkinglabs-ui.ts";
import { listStructuredData } from "../../lib/structured-data.ts";

const entries = await getCollection("decisions");
const view = mapDecisionsView(entries);
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title="Decisions — Tom"
  description="ADR-style public decisions."
  structuredData={listStructuredData(
    Astro.url,
    site,
    "Decisions",
    entries.map((d) => ({ id: d.id, name: d.data.decision, url: `/decisions/${d.id}` })),
  )}
>
  <DecisionsListingPageComposition view={view} />
</ThinkinglabsUiPage>
