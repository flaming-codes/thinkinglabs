---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import EmptyState from "../../components/EmptyState.astro";
import StatusPill from "../../components/StatusPill.astro";
import { byDateDesc } from "../../lib/sort.ts";

const items = byDateDesc(await getCollection("decisions"), "date");
function trunc(s: string | undefined, n: number): string {
  if (!s) return "";
  return s.length > n ? `${s.slice(0, n).trim()}…` : s;
}
---
<Base title="Decisions — Tom">
  <h1>Decisions</h1>
  {items.length === 0 ? <EmptyState /> : (
    <ul class="list">
      {items.map((d) => (
        <li>
          <a href={`/decisions/${d.id}`}>{d.data.decision}</a> <StatusPill status={d.data.status} />
          <div class="meta">{d.data.date.slice(0, 10)} · chose {d.data.chosen}</div>
          {d.data.why ? <div class="meta">{trunc(d.data.why, 160)}</div> : null}
        </li>
      ))}
    </ul>
  )}
</Base>
