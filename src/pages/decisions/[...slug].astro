---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import DecisionDetailPageComposition from "../../frontend/thinkinglabs-ui/pages/DecisionDetailPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { reversedByMap } from "../../lib/decisions.ts";
import { getKindStaticPaths } from "../../lib/route-helpers.ts";
import { decisionStructuredData } from "../../lib/structured-data.ts";
import { buildClaimLookup, buildTitleLookup, mapDecisionDetail } from "../../lib/thinkinglabs-ui.ts";

export const getStaticPaths = (async () => {
  return getKindStaticPaths("decisions");
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const { Content } = await render(entry);
const reversedBy = (await reversedByMap()).get(entry.id) ?? [];
const [decisions, claims, projects] = await Promise.all([
  getCollection("decisions"),
  getCollection("claims"),
  getCollection("projects"),
]);
const lookups = buildTitleLookup({ decisions, claims, projects });
const claimLookup = buildClaimLookup(claims);
const decision = mapDecisionDetail({ entry, reversedBy, lookups, claimLookup });
const site = Astro.site ?? new URL(Astro.url.origin);
---
<ThinkinglabsUiPage
  title={entry.data.decision.slice(0, 60)}
  description={entry.data.why ?? entry.data.context ?? entry.data.decision}
  structuredData={decisionStructuredData(entry, Astro.url, site)}
  ogType="article"
>
  <DecisionDetailPageComposition decision={decision}>
    <Content />
  </DecisionDetailPageComposition>
</ThinkinglabsUiPage>
