---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import ThinkinglabsUiPage from "../layouts/ThinkinglabsUiPage.astro";
import BrandLogo from "../frontend/thinkinglabs-ui/components/BrandLogo.astro";
import { titleFor } from "../lib/registry.ts";
import heroImage from "../assets/hero.png";

const thoughts = await getCollection("thoughts");
// Exploration page: prefer a thought with populated relation edges so the
// addendum renders; fall back to the most recent thought otherwise.
const entry =
  thoughts.find((t) => t.id === "agent-harnesses-are-state-machines") ??
  thoughts.sort((a, b) => b.data.created.localeCompare(a.data.created))[0]!;
const { Content } = await render(entry);

// Relation edges from the thought schema (claims/inputs/observations) are the
// only data-model fields not yet surfaced on this page. Resolve each referenced
// slug to its display title and detail-page link; render conditionally so the
// addendum stays absent when a thought has no edges.
const [relatedClaims, relatedInputs, relatedObservations] = await Promise.all([
  getCollection("claims"),
  getCollection("inputs"),
  getCollection("observations"),
]);

const relations = (
  [
    {
      kind: "claims",
      label: "Claims",
      ids: entry.data.claims,
      pool: relatedClaims,
    },
    {
      kind: "inputs",
      label: "Inputs",
      ids: entry.data.inputs,
      pool: relatedInputs,
    },
    {
      kind: "observations",
      label: "Observations",
      ids: entry.data.observations,
      pool: relatedObservations,
    },
  ] as const
)
  .map((group) => ({
    label: group.label,
    links: group.ids.map((id) => {
      const ref = group.pool.find((candidate) => candidate.id === id);
      return {
        href: `/${group.kind}/${id}`,
        title: titleFor(group.kind, ref?.data ?? {}, id),
      };
    }),
  }))
  .filter((group) => group.links.length > 0);

const dateFmt = new Intl.DateTimeFormat("en", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const created = dateFmt.format(new Date(entry.data.created));
const updated = dateFmt.format(new Date(entry.data.updated));
const tags = entry.data.tags ?? [];
---

<ThinkinglabsUiPage
  title={entry.data.title}
  description={`Thought: ${entry.data.title}`}
  robots="noindex"
  allowScroll
>
  <main class="font-sans flex flex-col gap-y-2 pb-8">
    <div class="tl-hero-frame relative h-dvh p-2">
      <Image
        src={heroImage}
        alt={entry.data.title}
        widths={[480, 768, 1024, 1280, 1600, 2048]}
        sizes="(min-width: 768px) 75vw, 100vw"
        format="webp"
        quality={80}
        class="tl-hero-media h-full w-full object-cover md:w-3/4"
      />

      <aside
        class="tl-nav-badge fixed rounded-full overflow-hidden aspect-square top-2 left-2 lg:left-auto lg:right-0 lg:top-0 z-20"
      >
        <input id="tl-nav" type="checkbox" class="tl-nav-toggle peer sr-only" />
        <label
          for="tl-nav"
          class="block cursor-pointer origin-top-right lg:scale-75"
          aria-label="Open navigation"
        >
          <BrandLogo ariaLabel="thinkinglabs" />
        </label>

        <div
          class="invisible fixed inset-0 z-50 flex scale-95 flex-col bg-white p-2 text-black opacity-0 transition duration-200 ease-out origin-top-left peer-checked:visible peer-checked:scale-100 peer-checked:opacity-100 lg:origin-top-right"
        >
          <div class="flex flex-col gap-10 lg:items-end">
            <label
              for="tl-nav"
              class="flex cursor-pointer items-center gap-2"
              aria-label="Close navigation"
            >
              <BrandLogo class="text-black!" />
              <span class="text-sm tracking-tight">thinkinglabs</span>
            </label>

            <nav>
              <ul
                class="flex list-none flex-col gap-1 p-0 lg:items-end lg:text-right"
              >
                <li>
                  <a
                    class="text-sm text-black no-underline transition-opacity hover:opacity-50"
                    href="/now">now</a
                  >
                </li>
                <li>
                  <a
                    class="text-sm text-black no-underline transition-opacity hover:opacity-50"
                    href="/thoughts">thoughts</a
                  >
                </li>
                <li>
                  <a
                    class="text-sm text-black no-underline transition-opacity hover:opacity-50"
                    href="/claims">claims</a
                  >
                </li>
                <li>
                  <a
                    class="text-sm text-black no-underline transition-opacity hover:opacity-50"
                    href="/predictions">predictions</a
                  >
                </li>
                <li>
                  <a
                    class="text-sm text-black no-underline transition-opacity hover:opacity-50"
                    href="/decisions">decisions</a
                  >
                </li>
                <li>
                  <a
                    class="text-sm text-black no-underline transition-opacity hover:opacity-50"
                    href="/experiments">experiments</a
                  >
                </li>
                <li>
                  <a
                    class="text-sm text-black no-underline transition-opacity hover:opacity-50"
                    href="/observations">observations</a
                  >
                </li>
                <li>
                  <a
                    class="text-sm text-black no-underline transition-opacity hover:opacity-50"
                    href="/changed-my-mind">changed my mind</a
                  >
                </li>
                <li>
                  <a
                    class="text-sm text-black no-underline transition-opacity hover:opacity-50"
                    href="/about">about</a
                  >
                </li>
                <li>
                  <a
                    class="text-sm text-black no-underline transition-opacity hover:opacity-50"
                    href="/contact">contact</a
                  >
                </li>
              </ul>
            </nav>
          </div>
        </div>
      </aside>

      <aside
        class="absolute top-1/2 -translate-y-1/2 left-4 right-4 md:right-auto"
      >
        <!-- Needs to stay gray-50 regardless of theme -->
        <h2 class="font-normal text-gray-50">{entry.data.title}</h2>
      </aside>
    </div>

    <section
      class="px-2 flex flex-col gap-4 md:pr-8 lg:max-w-3/4 lg:flex-row lg:justify-end lg:pr-2 lg:gap-16"
    >
      <header class="flex flex-col">
        <p class="text-sm opacity-70">
          <time datetime={entry.data.created}>{created}</time>
          {
            updated !== created && (
              <>
                {" · updated "}
                <time datetime={entry.data.updated}>{updated}</time>
              </>
            )
          }
        </p>
        {
          tags.length > 0 && (
            <ul class="flex flex-wrap gap-x-1 list-none p-0">
              {tags.map((tag) => (
                <li class="text-sm opacity-50">#{tag}</li>
              ))}
            </ul>
          )
        }
      </header>
      <article class="entity-prose md:pl-16 lg:pl-0">
        <Content />
      </article>
    </section>

    {
      relations.length > 0 && (
        <footer class="flex flex-col px-2 md:pr-8 lg:max-w-3/4 lg:items-end lg:pr-2">
          <dl class="flex w-full flex-col gap-6 border-t border-black/10 pt-6 lg:max-w-prose">
            {relations.map((group) => (
              <div class="flex flex-col gap-1">
                <dt class="text-sm opacity-50">{group.label}</dt>
                {group.links.map((link) => (
                  <dd class="m-0">
                    <a
                      class="text-sm no-underline opacity-80 transition-opacity hover:opacity-100"
                      href={link.href}
                    >
                      {link.title}
                    </a>
                  </dd>
                ))}
              </div>
            ))}
          </dl>
        </footer>
      )
    }
  </main>
</ThinkinglabsUiPage>

<style>
  /* The nav badge sits transparent over the hero, then fades to a solid
     black disc once the hero has scrolled fully out of view, so the logo
     stays legible against the page background. Driven entirely by a
     scroll-driven view-timeline (no JS). The timeline is declared on the
     hero image and exposed to the fixed badge via timeline-scope on their
     shared frame. Chromium-only today; @supports keeps it transparent as a
     graceful fallback in Safari/Firefox instead of always-black. */
  .tl-nav-badge {
    background-color: transparent;
  }

  @keyframes tl-nav-badge-reveal {
    from {
      background-color: transparent;
    }
    to {
      background-color: #000;
    }
  }

  @supports (animation-timeline: view()) {
    .tl-hero-frame {
      timeline-scope: --tl-hero;
    }

    .tl-hero-media {
      view-timeline-name: --tl-hero;
    }

    .tl-nav-badge {
      animation: tl-nav-badge-reveal linear both;
      animation-timeline: --tl-hero;
      animation-range: exit;
    }
  }

  .entity-prose {
    max-width: 65ch;
  }

  /* <Content /> markup is not Tailwind-aware during migration, so space
     paragraphs with plain scoped CSS reaching into the rendered markdown. */
  .entity-prose :global(p) {
    margin-block: 1.5em;
  }
</style>
