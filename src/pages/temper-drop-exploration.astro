---
import { getCollection, render } from "astro:content";
import ThinkinglabsUiPage from "../layouts/ThinkinglabsUiPage.astro";
import BrandLogo from "../frontend/thinkinglabs-ui/components/BrandLogo.astro";

const thoughts = await getCollection("thoughts");
const entry = thoughts.sort((a, b) =>
  b.data.created.localeCompare(a.data.created),
)[0]!;
const { Content } = await render(entry);

const dateFmt = new Intl.DateTimeFormat("en", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const created = dateFmt.format(new Date(entry.data.created));
const updated = dateFmt.format(new Date(entry.data.updated));
const tags = entry.data.tags ?? [];
---

<ThinkinglabsUiPage
  title={entry.data.title}
  description={`Thought: ${entry.data.title}`}
  robots="noindex"
  allowScroll
>
  <main class="font-sans gap-y-2">
    <aside class="fixed top-0 right-0 origin-top-right scale-75">
      <BrandLogo ariaLabel="thinkinglabs" />
    </aside>
    <div class="relative h-dvh p-2">
      <img
        src="/images/hero.png"
        alt={entry.data.title}
        class="h-full w-3/4 object-cover"
      />

      <aside class="absolute top-1/2 -translate-y-1/2 left-4">
        <!-- Needs to stay gray-50 regardless of theme -->
        <h2 class="font-normal text-gray-50">{entry.data.title}</h2>
      </aside>
    </div>

    <section class="px-2 max-w-3/4 flex justify-end">
      <header class="flex flex-col">
        <p class="text-sm opacity-70">
          <time datetime={entry.data.created}>{created}</time>
          {
            updated !== created && (
              <>
                {" · updated "}
                <time datetime={entry.data.updated}>{updated}</time>
              </>
            )
          }
        </p>
        {
          tags.length > 0 && (
            <ul class="flex flex-wrap gap-x-1 list-none p-0">
              {tags.map((tag) => (
                <li class="text-sm opacity-50">#{tag}</li>
              ))}
            </ul>
          )
        }
      </header>
      <article class="entity-prose">
        <Content />
      </article>
    </section>
  </main>
</ThinkinglabsUiPage>

<style>
  .entity-prose {
    max-width: 65ch;
  }

  /* <Content /> markup is not Tailwind-aware during migration, so space
     paragraphs with plain scoped CSS reaching into the rendered markdown. */
  .entity-prose :global(p) {
    margin-block: 1.5em;
  }
</style>
