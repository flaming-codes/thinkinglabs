---
import { getCollection, render } from "astro:content";
import ThinkinglabsUiPage from "../layouts/ThinkinglabsUiPage.astro";
import EntityDetail from "../frontend/thinkinglabs-ui/components/EntityDetail.astro";
import type { EntityRelationGroup } from "../frontend/thinkinglabs-ui/components/EntityDetail.astro";
import { titleFor } from "../lib/registry.ts";
import heroImage from "../assets/hero.png";

const thoughts = await getCollection("thoughts");
// Exploration page: prefer a thought with populated relation edges so the
// addendum renders; fall back to the most recent thought otherwise.
const entry =
  thoughts.find((t) => t.id === "agent-harnesses-are-state-machines") ??
  thoughts.sort((a, b) => b.data.created.localeCompare(a.data.created))[0]!;
const { Content } = await render(entry);

// Relation edges from the thought schema (claims/inputs/observations) are the
// only data-model fields not yet surfaced on this page. Resolve each referenced
// slug to its display title and detail-page link; the component drops empty
// groups so the addendum stays absent when a thought has no edges.
const [relatedClaims, relatedInputs, relatedObservations] = await Promise.all([
  getCollection("claims"),
  getCollection("inputs"),
  getCollection("observations"),
]);

const relations: EntityRelationGroup[] = (
  [
    {
      kind: "claims",
      label: "Claims",
      ids: entry.data.claims,
      pool: relatedClaims,
    },
    {
      kind: "inputs",
      label: "Inputs",
      ids: entry.data.inputs,
      pool: relatedInputs,
    },
    {
      kind: "observations",
      label: "Observations",
      ids: entry.data.observations,
      pool: relatedObservations,
    },
  ] as const
)
  .map((group) => ({
    label: group.label,
    links: group.ids.map((id) => {
      const ref = group.pool.find((candidate) => candidate.id === id);
      return {
        href: `/${group.kind}/${id}`,
        title: titleFor(group.kind, ref?.data ?? {}, id),
      };
    }),
  }))
  .filter((group) => group.links.length > 0);

const dateFmt = new Intl.DateTimeFormat("en", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const createdLabel = dateFmt.format(new Date(entry.data.created));
const updatedLabel = dateFmt.format(new Date(entry.data.updated));
const dates =
  updatedLabel === createdLabel
    ? [{ label: createdLabel, iso: entry.data.created }]
    : [
        { label: createdLabel, iso: entry.data.created },
        { label: `updated ${updatedLabel}`, iso: entry.data.updated },
      ];
---

<ThinkinglabsUiPage
  title={entry.data.title}
  description={`Thought: ${entry.data.title}`}
  robots="noindex"
  allowScroll
>
  <EntityDetail
    title={entry.data.title}
    dates={dates}
    tags={entry.data.tags ?? []}
    heroImage={heroImage}
    relations={relations}
  >
    <Content />
  </EntityDetail>
</ThinkinglabsUiPage>
