---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import Base from "../../layouts/Base.astro";
import MetaBlock from "../../components/MetaBlock.astro";
import StatusPill from "../../components/StatusPill.astro";
import Tags from "../../components/Tags.astro";
import { projectLastTouched } from "../../lib/projects.ts";
import { stripKindPrefix } from "../../lib/refs.ts";

export const getStaticPaths = (async () => {
  const items = await getCollection("projects");
  return items.map((p) => ({ params: { slug: p.id }, props: { entry: p } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const { Content } = await render(entry);
const lastTouched = await projectLastTouched(entry.id);
---
<Base title={`${entry.data.title} — Projects`}>
  <h1>{entry.data.title} <StatusPill status={entry.data.status} /></h1>
  <MetaBlock
    data={{ ...entry.data, last_touched: lastTouched }}
    fields={[
      ["started", "started"],
      ["last touched", "last_touched"],
      ["current question", "current_question"],
      ["help welcome", "help_welcome"],
    ]}
  />
  <Tags tags={entry.data.tags} />
  <article><Content /></article>
  {entry.data.related_thoughts.length > 0 ? (
    <>
      <h2>Related thoughts</h2>
      <ul class="list">
        {entry.data.related_thoughts.map((t) => <li><a href={`/thoughts/${stripKindPrefix(t)}`}>{t}</a></li>)}
      </ul>
    </>
  ) : null}
  {entry.data.related_claims.length > 0 ? (
    <>
      <h2>Related claims</h2>
      <ul class="list">
        {entry.data.related_claims.map((c) => <li><a href={`/claims/${stripKindPrefix(c)}`}>{c}</a></li>)}
      </ul>
    </>
  ) : null}
</Base>
