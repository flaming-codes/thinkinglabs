---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import ProjectDetailPageComposition from "../../frontend/thinkinglabs-ui/pages/ProjectDetailPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { projectLastTouched } from "../../lib/projects.ts";
import { buildClaimLookup, buildTitleLookup, mapProjectDetail } from "../../lib/thinkinglabs-ui.ts";
import { projectStructuredData } from "../../lib/structured-data.ts";

export const getStaticPaths = (async () => {
  const items = await getCollection("projects");
  return items.map((p) => ({ params: { slug: p.id }, props: { entry: p } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const { Content } = await render(entry);
const lastTouched = await projectLastTouched(entry.id);
const [thoughts, claims] = await Promise.all([getCollection("thoughts"), getCollection("claims")]);
const lookups = buildTitleLookup({ thoughts, claims });
const claimLookup = buildClaimLookup(claims);
const project = mapProjectDetail({ entry, lastTouched, lookups, claimLookup });
const site = Astro.site ?? new URL(Astro.url.origin);
---
<ThinkinglabsUiPage
  title={entry.data.title}
  description={entry.data.current_question ?? entry.data.help_welcome}
  structuredData={projectStructuredData(entry, Astro.url, site, lastTouched)}
  ogType="article"
  allowScroll
>
  <ProjectDetailPageComposition project={project}>
    <Content />
  </ProjectDetailPageComposition>
</ThinkinglabsUiPage>
