---
import { getCollection } from "astro:content";
import ProjectsListingPageComposition from "../../frontend/thinkinglabs-ui/pages/ProjectsListingPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { mapProjectsView } from "../../lib/thinkinglabs-ui.ts";
import { projectLastTouched } from "../../lib/projects.ts";
import { listStructuredData } from "../../lib/structured-data.ts";

const entries = await getCollection("projects");
const lastTouchedEntries = await Promise.all(
  entries.map(async (entry) => [entry.id, await projectLastTouched(entry.id)] as const),
);
const lastTouchedById = new Map(lastTouchedEntries);
const view = mapProjectsView({ entries, lastTouchedById });
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title="Projects — Tom"
  description="Active and dormant work, grouped by status."
  allowScroll
  structuredData={listStructuredData(
    Astro.url,
    site,
    "Projects",
    entries.map((p) => ({ id: p.id, name: p.data.title, url: `/projects/${p.id}` })),
  )}
>
  <ProjectsListingPageComposition view={view} />
</ThinkinglabsUiPage>
