---
import AppShell from "../frontend/thinkinglabs-ui/components/AppShell.astro";
import ThinkinglabsUiPage from "../layouts/ThinkinglabsUiPage.astro";
import { iconPrototypeAgents, iconPrototypes } from "../lib/icon-prototypes";

const tagCounts = new Map<string, number>();

iconPrototypes.forEach((icon) => {
  icon.tags.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  });
});

const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 14);
---

<ThinkinglabsUiPage
  title="Icon prototypes — thinkinglabs"
  description="One-off inspection page for restrained monochrome cartographer icon directions."
  robots="noindex"
>
  <AppShell activeNav="Index" hideSelectedHud>
    <section class="tl-page-head tl-icons-hero">
      <div>
        <div class="tl-eyebrow">/icon-prototypes</div>
        <h1>Restrained cartographer marks.</h1>
      </div>
      <p class="tl-page-sub">
        A minimal monochrome pass for thinkinglabs: terrain, routes, survey marks, strata,
        coordinates, and chart surfaces reduced to one quiet visual system.
      </p>
    </section>

    <section class="tl-icons-dashboard" aria-label="Icon prototype summary">
      <div class="tl-icons-stat">
        <span>{iconPrototypes.length}</span>
        <p>SVGs</p>
      </div>
      <div class="tl-icons-stat">
        <span>{iconPrototypeAgents.length}</span>
        <p>agent</p>
      </div>
      <div class="tl-icons-tags" aria-label="Common tags">
        {
          topTags.map(([tag, count]) => (
            <span>
              {tag}
              <small>{count}</small>
            </span>
          ))
        }
      </div>
    </section>

    <div class="tl-icons-agent-stack">
      {
        iconPrototypeAgents.map((agent, agentIndex) => (
          <section class="tl-icons-agent" data-selected-label={agent.name}>
            <header class="tl-icons-agent-head">
              <div>
                <div class="tl-eyebrow">{String(agentIndex + 1).padStart(2, "0")} / creative agent</div>
                <h2>{agent.name}</h2>
              </div>
              <p>{agent.style}</p>
            </header>

            <div class="tl-icons-grid">
              {
                agent.icons.map((icon, iconIndex) => (
                  <article class="tl-icon-card">
                    <div class="tl-icon-frame" set:html={icon.svg} />
                    <div class="tl-icon-meta">
                      <div class="tl-icon-number">{String(iconIndex + 1).padStart(2, "0")}</div>
                      <div>
                        <h3>{icon.title}</h3>
                        <p>{icon.concept}</p>
                      </div>
                    </div>
                    <div class="tl-icon-tags">
                      {icon.tags.slice(0, 4).map((tag) => (
                        <span>{tag}</span>
                      ))}
                    </div>
                  </article>
                ))
              }
            </div>
          </section>
        ))
      }
    </div>
  </AppShell>
</ThinkinglabsUiPage>

<style>
  .tl-icons-hero {
    gap: var(--tl-space-8);
    align-items: end;
    width: min(92rem, calc(100vw - 48px));
    min-height: 58vh;
    margin-inline: auto;
  }

  .tl-icons-hero .tl-page-sub {
    max-width: 42rem;
  }

  .tl-icons-dashboard,
  .tl-icons-agent-stack {
    width: min(92rem, calc(100vw - 48px));
    margin-inline: auto;
  }

  .tl-icons-dashboard {
    display: grid;
    grid-template-columns: 10rem 10rem minmax(0, 1fr);
    gap: var(--tl-space-8);
    align-items: stretch;
    padding: var(--tl-space-8) 0 var(--tl-space-16);
    border-top: 1px solid var(--tl-line);
  }

  .tl-icons-stat {
    display: grid;
    align-content: space-between;
    min-height: 8rem;
    padding: var(--tl-space-8);
    border: 1px solid var(--tl-line);
    border-radius: var(--tl-radius-md);
    background: color-mix(in srgb, var(--tl-bg) 88%, var(--tl-soft));
  }

  .tl-icons-stat span {
    font-size: clamp(38px, 5vw, 72px);
    font-weight: 650;
    line-height: 0.9;
    letter-spacing: var(--tl-type-track-tight);
  }

  .tl-icons-stat p,
  .tl-icons-agent-head p,
  .tl-icon-card p {
    color: var(--tl-muted);
    font-size: 13px;
    line-height: 1.45;
  }

  .tl-icons-tags {
    display: flex;
    flex-wrap: wrap;
    align-content: start;
    gap: var(--tl-space-3);
    padding: var(--tl-space-8);
    border: 1px solid var(--tl-line);
    border-radius: var(--tl-radius-md);
  }

  .tl-icons-tags span,
  .tl-icon-tags span {
    display: inline-flex;
    gap: var(--tl-space-2);
    align-items: center;
    min-height: 1.6rem;
    padding: 0.32rem 0.5rem;
    border: 1px solid var(--tl-line);
    border-radius: var(--tl-radius-xs);
    color: var(--tl-muted);
    font-size: 11px;
    font-weight: 650;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tl-icons-tags small {
    color: var(--tl-ink);
    font-size: 10px;
  }

  .tl-icons-agent-stack {
    display: grid;
    gap: clamp(5rem, 9vw, 9rem);
    padding-bottom: 18vh;
  }

  .tl-icons-agent {
    display: grid;
    gap: var(--tl-space-10);
  }

  .tl-icons-agent-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(12rem, 18rem);
    gap: var(--tl-space-12);
    align-items: end;
    padding-bottom: var(--tl-space-8);
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-icons-agent-head h2 {
    margin-top: var(--tl-space-4);
    font-size: clamp(28px, 4vw, 56px);
    font-weight: 650;
    line-height: 0.95;
    letter-spacing: var(--tl-type-track-heading);
    text-transform: uppercase;
  }

  .tl-icons-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: var(--tl-space-7);
  }

  .tl-icon-card {
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-height: 21rem;
    padding: var(--tl-space-8);
    border: 1px solid var(--tl-line);
    border-radius: var(--tl-radius-md);
    background: color-mix(in srgb, var(--tl-bg) 92%, var(--tl-soft));
    transition:
      border-color var(--tl-motion-fast) var(--tl-ease-standard),
      box-shadow var(--tl-motion-base) var(--tl-ease-standard),
      transform var(--tl-motion-base) var(--tl-ease-standard);
  }

  .tl-icon-card:hover {
    border-color: color-mix(in srgb, var(--tl-ink) 30%, var(--tl-line));
    box-shadow: var(--tl-gallery-shadow);
    transform: translateY(-2px);
  }

  .tl-icon-frame {
    display: grid;
    place-items: center;
    width: 100%;
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--tl-ink) 8%, transparent);
    border-radius: var(--tl-radius-sm);
    background:
      linear-gradient(color-mix(in srgb, var(--tl-ink) 3.5%, transparent) 1px, transparent 1px),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--tl-ink) 3.5%, transparent) 1px,
        transparent 1px
      ),
      var(--tl-bg);
    background-size: 16px 16px;
  }

  .tl-icon-frame :global(svg) {
    display: block;
    width: min(72%, 8rem);
    height: auto;
    overflow: visible;
  }

  .tl-icon-meta {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: var(--tl-space-5);
    padding-top: var(--tl-space-7);
  }

  .tl-icon-number {
    color: var(--tl-faint);
    font-size: 11px;
    font-weight: 650;
    letter-spacing: 0.12em;
  }

  .tl-icon-card h3 {
    margin: 0 0 var(--tl-space-3);
    font-size: 15px;
    font-weight: 650;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .tl-icon-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--tl-space-2);
    padding-top: var(--tl-space-7);
  }

  .tl-icon-tags span {
    min-height: 1.35rem;
    padding: 0.24rem 0.38rem;
    font-size: 9px;
  }

  @media (max-width: 1180px) {
    .tl-icons-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 920px) {
    .tl-icons-hero,
    .tl-icons-agent-head,
    .tl-icons-dashboard {
      grid-template-columns: 1fr;
    }

    .tl-icons-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .tl-icons-hero,
    .tl-icons-dashboard,
    .tl-icons-agent-stack {
      width: min(100% - 28px, 92rem);
    }

    .tl-icons-grid {
      grid-template-columns: 1fr;
    }

    .tl-icon-card {
      min-height: 0;
    }
  }
</style>
