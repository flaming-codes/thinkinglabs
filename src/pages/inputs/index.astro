---
import { getCollection } from "astro:content";
import InputsListingPageComposition from "../../frontend/thinkinglabs-ui/pages/InputsListingPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { inputCitationCounts, mapInputsView } from "../../lib/thinkinglabs-ui.ts";
import { listStructuredData } from "../../lib/structured-data.ts";

const [entries, thoughts, claims, predictions] = await Promise.all([
  getCollection("inputs"),
  getCollection("thoughts"),
  getCollection("claims"),
  getCollection("predictions"),
]);
const citationsBySlug = inputCitationCounts({ inputs: entries, thoughts, claims, predictions });
const view = mapInputsView({ entries, citationsBySlug });
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title="Inputs — Tom"
  description="External material that shaped thinking."
  structuredData={listStructuredData(
    Astro.url,
    site,
    "Inputs",
    entries.map((i) => ({ id: i.id, name: i.data.title, url: `/inputs/${i.id}` })),
  )}
>
  <InputsListingPageComposition view={view} />
</ThinkinglabsUiPage>
