---
import { getCollection } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import InputDetailMinimalPageComposition from "../../frontend/thinkinglabs-ui/pages/InputDetailMinimalPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { inputCitationBacklinks, mapInputDetail } from "../../lib/thinkinglabs-ui.ts";
import { inputStructuredData } from "../../lib/structured-data.ts";

export const getStaticPaths = (async () => {
  const items = await getCollection("inputs");
  return items.map((i) => ({ params: { slug: i.id }, props: { entry: i } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const [thoughts, claims, predictions, posts] = await Promise.all([
  getCollection("thoughts"),
  getCollection("claims"),
  getCollection("predictions"),
  getCollection("posts"),
]);
const citations = inputCitationBacklinks({
  targetSlug: entry.id,
  thoughts,
  claims,
  predictions,
  posts,
});
const input = mapInputDetail({ entry, citations });
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title={entry.data.title}
  description={entry.data.note ?? entry.data.source ?? entry.data.title}
  structuredData={inputStructuredData(entry, Astro.url, site)}
  ogType="article"
>
  <InputDetailMinimalPageComposition input={input} />
</ThinkinglabsUiPage>
