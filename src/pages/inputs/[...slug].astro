---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import Base from "../../layouts/Base.astro";
import MetaBlock from "../../components/MetaBlock.astro";
import Tags from "../../components/Tags.astro";
import { inputStructuredData } from "../../lib/structured-data.ts";

export const getStaticPaths = (async () => {
  const items = await getCollection("inputs");
  return items.map((i) => ({ params: { slug: i.id }, props: { entry: i } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const { Content } = await render(entry);
const site = Astro.site ?? new URL(Astro.url.origin);
---
<Base
  title={`${entry.data.title} — Inputs`}
  description={entry.data.note ?? entry.data.source ?? entry.data.title}
  structuredData={inputStructuredData(entry, Astro.url, site)}
>
  <h1>{entry.data.title}</h1>
  <MetaBlock
    data={entry.data}
    fields={[
      ["consumed", "consumed"],
      ["source", "source"],
      ["note", "note"],
    ]}
  />
  {entry.data.url ? (
    <p><a href={entry.data.url}>{entry.data.url}</a></p>
  ) : null}
  <Tags tags={entry.data.tags} />
  <article><Content /></article>
</Base>
