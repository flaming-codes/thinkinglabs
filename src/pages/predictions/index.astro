---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import EmptyState from "../../components/EmptyState.astro";
import { byDateDesc } from "../../lib/sort.ts";

const all = byDateDesc(await getCollection("predictions"), "made");
const pending = all.filter((p) => p.data.resolution === "pending");
const resolved = all.filter((p) => p.data.resolution !== "pending");
---
<Base title="Predictions — Tom">
  <h1>Predictions</h1>
  <p class="meta"><a href="/predictions/calibration">See calibration plot</a>.</p>

  <h2>Pending</h2>
  {pending.length === 0 ? <EmptyState message="(no pending predictions)" /> : (
    <ul class="list">
      {pending.map((p) => (
        <li>
          <a href={`/predictions/${p.id}`}>{p.data.prediction}</a>
          <div class="meta">
            made {p.data.made.slice(0, 10)} · resolves {p.data.resolves.slice(0, 10)} · confidence {p.data.confidence}
          </div>
        </li>
      ))}
    </ul>
  )}

  <h2>Resolved</h2>
  {resolved.length === 0 ? <EmptyState message="(no resolved predictions)" /> : (
    <ul class="list">
      {resolved.map((p) => (
        <li>
          <a href={`/predictions/${p.id}`}>{p.data.prediction}</a>
          <div class="meta">
            made {p.data.made.slice(0, 10)} · resolves {p.data.resolves.slice(0, 10)} · confidence {p.data.confidence} · {p.data.resolution}
          </div>
        </li>
      ))}
    </ul>
  )}
</Base>
