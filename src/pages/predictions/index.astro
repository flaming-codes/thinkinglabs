---
import { getCollection } from "astro:content";
import PredictionsListingPageComposition from "../../frontend/thinkinglabs-ui/pages/PredictionsListingPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { mapPredictionsView } from "../../lib/thinkinglabs-ui.ts";
import { listStructuredData } from "../../lib/structured-data.ts";

const entries = await getCollection("predictions");
const view = mapPredictionsView({ entries });
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title="Predictions — Tom"
  description="Falsifiable predictions, pending and resolved."
  structuredData={listStructuredData(
    Astro.url,
    site,
    "Predictions",
    entries.map((p) => ({ id: p.id, name: p.data.prediction, url: `/predictions/${p.id}` })),
  )}
>
  <PredictionsListingPageComposition view={view} />
</ThinkinglabsUiPage>
