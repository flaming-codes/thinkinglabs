---
import { render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import Base from "../../layouts/Base.astro";
import MetaBlock from "../../components/MetaBlock.astro";
import Tags from "../../components/Tags.astro";
import { getKindStaticPaths } from "../../lib/route-helpers.ts";
import { predictionStructuredData } from "../../lib/structured-data.ts";

export const getStaticPaths = (async () => {
  return getKindStaticPaths("predictions");
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const { Content } = await render(entry);
const site = Astro.site ?? new URL(Astro.url.origin);
---
<Base
  title={`Prediction — ${entry.data.prediction.slice(0, 60)}`}
  description={entry.data.prediction}
  structuredData={predictionStructuredData(entry, Astro.url, site)}
>
  <h1>{entry.data.prediction}</h1>
  <MetaBlock
    data={entry.data}
    fields={[
      ["made", "made"],
      ["resolves", "resolves"],
      ["confidence", "confidence"],
      ["resolution", "resolution"],
      ["resolved on", "resolved_on"],
      ["resolution note", "resolution_note"],
    ]}
  />
  <Tags tags={entry.data.tags} />
  <article><Content /></article>
</Base>
