---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import PredictionDetailPageComposition from "../../frontend/thinkinglabs-ui/pages/PredictionDetailPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { buildTitleLookup, mapPredictionDetail } from "../../lib/thinkinglabs-ui.ts";
import { getKindStaticPaths } from "../../lib/route-helpers.ts";
import { predictionStructuredData } from "../../lib/structured-data.ts";

export const getStaticPaths = (async () => {
  return getKindStaticPaths("predictions");
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const [thoughts, claims, inputs, observations] = await Promise.all([
  getCollection("thoughts"),
  getCollection("claims"),
  getCollection("inputs"),
  getCollection("observations"),
]);
const lookups = buildTitleLookup({ thoughts, claims, inputs, observations });
const prediction = mapPredictionDetail({ entry, lookups });
const { Content } = await render(entry);
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title={entry.data.prediction.slice(0, 60)}
  description={entry.data.prediction}
  structuredData={predictionStructuredData(entry, Astro.url, site)}
  ogType="article"
  allowScroll
>
  <PredictionDetailPageComposition prediction={prediction}>
    <Content />
  </PredictionDetailPageComposition>
</ThinkinglabsUiPage>
