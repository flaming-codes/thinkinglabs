---
import { getCollection } from "astro:content";
import CalibrationPageComposition from "../../frontend/thinkinglabs-ui/pages/CalibrationPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { mapCalibrationData } from "../../lib/thinkinglabs-ui.ts";

const predictions = await getCollection("predictions");
const calibration = mapCalibrationData(predictions);
---

<ThinkinglabsUiPage
  title="Calibration — Predictions"
  description="Stated confidence versus realized accuracy across resolved predictions."
>
  <CalibrationPageComposition calibration={calibration} />
</ThinkinglabsUiPage>
