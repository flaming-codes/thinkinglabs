---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection } from "astro:content";
import { resolve } from "node:path";
import ClaimDetailPageComposition from "../../frontend/thinkinglabs-ui/pages/ClaimDetailPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { parseClaimHistory } from "../../lib/claim-history.ts";
import { walkFileHistory } from "../../lib/git.ts";
import { getKindStaticPaths } from "../../lib/route-helpers.ts";
import { buildTitleLookup, mapClaimDetail } from "../../lib/thinkinglabs-ui.ts";
import { claimStructuredData } from "../../lib/structured-data.ts";

export const getStaticPaths = (async () => {
  return getKindStaticPaths("claims");
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const thoughts = await getCollection("thoughts");
const cwd = resolve(".");
const relPath = `content/claims/${entry.id}.md`;
const history = parseClaimHistory(walkFileHistory(cwd, relPath));
const lookups = buildTitleLookup({ thoughts });
const claim = mapClaimDetail({ entry, history, lookups });
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title={`${entry.data.claim.slice(0, 60)} — Claims`}
  description={entry.data.claim}
  structuredData={claimStructuredData(entry, Astro.url, site)}
>
  <ClaimDetailPageComposition claim={claim} />
</ThinkinglabsUiPage>
