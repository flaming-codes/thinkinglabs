---
import { getCollection } from "astro:content";
import ClaimsListingPageComposition from "../../frontend/thinkinglabs-ui/pages/ClaimsListingPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { mapClaimSummaries } from "../../lib/thinkinglabs-ui.ts";
import { listStructuredData } from "../../lib/structured-data.ts";

const items = await getCollection("claims");
const claims = mapClaimSummaries(items);
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title="Claims — Tom"
  description="Atomic structured claims with confidence and evidence."
  structuredData={listStructuredData(
    Astro.url,
    site,
    "Claims",
    items.map((claim) => ({ id: claim.id, name: claim.data.claim, url: `/claims/${claim.id}` })),
  )}
>
  <ClaimsListingPageComposition claims={claims} totalCount={items.length} />
</ThinkinglabsUiPage>
