---
import { getCollection } from "astro:content";
import NowPageComposition from "../frontend/thinkinglabs-ui/pages/NowPageComposition.astro";
import ThinkinglabsUiPage from "../layouts/ThinkinglabsUiPage.astro";
import { mapNowData } from "../lib/thinkinglabs-ui.ts";
import { listStructuredData } from "../lib/structured-data.ts";

const [projects, inputs] = await Promise.all([getCollection("projects"), getCollection("inputs")]);
const alive = projects.filter((project) => project.data.status === "alive");
const now = mapNowData({ projects, inputs });
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title="Now — Tom"
  description="What I'm currently focused on."
  structuredData={listStructuredData(
    Astro.url,
    site,
    "Active projects",
    alive.map((project) => ({
      id: project.id,
      name: project.data.title,
      url: `/projects/${project.id}`,
    })),
  )}
>
  <NowPageComposition now={now} />
</ThinkinglabsUiPage>
