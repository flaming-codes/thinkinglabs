---
import heroImage from "@/assets/error.png";
import DetailPage from "../frontend/thinkinglabs-ui/components/DetailPage.astro";
import ThinkinglabsUiPage from "../layouts/ThinkinglabsUiPage.astro";
---

<ThinkinglabsUiPage
  title="Not found — thinkinglabs"
  description="That page does not exist on thinkinglabs."
  robots="noindex"
  allowScroll
>
  <DetailPage
    title="Not found"
    heroAlt="Page not found"
    heroImage={heroImage}
    dates={[{ label: "Error 404" }]}
  >
    <p>
      The URL you followed does not match anything in the source tree. Pages
      here are generated from a public markdown repository, so links break when
      files are renamed, retired, or merged into something else.
    </p>
    <p><a class="tl-token-link" href="/">Back to the index</a></p>
  </DetailPage>
</ThinkinglabsUiPage>
