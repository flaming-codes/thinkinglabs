---
import { getCollection } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import ObservationDetailPageComposition from "../../frontend/thinkinglabs-ui/pages/ObservationDetailPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { getKindStaticPaths } from "../../lib/route-helpers.ts";
import {
  buildClaimLookup,
  buildTitleLookup,
  mapObservationDetail,
} from "../../lib/thinkinglabs-ui.ts";
import { observationStructuredData } from "../../lib/structured-data.ts";

export const getStaticPaths = (async () => {
  return getKindStaticPaths("observations");
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const [claims, thoughts, projects] = await Promise.all([
  getCollection("claims"),
  getCollection("thoughts"),
  getCollection("projects"),
]);
const lookups = buildTitleLookup({ claims, thoughts, projects });
const claimLookup = buildClaimLookup(claims);
const observation = mapObservationDetail({ entry, lookups, claimLookup });
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title={entry.data.observation.slice(0, 60)}
  description={entry.data.context ?? entry.data.observation}
  structuredData={observationStructuredData(entry, Astro.url, site)}
  ogType="article"
  allowScroll
>
  <ObservationDetailPageComposition observation={observation} />
</ThinkinglabsUiPage>
