---
import { getCollection } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import PostDetailPageComposition from "../../frontend/thinkinglabs-ui/pages/PostDetailPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { buildClaimLookup, buildTitleLookup, mapPostDetail } from "../../lib/thinkinglabs-ui.ts";
import { postStructuredData } from "../../lib/structured-data.ts";

export const getStaticPaths = (async () => {
  const items = await getCollection("posts");
  return items.map((post) => ({ params: { slug: post.id }, props: { entry: post } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const [claims, thoughts, inputs] = await Promise.all([
  getCollection("claims"),
  getCollection("thoughts"),
  getCollection("inputs"),
]);
const lookups = buildTitleLookup({ claims, thoughts, inputs });
const claimLookup = buildClaimLookup(claims);
const inputLookup = new Map(inputs.map((input) => [input.id, input]));
const post = mapPostDetail({ entry, lookups, claimLookup, inputLookup });
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title={entry.data.title}
  description={entry.data.summary}
  structuredData={postStructuredData(entry, Astro.url, site)}
  ogType="article"
>
  <PostDetailPageComposition post={post} />
</ThinkinglabsUiPage>
