---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import Base from "../../layouts/Base.astro";
import MetaBlock from "../../components/MetaBlock.astro";
import RelatedRefs from "../../components/RelatedRefs.astro";
import Tags from "../../components/Tags.astro";
import { postStructuredData } from "../../lib/structured-data.ts";

export const getStaticPaths = (async () => {
  const items = await getCollection("posts");
  return items.map((p) => ({ params: { slug: p.id }, props: { entry: p } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;
const { Content } = await render(entry);
const site = Astro.site ?? new URL(Astro.url.origin);
---
<Base
  title={`${entry.data.title} — Posts`}
  description={entry.data.summary}
  structuredData={postStructuredData(entry, Astro.url, site)}
  ogType="article"
>
  <h1>{entry.data.title}</h1>
  <MetaBlock
    data={entry.data}
    fields={[
      ["created", "created"],
      ["updated", "updated"],
      ["summary", "summary"],
    ]}
  />
  <Tags tags={entry.data.tags} />
  <article><Content /></article>
  <RelatedRefs heading="Related claims" kind="claims" refs={entry.data.related_claims} />
  <RelatedRefs heading="Related thoughts" kind="thoughts" refs={entry.data.related_thoughts} />
</Base>
