---
import { getCollection } from "astro:content";
import PostsListingPageComposition from "../../frontend/thinkinglabs-ui/pages/PostsListingPageComposition.astro";
import ThinkinglabsUiPage from "../../layouts/ThinkinglabsUiPage.astro";
import { mapPostSummaries } from "../../lib/thinkinglabs-ui.ts";
import { listStructuredData } from "../../lib/structured-data.ts";

const items = await getCollection("posts");
const posts = mapPostSummaries(items);
const site = Astro.site ?? new URL(Astro.url.origin);
---

<ThinkinglabsUiPage
  title="Posts — Tom"
  description="Long-form evergreen posts with per-section freshness."
  structuredData={listStructuredData(
    Astro.url,
    site,
    "Posts",
    items.map((post) => ({ id: post.id, name: post.data.title, url: `/posts/${post.id}` })),
  )}
>
  <PostsListingPageComposition posts={posts} />
</ThinkinglabsUiPage>
