---
/** Inline tag list; renders nothing on empty input so callers can drop it in unconditionally. */
interface Props {
  tags: ReadonlyArray<string>;
}
const { tags } = Astro.props;
---
{tags.length > 0 ? (
  <span class="tags">
    {tags.map((t) => <span class="tag">#{t}</span>)}
  </span>
) : null}
