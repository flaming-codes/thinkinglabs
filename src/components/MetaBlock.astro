---
/** Renders frontmatter as a `<dl>`; arrays join on commas, dates pass through as-is so callers control formatting. */
interface Props {
  data: Record<string, unknown>;
  fields: ReadonlyArray<readonly [label: string, key: string]>;
}
const { data, fields } = Astro.props;
const rows = fields
  .map(([label, key]) => [label, data[key]] as const)
  .filter(([, v]) => v !== undefined && v !== null && v !== "" && !(Array.isArray(v) && v.length === 0));
---
{rows.length > 0 ? (
  <dl class="meta-block">
    {rows.map(([label, value]) => (
      <>
        <dt>{label}</dt>
        <dd>{Array.isArray(value) ? (value as unknown[]).join(", ") : String(value)}</dd>
      </>
    ))}
  </dl>
) : null}
