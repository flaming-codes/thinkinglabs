---
import { stripKindPrefix, stripMdExt } from "../lib/refs.ts";
import type { Kind } from "../schemas/index.ts";

/** Kind-agnostic "related X" list; renders nothing when refs is empty so callers can stay declarative. */
interface Props {
  heading: string;
  kind: Kind;
  refs: ReadonlyArray<string>;
  routeBase?: string;
}

const { heading, kind, refs, routeBase } = Astro.props;
const base = routeBase ?? `/${kind}`;
---
{refs.length > 0 ? (
  <>
    <h2>{heading}</h2>
    <ul class="list">
      {refs.map((ref) => {
        const slug = stripKindPrefix(stripMdExt(ref));
        return <li><a href={`${base}/${slug}`}>{ref}</a></li>;
      })}
    </ul>
  </>
) : null}
