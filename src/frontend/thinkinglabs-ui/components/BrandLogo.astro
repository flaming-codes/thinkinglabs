---
interface Props {
  class?: string;
  ariaLabel?: string;
}

const { class: className, ariaLabel } = Astro.props;
---

<span
  class:list={[className, "tl-wordmark"]}
  data-wordmark="thinkinglabs"
  role={ariaLabel ? "img" : undefined}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : "true"}
>
  thinkinglabs
</span>

<style>
  .tl-wordmark {
    position: relative;
    display: inline-grid;
    align-items: center;
    justify-items: center;
    color: transparent;
    font-family: var(--tl-wordmark-font);
    font-size: clamp(28px, 3vw, 44px);
    font-weight: 400;
    line-height: 0.82;
    letter-spacing: 0;
    text-transform: none;
    -webkit-text-fill-color: transparent;
    --tl-wordmark-paint: var(--tl-ink);
    --tl-wordmark-hover-paint: var(--tl-ink);
    --tl-linefont-scale: 1;
    --tl-linefont-size: 44px;
    --tl-hover-font-size: 20px;
  }

  .tl-wordmark::before,
  .tl-wordmark::after {
    grid-area: 1 / 1;
    color: var(--tl-wordmark-paint);
    content: attr(data-wordmark);
    -webkit-text-fill-color: var(--tl-wordmark-paint);
    transition:
      opacity 360ms ease,
      transform 360ms ease;
    transform-origin: center;
  }

  .tl-wordmark::before {
    font-family: var(--tl-wordmark-font);
    font-size: var(--tl-linefont-size);
    font-style: normal;
    font-weight: 300;
    font-optical-sizing: auto;
    font-variation-settings: "wdth" 112.5;
    opacity: 1;
    transform: translateY(-0.08em) scale(var(--tl-linefont-scale));
  }

  .tl-wordmark::after {
    color: var(--tl-wordmark-hover-paint);
    font-family: var(--tl-wordmark-hover-font);
    font-size: var(--tl-hover-font-size);
    font-style: normal;
    font-weight: 300;
    font-variation-settings: normal;
    opacity: 0;
    -webkit-text-fill-color: var(--tl-wordmark-hover-paint);
    transform: translateY(0.18em);
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-wordmark::before,
    .tl-wordmark::after {
      transition: none;
    }
  }
</style>
