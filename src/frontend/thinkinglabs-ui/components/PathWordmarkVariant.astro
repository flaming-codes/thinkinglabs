<svg
  class="tl-path-wordmark"
  viewBox="2 28 312 72"
  preserveAspectRatio="xMidYMid meet"
  aria-hidden="true"
  focusable="false"
>
  {segments.map((segment) => (
    <path
      class="tl-path-wordmark-segment"
      data-segment={segment.id}
      d={segment.d}
      pathLength="1"
    />
  ))}
</svg>

<style>
  .tl-path-wordmark {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .tl-path-wordmark-segment {
    fill: var(--tl-ink);
    fill-opacity: 0;
    stroke: var(--tl-ink);
    stroke-width: 1.45;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    vector-effect: non-scaling-stroke;
    animation:
      tl-path-wordmark-draw var(--duration) cubic-bezier(0.62, 0.01, 0.18, 1) var(--delay) forwards,
      tl-path-wordmark-fill 120ms ease-out calc(var(--delay) + var(--duration) - 50ms) forwards;
  }

  .tl-path-wordmark-segment[data-segment="t"] {
    --delay: 28ms;
    --duration: 60ms;
  }

  .tl-path-wordmark-segment[data-segment="h"] {
    --delay: 63ms;
