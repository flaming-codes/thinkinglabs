  @keyframes tl-path-wordmark-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes tl-path-wordmark-fill {
    to {
      fill-opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-path-wordmark-segment {
      fill-opacity: 1;
      stroke-dashoffset: 0;
      animation: none;
    }
  }
</style>
