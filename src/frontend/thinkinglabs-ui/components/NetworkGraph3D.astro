---
import type { PositionedGraph } from "../../../lib/network-graph-layout.ts";
import type { GraphNode } from "../../../lib/network-graph.ts";
import { KIND_REGISTRY } from "../../../lib/registry.ts";

interface Props {
  layout: PositionedGraph;
  nodes: ReadonlyArray<GraphNode>;
}

const { layout, nodes } = Astro.props;

const nodeMetaById = new Map(nodes.map((n) => [n.id, n]));
const merged = layout.nodes
  .map((p) => {
    const meta = nodeMetaById.get(p.id);
    if (!meta) return null;
    return {
      id: meta.id,
      kind: meta.kind,
      title: meta.title,
      href: meta.href,
      degree: meta.degree,
      x: p.x,
      y: p.y,
      z: p.z,
    };
  })
  .filter((n): n is NonNullable<typeof n> => n !== null);

const payload = { nodes: merged, edges: layout.edges };
const payloadJson = JSON.stringify(payload).replace(/</g, "\\u003c");

const grouped: Record<string, Array<GraphNode>> = {};
for (const n of nodes) {
  (grouped[n.kind] ??= []).push(n);
}
const groupedKinds = Object.keys(grouped).sort();
---

<div class="tl-graph-wrap" data-network-graph-root>
  <script id="network-graph-data" type="application/json" is:inline set:html={payloadJson} />
  <p
    id="tl-graph-description"
    class="tl-graph-sr-only"
    data-graph-description
  >
    Interactive 3D rendering of the knowledge network. Drag to rotate, scroll to
    zoom, and select a node to open it.
  </p>
  <div
    class="tl-graph-hover-label"
    data-graph-hover-label
    role="status"
    aria-live="polite"
  ></div>
  <aside class="tl-graph-legend" aria-label="Node legend">
    <ul>
      {groupedKinds.map((k) => (
        <li class={`tl-graph-legend-row tl-graph-legend-${k}`}>
          <span class="tl-graph-legend-dot" aria-hidden="true"></span>
          <span class="tl-graph-legend-label">{KIND_REGISTRY[k as keyof typeof KIND_REGISTRY]?.listingTitle ?? k}</span>
          <span class="tl-graph-legend-count">{grouped[k]?.length ?? 0}</span>
        </li>
      ))}
    </ul>
  </aside>
</div>

<noscript>
  <section class="tl-graph-fallback">
    <h2>Knowledge graph index</h2>
    <p>The interactive 3D graph requires JavaScript. Below is the same data as a plain list.</p>
    {groupedKinds.map((k) => (
      <section>
        <h3>{KIND_REGISTRY[k as keyof typeof KIND_REGISTRY]?.listingTitle ?? k}</h3>
        <ul>
          {grouped[k]?.map((n) => (
            <li>{n.href ? <a href={n.href}>{n.title}</a> : <span>{n.title}</span>}</li>
          ))}
        </ul>
      </section>
    ))}
  </section>
</noscript>

<script>
  import "./NetworkGraph3D.client.ts";
</script>

<style>
  .tl-graph-wrap {
    position: fixed;
    inset: 0;
    background: var(--tl-graph-bg);
    overflow: hidden;
  }

  .tl-graph-wrap :global(canvas) {
    display: block;
  }

  /* Visually hidden description for assistive technology; referenced by the
     canvas via aria-describedby. */
  .tl-graph-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  .tl-graph-hover-label {
    position: absolute;
    top: calc(var(--tl-ui-top) + clamp(3.25rem, 6vh, 4.5rem));
    left: 50%;
    z-index: 6;
    max-width: min(36rem, calc(100vw - 4rem));
    padding: 0 1rem;
    color: var(--tl-ink);
    font-size: var(--tl-type-caption);
    font-weight: var(--tl-type-heading-weight-strong);
    line-height: 1.35;
    text-align: center;
    pointer-events: none;
    opacity: 0;
    transform: translate(-50%, -6px);
    transition:
      opacity var(--tl-motion-base) var(--tl-ease-standard),
      transform var(--tl-motion-base) var(--tl-ease-emphasized);
  }

  .tl-graph-hover-label.is-visible {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  .tl-graph-legend {
    position: absolute;
    bottom: max(var(--tl-ui-bottom), clamp(1rem, 3vh, 2rem));
    left: 50%;
    z-index: 5;
    padding: var(--tl-space-4) var(--tl-space-8);
    background: var(--tl-pane-bg);
    border: 1px solid var(--tl-pane-border);
    border-radius: var(--tl-radius-pill);
    box-shadow: var(--tl-pane-shadow);
    backdrop-filter: saturate(180%) blur(28px);
    -webkit-backdrop-filter: saturate(180%) blur(28px);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .tl-graph-legend ul {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: max-content;
    gap: 0 var(--tl-space-10);
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tl-graph-legend-row {
    display: inline-flex;
    align-items: center;
    gap: var(--tl-space-3);
    color: var(--tl-ink);
    font-size: var(--tl-type-metadata-size);
    font-weight: 540;
    line-height: var(--tl-type-metadata-line);
    letter-spacing: 0.04em;
  }

  .tl-graph-legend-dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: var(--tl-radius-pill);
    background: var(--tl-soft);
  }

  .tl-graph-legend-count {
    color: var(--tl-muted);
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 720px) {
    .tl-graph-legend {
      padding: var(--tl-space-4) var(--tl-space-6);
      border-radius: var(--tl-radius-lg);
    }

    .tl-graph-legend ul {
      grid-auto-flow: row;
      grid-template-columns: repeat(2, max-content);
      gap: var(--tl-space-2) var(--tl-space-8);
    }
  }

  .tl-graph-legend-thoughts .tl-graph-legend-dot { background: var(--tl-kind-color-thoughts); }
  .tl-graph-legend-claims .tl-graph-legend-dot { background: var(--tl-kind-color-claims); }
  .tl-graph-legend-projects .tl-graph-legend-dot { background: var(--tl-kind-color-projects); }
  .tl-graph-legend-predictions .tl-graph-legend-dot { background: var(--tl-kind-color-predictions); }
  .tl-graph-legend-changed-my-mind .tl-graph-legend-dot { background: var(--tl-kind-color-changed-my-mind); }
  .tl-graph-legend-decisions .tl-graph-legend-dot { background: var(--tl-kind-color-decisions); }
  .tl-graph-legend-questions .tl-graph-legend-dot { background: var(--tl-kind-color-questions); }
  .tl-graph-legend-posts .tl-graph-legend-dot { background: var(--tl-kind-color-posts); }
  .tl-graph-legend-inputs .tl-graph-legend-dot { background: var(--tl-kind-color-inputs); }
  .tl-graph-legend-provenance .tl-graph-legend-dot { background: var(--tl-kind-color-provenance); }

  .tl-graph-fallback {
    position: relative;
    z-index: 10;
    width: min(40rem, calc(100vw - 2 * var(--tl-ui-x)));
    margin: 16vh auto;
    color: var(--tl-ink);
  }

  .tl-graph-fallback h2 {
    margin: 0 0 var(--tl-space-7);
    font-size: var(--tl-type-display-md);
    font-weight: var(--tl-type-heading-weight-strong);
    letter-spacing: var(--tl-type-track-heading);
    text-transform: uppercase;
  }

  .tl-graph-fallback h3 {
    margin: var(--tl-space-12) 0 var(--tl-space-3);
    font-size: var(--tl-type-metadata-size);
    font-weight: var(--tl-type-metadata-weight);
    letter-spacing: var(--tl-type-metadata-track);
    text-transform: uppercase;
  }

  .tl-graph-fallback ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tl-graph-fallback li + li {
    margin-top: var(--tl-space-2);
  }

  .tl-graph-fallback a {
    color: var(--tl-ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

</style>
