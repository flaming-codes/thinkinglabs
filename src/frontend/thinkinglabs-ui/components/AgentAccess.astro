---
export interface AgentAccessConfig {
  markdownHref: string;
  tokenEstimate?: number | undefined;
}

interface Props {
  access: AgentAccessConfig;
}

const { access } = Astro.props;
---

<dl class="tl-agent-access" data-tl-agent-access>
  <div class="tl-agent-access-row">
    <dt>Agent context</dt>
    <dd>
      <a href={access.markdownHref}>Markdown</a>
      <button type="button" data-copy-for-ai={access.markdownHref} aria-live="polite">
        Copy for AI
      </button>
      {
        access.tokenEstimate !== undefined && (
          <span class="tl-agent-access-meta">~{access.tokenEstimate.toLocaleString()} tokens</span>
        )
      }
    </dd>
  </div>
</dl>

<script>
  import { onPageReady } from "../lib/page-lifecycle";

  let controller: AbortController | null = null;

  const init = () => {
    controller?.abort();
    controller = new AbortController();
    const { signal } = controller;

    for (const button of document.querySelectorAll<HTMLButtonElement>("[data-copy-for-ai]")) {
      button.addEventListener(
        "click",
        async () => {
          const href = button.dataset.copyForAi;
          if (!href) return;
          const original = button.textContent ?? "Copy for AI";
          try {
            const response = await fetch(href);
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            await navigator.clipboard.writeText(await response.text());
            button.textContent = "Copied";
          } catch {
            button.textContent = "Failed";
          } finally {
            window.setTimeout(() => {
              button.textContent = original;
            }, 1800);
          }
        },
        { signal },
      );
    }
  };

  onPageReady(init);
</script>

<style>
  .tl-agent-access {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin: 0;
    padding-top: 0.05rem;
    color: var(--tl-muted);
    font-size: var(--tl-type-caption);
    line-height: 1.35;
  }

  .tl-agent-access-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.45rem;
    align-items: baseline;
  }

  .tl-agent-access dt {
    color: color-mix(in srgb, var(--tl-muted) 78%, transparent);
  }

  .tl-agent-access dd {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.45rem;
    margin: 0;
    color: color-mix(in srgb, var(--tl-ink) 68%, transparent);
  }

  .tl-agent-access-meta {
    color: color-mix(in srgb, var(--tl-muted) 65%, transparent);
  }

  .tl-agent-access a,
  .tl-agent-access button {
    color: inherit;
    font: inherit;
    text-decoration: none;
  }

  .tl-agent-access button {
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .tl-agent-access a:hover,
  .tl-agent-access button:hover {
    color: color-mix(in srgb, var(--tl-ink) 90%, transparent);
  }
</style>
