---
import SiteFooter from "./SiteFooter.astro";
import SiteHeader from "./SiteHeader.astro";

interface Props {
  activeNav?: "Index" | "Now" | "Calibration" | "Brain-diff" | "Agents" | "About";
  hideSelectedHud?: boolean;
  mode?: "document" | "gallery";
}

const { activeNav = "Index", hideSelectedHud = false, mode = "document" } = Astro.props;
const showSelectedHud = activeNav !== "Index" && !hideSelectedHud;
---

<article class="tl-shell" id="top" data-active-nav={activeNav} data-layout={mode}>
  <SiteHeader activeNav={activeNav} />
  <main id="main-content" tabindex="-1" class="tl-scroll" data-tl-scroll>
    <div class="tl-scroll-content">
      <slot />
    </div>
  </main>
  {
    showSelectedHud && (
      <aside class="tl-selected-hud" aria-live="polite" aria-atomic="true">
        <p class="tl-selected-kicker">Selected</p>
        <p class="tl-selected-value" data-selected-text>{activeNav}</p>
      </aside>
    )
  }
</article>
<SiteFooter />

<script>
  import { onPageReady } from "../lib/page-lifecycle";

  let controller: AbortController | null = null;

  const init = () => {
    controller?.abort();
    controller = new AbortController();
    const { signal } = controller;

    const shell = document.querySelector<HTMLElement>(".tl-shell");
    const scroller = document.querySelector<HTMLElement>("[data-tl-scroll]");
    const selectedText = document.querySelector<HTMLElement>("[data-selected-text]");
    const brandContext = document.querySelector<HTMLElement>("[data-brand-context]");
    const candidates = Array.from(document.querySelectorAll<HTMLElement>("[data-selected-label]"));
    const fallback = shell?.dataset.activeNav ?? "Index";

    const setSelected = (label: string, meta?: string) => {
      if (selectedText) selectedText.textContent = label;
      if (brandContext) brandContext.textContent = meta ?? label;
    };

    const updateSelected = () => {
      if (!scroller || candidates.length === 0) {
        setSelected(fallback);
        return;
      }

      const viewportMiddle = scroller.getBoundingClientRect().top + scroller.clientHeight * 0.52;
      let active = candidates[0];
      let activeDistance = Number.POSITIVE_INFINITY;

      candidates.forEach((candidate) => {
        const rect = candidate.getBoundingClientRect();
        const middle = rect.top + rect.height * 0.5;
        const distance = Math.abs(middle - viewportMiddle);
        if (distance < activeDistance) {
          active = candidate;
          activeDistance = distance;
        }
      });

      setSelected(active?.dataset.selectedLabel ?? fallback, active?.dataset.brandContext);
    };

    scroller?.addEventListener("scroll", updateSelected, { passive: true, signal });
    window.addEventListener("resize", updateSelected, { signal });
    updateSelected();
  };

  onPageReady(init);
</script>

<style>
  .tl-shell {
    isolation: isolate;
    width: 100%;
    height: var(--tl-viewport-height);
    background: var(--tl-bg);
    color: var(--tl-ink);
    overflow: hidden;
  }

  .tl-shell,
  .tl-shell :global(*) {
    box-sizing: border-box;
  }

  .tl-shell :global(h1),
  .tl-shell :global(h2),
  .tl-shell :global(h3),
  .tl-shell :global(p),
  .tl-shell :global(figure),
  .tl-shell :global(blockquote),
  .tl-shell :global(ol) {
    margin: 0;
  }

  .tl-shell :global(a:hover),
  .tl-shell :global(button:hover) {
    opacity: 0.68;
  }

  .tl-scroll {
    height: var(--tl-viewport-height);
    overflow: hidden auto;
    overscroll-behavior: none;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }

  /* The main landmark is a skip-link target (tabindex="-1"); suppress the
     programmatic-focus outline so jumping to it does not paint a ring around
     the whole scroll region. */
  .tl-scroll:focus,
  .tl-scroll:focus-visible {
    outline: none;
  }

  .tl-scroll::-webkit-scrollbar {
    width: 0;
    height: 0;
  }

  .tl-scroll-content {
    min-height: var(--tl-viewport-height);
  }

  .tl-selected-hud {
    position: fixed;
    z-index: var(--tl-layer-hud);
    top: 50%;
    left: var(--tl-ui-left);
    display: grid;
    gap: var(--tl-space-3);
    width: min(35rem, calc(100vw - var(--tl-ui-left) - var(--tl-ui-right)));
    color: var(--tl-difference-ink);
    mix-blend-mode: difference;
    pointer-events: none;
  }

  .tl-selected-kicker {
    color: inherit;
    font-size: var(--tl-type-metadata-size);
    font-weight: var(--tl-type-metadata-weight);
    line-height: var(--tl-type-metadata-line);
    letter-spacing: var(--tl-type-metadata-track);
    text-transform: uppercase;
  }

  .tl-selected-value {
    max-width: 30ch;
    font-size: clamp(22px, 2vw, 34px);
    font-weight: 550;
    line-height: var(--tl-type-line-tight);
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .tl-shell :global(.tl-eyebrow),
  .tl-shell :global(.tl-mono),
  .tl-shell :global(.tl-index-eyebrow),
  .tl-shell :global(.tl-index-crumb),
  .tl-shell :global(.tl-index-section-label),
  .tl-shell :global(.tl-stat-label),
  .tl-shell :global(.tl-stat-sub),
  .tl-shell :global(.tl-metric-label),
  .tl-shell :global(.tl-metric-hint) {
    color: inherit;
    font-size: var(--tl-type-metadata-size);
    font-weight: var(--tl-type-metadata-weight);
    line-height: var(--tl-type-metadata-line);
    letter-spacing: var(--tl-type-metadata-track);
    text-transform: uppercase;
  }

  .tl-shell :global(.tl-mono),
  .tl-shell :global(.tl-index-crumb),
  .tl-shell :global(.tl-stat-sub),
  .tl-shell :global(.tl-metric-hint) {
    color: var(--tl-muted);
    font-size: var(--tl-type-mono-xs);
    letter-spacing: 0.08em;
  }

  .tl-shell :global(.tl-mono.is-right) {
    text-align: right;
  }

  .tl-shell :global(.tl-ink) {
    color: var(--tl-ink);
  }

  .tl-shell :global(.tl-muted),
  .tl-shell :global(.is-muted) {
    color: var(--tl-muted);
  }

  .tl-shell :global(.tl-line) {
    border-color: var(--tl-line);
  }

  .tl-shell :global(.is-strike) {
    color: var(--tl-muted);
    text-decoration: line-through;
  }

  .tl-shell :global(code) {
    font-family: var(--tl-font);
    font-size: 0.88em;
  }

  .tl-shell :global(.tl-gradient-block) {
    display: none;
  }

  .tl-shell :global(.tl-page-head),
  .tl-shell :global(.tl-home-index),
  .tl-shell :global(.tl-home-thesis-row),
  .tl-shell :global(.tl-home-agents),
  .tl-shell :global(.tl-index-list),
  .tl-shell :global(.tl-filter-row),
  .tl-shell :global(.tl-index-bottom) {
    width: var(--tl-center);
    margin-inline: auto;
  }

  .tl-shell :global(.tl-page-head) {
    display: grid;
    min-height: 72vh;
    align-content: end;
    padding: 18vh 0 10vh;
  }

  .tl-shell :global(.tl-page-head.is-spacious),
  .tl-shell :global(.tl-page-head.is-detail) {
    min-height: 78vh;
  }

  .tl-shell :global(.tl-page-head-grid) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(10rem, 16rem);
    gap: var(--tl-space-16);
    align-items: end;
  }

  .tl-shell :global(.tl-page-head h1) {
    margin-top: 14px;
    font-size: var(--tl-type-display-xl);
    font-weight: var(--tl-type-heading-weight-strong);
    line-height: var(--tl-type-line-display);
    letter-spacing: var(--tl-type-track-tight);
    text-transform: uppercase;
  }

  .tl-shell :global(.tl-page-sub),
  .tl-shell :global(.tl-page-head-grid p),
  .tl-shell :global(.tl-projects-row p),
  .tl-shell :global(.tl-thought-excerpt),
  .tl-shell :global(.tl-inputs-note),
  .tl-shell :global(.tl-questions-deck),
  .tl-shell :global(.tl-decisions-summary),
  .tl-shell :global(.tl-pred-topic),
  .tl-shell :global(.tl-kind-row p),
  .tl-shell :global(.tl-home-thesis-row p) {
    color: var(--tl-muted);
    font-size: 15px;
    line-height: var(--tl-type-line-body);
  }

  .tl-shell :global(.tl-split-header),
  .tl-shell :global(.tl-filter-row) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--tl-space-11);
    padding: 0 0 var(--tl-space-8);
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-shell :global(.tl-split-header.is-tight) {
    padding-top: 64px;
  }

  .tl-shell :global(.tl-kind-list),
  .tl-shell :global(.tl-index-list) {
    display: grid;
  }

  .tl-shell :global(.tl-kind-row),
  .tl-shell :global(.tl-claims-row),
  .tl-shell :global(.tl-thought-row),
  .tl-shell :global(.tl-projects-row),
  .tl-shell :global(.tl-post-row),
  .tl-shell :global(.tl-pred-row),
  .tl-shell :global(.tl-inputs-row),
  .tl-shell :global(.tl-questions-row),
  .tl-shell :global(.tl-decisions-row),
  .tl-shell :global(.tl-flip-row),
  .tl-shell :global(.tl-home-entity-link) {
    position: relative;
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto;
    gap: var(--tl-space-10);
    align-items: baseline;
    padding: var(--tl-space-13) 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-shell :global(.tl-kind-row h3),
  .tl-shell :global(.tl-claims-row h3),
  .tl-shell :global(.tl-thought-row h3),
  .tl-shell :global(.tl-projects-row h3),
  .tl-shell :global(.tl-post-row h3),
  .tl-shell :global(.tl-pred-title),
  .tl-shell :global(.tl-questions-row h3),
  .tl-shell :global(.tl-decisions-row h3),
  .tl-shell :global(.tl-flip-title),
  .tl-shell :global(.tl-home-entity-link h3),
  .tl-shell :global(.tl-home-agents-body h2) {
    font-size: var(--tl-type-display-sm);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: var(--tl-type-track-heading);
  }

  .tl-shell :global(.tl-home-hero),
  .tl-shell :global(.tl-home-thesis-row),
  .tl-shell :global(.tl-home-index),
  .tl-shell :global(.tl-home-agents),
  .tl-shell :global(.tl-home-modal),
  .tl-shell :global(.tl-home-entity-more) {
    display: none;
  }

  .tl-shell :global(.tl-pred-conf),
  .tl-shell :global(.tl-flip-date-big),
  .tl-shell :global(.tl-inputs-year),
  .tl-shell :global(.tl-kind-count),
  .tl-shell :global(.tl-thought-words) {
    font-size: clamp(32px, 5vw, 70px);
    font-weight: var(--tl-type-heading-weight-strong);
    line-height: var(--tl-type-line-display);
    letter-spacing: var(--tl-type-track-tight);
  }

  .tl-shell :global(.tl-heat-label) {
    display: inline-flex;
    align-items: center;
    width: max-content;
    padding: 0.35rem 0.55rem;
    border: 1px solid var(--tl-line);
    color: var(--tl-muted);
  }

  .tl-shell :global(.tl-prose-body) {
    color: var(--tl-detail-body-ink);
    font-size: clamp(18px, 1.12vw, 20px);
    font-weight: var(--tl-detail-body-weight);
    line-height: 1.82;
    text-wrap: pretty;
  }

  .tl-shell :global(.tl-prose-body p + p) {
    margin-top: 1.35rem;
  }

  .tl-shell :global(.tl-pred-foot),
  .tl-shell :global(.tl-index-bottom) {
    padding-bottom: 18vh;
  }

  @media (max-width: 767px) {
    .tl-selected-hud {
      top: 50%;
      gap: var(--tl-space-2);
    }

    .tl-selected-value {
      font-size: clamp(18px, 5vw, 24px);
    }

    .tl-shell :global(.tl-page-head),
    .tl-shell :global(.tl-home-index),
    .tl-shell :global(.tl-home-thesis-row),
    .tl-shell :global(.tl-home-agents),
    .tl-shell :global(.tl-index-list),
    .tl-shell :global(.tl-filter-row),
    .tl-shell :global(.tl-index-bottom) {
      width: var(--tl-center);
    }

    .tl-shell :global(.tl-page-head-grid),
    .tl-shell :global(.tl-kind-row),
    .tl-shell :global(.tl-claims-row),
    .tl-shell :global(.tl-thought-row),
    .tl-shell :global(.tl-projects-row),
    .tl-shell :global(.tl-post-row),
    .tl-shell :global(.tl-pred-row),
    .tl-shell :global(.tl-inputs-row),
    .tl-shell :global(.tl-questions-row),
    .tl-shell :global(.tl-decisions-row),
    .tl-shell :global(.tl-flip-row),
    .tl-shell :global(.tl-home-entity-link) {
      grid-template-columns: 1fr;
      gap: var(--tl-space-5);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-scroll {
      scroll-behavior: auto;
    }
  }
</style>
