---
/** One entry in the dateline; kinds map their own date fields (reviewed, made, asked, ...) to this. */
export interface EntityDate {
  label: string;
  /** ISO value for the `<time datetime>` attribute; omit when only a formatted label is available. */
  iso?: string;
}

interface Props {
  /** Dateline entries, joined with "·". Empty/omitted hides the dateline. */
  dates?: EntityDate[] | undefined;
  /** Optional tag list rendered under the dateline. */
  tags?: string[] | undefined;
}

const { dates = [], tags = [] } = Astro.props;

const hasMeta = Astro.slots.has("meta");
const hasDates = dates.length > 0;
---

{/*
  Two-column reading row: a left meta column (dateline, tags, `meta` slot) and
  the prose `article`. On narrow screens the columns stack; on lg+ they sit in a
  right-aligned 3/4 measure shared with EntityFooter.
*/}
<section
  class="px-2 flex flex-col gap-4 md:pr-8 lg:max-w-3/4 lg:flex-row lg:justify-end lg:pr-2 lg:gap-16"
>
  <header class="flex flex-col gap-3">
    {
      hasDates && (
        <p class="flex flex-wrap gap-x-1 text-sm opacity-70">
          {dates.map((date, index) => (
            <>
              {index > 0 && <span aria-hidden="true">·</span>}
              {date.iso ? <time datetime={date.iso}>{date.label}</time> : <span>{date.label}</span>}
            </>
          ))}
        </p>
      )
    }
    {
      tags.length > 0 && (
        <ul class="flex flex-wrap gap-x-1 list-none p-0">
          {tags.map((tag) => (
            <li class="text-sm opacity-50">#{tag}</li>
          ))}
        </ul>
      )
    }
    {hasMeta && <slot name="meta" />}
  </header>
  <article class="entity-prose md:pl-16 lg:pl-0">
    <slot />
  </article>
</section>

<style>
  .entity-prose {
    max-width: 65ch;
  }

  /* <Content /> markup is not Tailwind-aware during migration, so space
     paragraphs with plain scoped CSS reaching into the rendered markdown. */
  .entity-prose :global(p) {
    margin-block: 1.5em;
  }
</style>
