---
import DetailFooter from "./DetailFooter.astro";
import type { DetailLink, DetailLinkGroup } from "./DetailFooter.astro";

export type EntityRelationLink = DetailLink;
export type EntityRelationGroup = DetailLinkGroup;

interface Props {
  /** Resolved relation groups; the footer is omitted when empty and no `aside` slot is present. */
  relations?: EntityRelationGroup[] | undefined;
}

const { relations = [] } = Astro.props;

const hasAside = Astro.slots.has("aside");
---

<DetailFooter linkGroups={relations}>
  {hasAside && <slot name="aside" slot="aside" />}
</DetailFooter>
