---
interface Props {
  label: string;
  tone?: "default" | "active" | "deprecated" | "superseded" | "positive" | "negative";
}

const { label, tone = "default" } = Astro.props;
---

<span class:list={["tl-status-tag", `is-${tone}`]}>{label}</span>

<style>
  .tl-status-tag {
    display: inline;
    width: max-content;
    padding: 0;
    border: 0;
    color: inherit;
    background: transparent;
    font-size: 11px;
    font-weight: 650;
    line-height: 1.2;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }
</style>
