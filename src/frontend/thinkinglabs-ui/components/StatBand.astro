---
import type { IndexStat } from "../types";

interface Props {
  stats: IndexStat[];
}

const { stats } = Astro.props;
---

<section class="tl-stat-band">
  {stats.map((stat) => (
    <div class="tl-stat-cell">
      <div class="tl-stat-label">{stat.label}</div>
      <div class="tl-stat-num">{stat.value}</div>
      <div class="tl-stat-sub">{stat.sub}</div>
    </div>
  ))}
</section>

<style>
  .tl-stat-band {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    width: var(--tl-center);
    margin-inline: auto;
    padding: 8vh 0;
  }

  .tl-stat-label,
  .tl-stat-sub {
    color: inherit;
    font-size: 11px;
    font-weight: 650;
    line-height: 1;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .tl-stat-sub {
    color: var(--tl-muted);
    font-size: 12px;
    letter-spacing: 0.08em;
  }

  @media (max-width: 767px) {
    .tl-stat-band {
      grid-template-columns: 1fr;
      gap: 12px;
      width: min(100% - 40px, 43.75rem);
    }
  }
</style>
