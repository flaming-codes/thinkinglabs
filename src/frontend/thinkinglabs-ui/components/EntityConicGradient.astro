---
interface Props {
  entity: string;
  class?: string;
}

const { entity, class: className } = Astro.props;
---

<span class:list={["tl-conic-gradient", className]} data-entity={entity} aria-hidden="true">
  <span class="tl-conic-content"><slot /></span>
</span>

<style is:global>
  .tl-conic-gradient {
    position: relative;
    display: block;
    overflow: hidden;
    background: var(--tl-entity-gradient-luster), var(--tl-entity-gradient, var(--tl-soft));
    background-blend-mode: var(--tl-entity-gradient-blend);
  }

  .tl-conic-gradient::before {
    position: absolute;
    inset: -18%;
    background: var(--tl-entity-gradient-luster), var(--tl-entity-gradient, var(--tl-soft));
    background-blend-mode: var(--tl-entity-gradient-blend);
    content: "";
    transform: rotate(-4deg) scale(1.08);
    transform-origin: var(--tl-gradient-origin, 50% 50%);
    animation: tl-entity-gradient-drift var(--tl-gradient-duration, 28s) ease-in-out infinite
      alternate;
  }

  .tl-conic-content {
    position: relative;
    z-index: 1;
    display: contents;
  }

  @keyframes tl-entity-gradient-drift {
    0% {
      transform: rotate(-4deg) scale(1.08) translate3d(-0.25%, -0.2%, 0);
    }

    50% {
      transform: rotate(-1.6deg) scale(1.095) translate3d(0.25%, 0.35%, 0);
    }

    100% {
      transform: rotate(-6deg) scale(1.09) translate3d(0.35%, -0.15%, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-conic-gradient::before {
      animation: none;
    }
  }
</style>
