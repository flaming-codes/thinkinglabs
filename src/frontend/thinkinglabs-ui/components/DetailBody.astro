---
import AgentAccess from "./AgentAccess.astro";
import type { AgentAccessConfig } from "./AgentAccess.astro";

/** One small metadata item shown above the detail body. */
export interface DetailMetadataItem {
  label: string;
  /** ISO value for the `<time datetime>` attribute; omit when only a formatted label is available. */
  iso?: string;
}

interface Props {
  /** Header metadata entries, joined with "·". Empty/omitted hides the line. */
  metadata?: DetailMetadataItem[] | undefined;
  /** Optional tag list rendered under the metadata line. */
  tags?: string[] | undefined;
  /** Optional clean Markdown/copy affordance for agent-readable context. */
  agentAccess?: AgentAccessConfig | undefined;
}

const { metadata = [], tags = [], agentAccess } = Astro.props;

const hasMeta = Astro.slots.has("meta");
const hasMetadata = metadata.length > 0;

function metadataTuple(item: DetailMetadataItem, index: number): DetailMetadataItem & {
  readonly heading: string;
  readonly value: string;
} {
  const formatDate = (value: string): string => {
    const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(value);
    if (!match) return value;
    const year = Number(match[1]);
    const month = Number(match[2]);
    const day = Number(match[3]);
    return new Intl.DateTimeFormat("en", {
      dateStyle: "long",
      timeZone: "UTC",
    }).format(new Date(Date.UTC(year, month - 1, day)));
  };

  const match = /^(updated|asked|observed|read|made|resolves|started)\s+(.+)$/i.exec(item.label);
  if (match) {
    return {
      ...item,
      heading: `${match[1]?.slice(0, 1).toUpperCase()}${match[1]?.slice(1).toLowerCase()}`,
      value: formatDate(match[2] ?? item.label),
    };
  }
  return {
    ...item,
    heading: index === 0 ? "" : "Updated",
    value: formatDate(item.label),
  };
}

const metadataRows = metadata.map(metadataTuple);
---

{/*
  Two-column reading row: a left meta column (metadata, tags, `meta` slot) and
  the prose `article`. On narrow screens the columns stack; on lg+ they sit in a
  right-aligned 3/4 measure shared with DetailFooter.
*/}
<section
  class="px-2 flex flex-col gap-4 pt-10 md:pr-8 md:pt-14 lg:max-w-3/4 lg:flex-row lg:justify-end lg:gap-28 lg:pr-2 lg:pt-20"
>
  <header class="tl-detail-meta">
    {
      hasMetadata && (
        <dl class="tl-detail-metadata-list">
          {metadataRows.map((item) => (
            <div class="tl-detail-metadata-row">
              {item.heading && <dt>{item.heading}</dt>}
              <dd>
                {item.iso ? <time datetime={item.iso}>{item.value}</time> : <span>{item.value}</span>}
              </dd>
            </div>
          ))}
        </dl>
      )
    }
    {
      tags.length > 0 && (
        <ul class="tl-detail-tags">
          {tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )
    }
    {hasMeta && <slot name="meta" />}
    {agentAccess && <AgentAccess access={agentAccess} />}
  </header>
  <article class="detail-prose md:pl-16 lg:pl-0">
    <slot />
  </article>
</section>

<style>
  .detail-prose {
    max-width: 65ch;
  }

  .tl-detail-meta {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    color: var(--tl-muted);
    font-size: var(--tl-type-caption);
    line-height: 1.35;
  }

  .tl-detail-metadata-list,
  .tl-detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.45rem;
    margin: 0;
    padding: 0;
  }

  .tl-detail-metadata-list {
    flex-direction: column;
  }

  .tl-detail-metadata-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.45rem;
    align-items: baseline;
  }

  .tl-detail-metadata-row dt {
    color: color-mix(in srgb, var(--tl-muted) 78%, transparent);
  }

  .tl-detail-metadata-row dd {
    margin: 0;
    color: color-mix(in srgb, var(--tl-ink) 68%, transparent);
  }

  .tl-detail-tags {
    list-style: none;
  }

  .tl-detail-tags li {
    color: color-mix(in srgb, var(--tl-muted) 80%, transparent);
  }

  /* <Content /> markup is not Tailwind-aware during migration, so space
     paragraphs with plain scoped CSS reaching into the rendered markdown. */
  .detail-prose :global(p) {
    margin-block: 1.5em;
  }
</style>
