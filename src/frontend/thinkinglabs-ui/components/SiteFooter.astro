---
import BrandLogo from "./BrandLogo.astro";

const year = new Date().getFullYear();
---

<footer class="tl-site-footer">
  <div class="tl-site-footer-inner">
    <div class="tl-site-footer-top">
      <div class="tl-site-footer-brand">
        <BrandLogo class="tl-site-footer-logo" ariaLabel="thinkinglabs" />
        <p class="tl-site-footer-lede">
          A project in mind?
          <span class="is-muted">I keep score in public — feel free to send something I should read.</span>
        </p>
      </div>
      <div class="tl-site-footer-cols">
        <div class="tl-site-footer-col">
          <h3>Surfaces</h3>
          <a href="/llms.txt">llms.txt</a>
          <a href="/feed/brain-diff.xml">JSON feeds</a>
          <a href="mcp://stdio/pnpm%20mcp:thinkinglabs">MCP server</a>
        </div>
        <div class="tl-site-footer-col">
          <h3>Discover</h3>
          <a href="/now">Now</a>
          <a href="/predictions/calibration">Calibration</a>
          <a href="/feed/brain-diff.xml">Brain-diff</a>
        </div>
        <div class="tl-site-footer-col">
          <h3>Contact</h3>
          <a href="mailto:tom@wild.as">tom@wild.as</a>
          <a href="https://github.com/flaming-codes/thinkinglabs">github</a>
        </div>
      </div>
    </div>
    <div class="tl-site-footer-bottom">
      <span class="tl-site-footer-copy">© {year} thinkinglabs · built in public</span>
      <a href="#top" class="tl-site-footer-top-link" aria-label="Back to top">Back to top ↑</a>
    </div>
  </div>
</footer>
