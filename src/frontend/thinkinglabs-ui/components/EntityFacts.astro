---
/** Compact label/value facts for the EntityDetail `meta` slot (status, confidence, horizon, ...). */
export interface EntityFact {
  label: string;
  value: string;
  /** Optional muted suffix shown after the value (e.g. "120d ago"). */
  sub?: string;
}

interface Props {
  facts: EntityFact[];
}

const { facts } = Astro.props;
const visible = facts.filter((fact) => fact.value.trim().length > 0);
---

{
  visible.length > 0 && (
    <dl class="tl-entity-facts">
      {visible.map((fact) => (
        <div class="tl-entity-fact">
          <dt>{fact.label}</dt>
          <dd>
            <span>{fact.value}</span>
            {fact.sub && <span class="tl-entity-fact-sub"> {fact.sub}</span>}
          </dd>
        </div>
      ))}
    </dl>
  )
}

<style>
  .tl-entity-facts {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin: 0;
    color: var(--tl-muted);
    font-size: var(--tl-type-caption);
    line-height: 1.35;
  }

  .tl-entity-fact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.45rem;
    align-items: baseline;
  }

  .tl-entity-fact dt {
    color: color-mix(in srgb, var(--tl-muted) 78%, transparent);
  }

  .tl-entity-fact dd {
    margin: 0;
    color: color-mix(in srgb, var(--tl-ink) 68%, transparent);
  }

  .tl-entity-fact-sub {
    color: color-mix(in srgb, var(--tl-muted) 65%, transparent);
  }
</style>
