---
/** Compact label/value facts for the EntityDetail `meta` slot (status, confidence, horizon, ...). */
export interface EntityFact {
  label: string;
  value: string;
  /** Optional muted suffix shown after the value (e.g. "120d ago"). */
  sub?: string;
}

interface Props {
  facts: EntityFact[];
}

const { facts } = Astro.props;
const visible = facts.filter((fact) => fact.value.trim().length > 0);
---

{
  visible.length > 0 && (
    <dl class="flex flex-col gap-3">
      {visible.map((fact) => (
        <div class="flex flex-col gap-0.5">
          <dt class="text-xs uppercase tracking-wider opacity-50">{fact.label}</dt>
          <dd class="m-0 text-sm opacity-80">
            {fact.value}
            {fact.sub && <span class="opacity-50"> {fact.sub}</span>}
          </dd>
        </div>
      ))}
    </dl>
  )
}
