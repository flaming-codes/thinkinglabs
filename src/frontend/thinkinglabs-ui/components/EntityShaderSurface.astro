---
import { hasEntityShaderGradient } from "../entity-shader-presets";

interface Props {
  entity: string;
  region?: "landing" | "detail" | "header";
  class?: string;
}

const { entity, region = "landing", class: className } = Astro.props;
const shaderEntity = hasEntityShaderGradient(entity) ? entity : undefined;
---

<span
  class:list={["tl-shader-surface", className]}
  data-entity={entity}
  data-tl-shader-surface
  data-tl-shader-enabled={shaderEntity ? "true" : undefined}
  data-tl-shader-entity={shaderEntity}
  data-tl-shader-region={region}
  aria-hidden="true"
>
  <span class="tl-shader-fallback"></span>
  <span class="tl-shader-content"><slot /></span>
</span>

<script>
  import "./EntityShaderSurface.client.ts";
</script>

<style is:global>
  .tl-shader-surface {
    position: relative;
    display: block;
    overflow: hidden;
    background: var(--tl-entity-gradient-luster), var(--tl-entity-gradient, #000);
    background-blend-mode: var(--tl-entity-gradient-blend);
  }

  .tl-shader-surface[data-tl-shader-enabled="true"] {
    background: #000;
  }

  .tl-shader-fallback,
  .tl-shader-mount,
  .tl-shader-canvas,
  .tl-shader-surface canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .tl-shader-fallback {
    background: var(--tl-entity-gradient-luster), var(--tl-entity-gradient, #000);
    background-blend-mode: var(--tl-entity-gradient-blend);
  }

  .tl-shader-surface[data-tl-shader-enabled="true"] .tl-shader-fallback {
    background: #000;
  }

  .tl-shader-mount {
    z-index: 1;
    opacity: 0;
    transition: opacity 700ms ease;
  }

  .tl-shader-content {
    position: relative;
    z-index: 2;
    display: contents;
  }

  .tl-shader-surface[data-tl-shader-ready="true"] .tl-shader-mount {
    opacity: 1;
  }

  .tl-shader-surface[data-tl-shader-ready="true"] .tl-shader-fallback {
    opacity: 0;
    transition: opacity 900ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-shader-fallback {
      animation: none;
    }
  }
</style>
