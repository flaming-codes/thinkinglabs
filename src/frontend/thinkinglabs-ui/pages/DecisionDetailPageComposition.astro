---
import AppShell from "../components/AppShell.astro";
import EntityConicGradient from "../components/EntityConicGradient.astro";
import StatusTag from "../components/StatusTag.astro";
import type { DecisionDetail } from "../types";

interface Props {
  decision: DecisionDetail;
}

const { decision } = Astro.props;
const hasReverseLinks = decision.reverses.length > 0 || decision.reversedBy.length > 0;
const related = [...decision.relatedClaims, ...decision.relatedProjects];
---

<AppShell activeNav="Index">
  <article class="tl-decision-detail" data-selected-label={decision.title} data-entity="decisions">
    <header class="tl-decision-head">
      <EntityConicGradient class="tl-decision-rule" entity="decisions" />
      <div class="tl-decision-title">
        <p class="tl-mono">Decision detail</p>
        <h1>{decision.title}</h1>
      </div>
      <aside class="tl-decision-verdict">
        <span class="tl-eyebrow">Chosen</span>
        <p>{decision.chosen}</p>
        <StatusTag label={decision.status} tone={decision.status === "standing" ? "active" : "default"} />
      </aside>
    </header>

    <section class="tl-decision-ledger">
      <div>
        <span class="tl-eyebrow">Date</span>
        <p>{decision.date}</p>
      </div>
      <div>
        <span class="tl-eyebrow">Follow-up</span>
        <p>{decision.followUp ?? "Not scheduled"}</p>
      </div>
      <div>
        <span class="tl-eyebrow">Tags</span>
        <p>{decision.tags.length > 0 ? decision.tags.join(", ") : "No tags"}</p>
      </div>
    </section>

    {hasReverseLinks ? (
      <section class="tl-decision-reversals">
        {decision.reverses.length > 0 ? (
          <div>
            <span class="tl-eyebrow">Reverses</span>
            {decision.reverses.map((rel) => (
              <p>{rel.href ? <a href={rel.href}>{rel.title}</a> : rel.title}</p>
            ))}
          </div>
        ) : null}
        {decision.reversedBy.length > 0 ? (
          <div>
            <span class="tl-eyebrow">Reversed by</span>
            {decision.reversedBy.map((rel) => (
              <p>{rel.href ? <a href={rel.href}>{rel.title}</a> : rel.title}</p>
            ))}
          </div>
        ) : null}
      </section>
    ) : null}

    <section class="tl-decision-brief">
      <article>
        <span class="tl-eyebrow">Context</span>
        <p>{decision.context}</p>
      </article>
      <article>
        <span class="tl-eyebrow">Why</span>
        <p>{decision.why}</p>
      </article>
      <article class="tl-decision-change">
        <span class="tl-eyebrow">What would change my mind</span>
        <p>{decision.changeTrigger}</p>
      </article>
    </section>

    {decision.options.length > 0 ? (
      <section class="tl-decision-options">
        <header class="tl-split-header is-tight">
          <div class="tl-eyebrow">Options considered</div>
          <div class="tl-mono">{decision.options.length} alternatives</div>
        </header>
        <ol>
          {decision.options.map((option, index) => (
            <li>
              <span class="tl-mono">{String(index + 1).padStart(2, "0")}</span>
              <p>{option}</p>
            </li>
          ))}
        </ol>
      </section>
    ) : null}

    <section class="tl-decision-body">
      <slot />
    </section>

    {related.length > 0 ? (
      <section class="tl-decision-related">
        <header class="tl-split-header is-tight">
          <div class="tl-eyebrow">Related</div>
          <div class="tl-mono">{related.length} linked entries</div>
        </header>
        <div>
          {related.map((rel) => (
            <article class="tl-decision-relation">
              <span class="tl-mono">{rel.kind}</span>
              <h3>{rel.href ? <a href={rel.href}>{rel.title}</a> : rel.title}</h3>
              <span class="tl-mono is-right">{rel.value ?? ""}</span>
            </article>
          ))}
        </div>
      </section>
    ) : null}
  </article>
</AppShell>

<style>
  .tl-decision-detail {
    padding: clamp(7rem, 13vh, 10rem) 20px clamp(7rem, 16vh, 12rem);
    background: var(--tl-bg);
    color: var(--tl-ink);
  }

  .tl-decision-head,
  .tl-decision-ledger,
  .tl-decision-reversals,
  .tl-decision-brief,
  .tl-decision-options,
  .tl-decision-body,
  .tl-decision-related {
    width: min(100%, 980px);
    margin-inline: auto;
  }

  .tl-decision-head {
    display: grid;
    grid-template-columns: 88px minmax(0, 1fr) minmax(14rem, 18rem);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: end;
    min-height: clamp(23rem, 58vh, 38rem);
  }

  :global(.tl-decision-rule) {
    align-self: stretch;
    background: var(--tl-media-bg);
  }

  .tl-decision-title {
    display: grid;
    gap: 18px;
    padding-bottom: clamp(1rem, 4vh, 2rem);
  }

  .tl-decision-title h1 {
    max-width: 15ch;
    font-size: clamp(40px, 6vw, 78px);
    font-weight: 640;
    line-height: 0.94;
    letter-spacing: -0.045em;
    text-transform: uppercase;
  }

  .tl-decision-verdict {
    display: grid;
    gap: 14px;
    padding: 22px 0;
    border-top: 1px solid var(--tl-line);
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-decision-verdict p {
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 590;
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .tl-decision-ledger {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    margin-top: clamp(3rem, 7vh, 5rem);
    background: var(--tl-line);
  }

  .tl-decision-ledger div {
    display: grid;
    gap: 10px;
    min-height: 9rem;
    padding: 20px;
    background: var(--tl-bg);
  }

  .tl-decision-ledger p {
    align-self: end;
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.08;
  }

  .tl-decision-reversals {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    margin-top: 1px;
    background: var(--tl-line);
  }

  .tl-decision-reversals div {
    display: grid;
    gap: 12px;
    padding: 22px;
    background: var(--tl-code-bg);
  }

  .tl-decision-reversals p {
    font-size: 18px;
    line-height: 1.3;
  }

  .tl-decision-brief {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    padding: clamp(3rem, 9vh, 6rem) 0;
  }

  .tl-decision-brief article {
    display: grid;
    gap: 14px;
  }

  .tl-decision-change {
    grid-column: 1 / -1;
  }

  .tl-decision-brief p {
    color: var(--tl-prose-ink);
    font-size: 17px;
    line-height: 1.7;
  }

  .tl-decision-options ol {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tl-decision-options li {
    display: grid;
    grid-template-columns: 60px minmax(0, 1fr);
    gap: 22px;
    padding: 22px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-decision-options p,
  .tl-decision-body {
    color: var(--tl-prose-ink);
    font-size: 16px;
    line-height: 1.75;
  }

  .tl-decision-body {
    padding: clamp(2.5rem, 8vh, 5rem) 0;
  }

  .tl-decision-body :global(p) {
    max-width: 43rem;
    margin: 0 0 1.1rem;
  }

  .tl-decision-relation {
    display: grid;
    grid-template-columns: 66px minmax(0, 1fr) auto;
    gap: 22px;
    align-items: baseline;
    padding: 26px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-decision-relation h3 {
    font-size: clamp(22px, 2.8vw, 35px);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  @media (max-width: 860px) {
    .tl-decision-head,
    .tl-decision-ledger,
    .tl-decision-reversals,
    .tl-decision-brief {
      grid-template-columns: 1fr;
    }

    :global(.tl-decision-rule) {
      min-height: 11rem;
    }
  }

  @media (max-width: 767px) {
    .tl-decision-detail {
      padding: 5rem 16px 3rem;
    }

    .tl-decision-relation,
    .tl-decision-options li {
      grid-template-columns: 1fr;
      gap: 10px;
    }
  }

</style>
