---
import heroImage from "@/assets/hero.png";
import EntityDetail from "../components/EntityDetail.astro";
import type { EntityRelationGroup } from "../components/EntityDetail.astro";
import EntityFacts from "../components/EntityFacts.astro";
import type { EntityFact } from "../components/EntityFacts.astro";
import type { DecisionDetail } from "../types";

interface Props {
  decision: DecisionDetail;
}

const { decision } = Astro.props;

const facts: EntityFact[] = [{ label: "Status", value: decision.status }];
if (decision.followUp) {
  facts.push({ label: "Follow up", value: decision.followUp });
}

const relations: EntityRelationGroup[] = [];
if (decision.reverses.length > 0) {
  relations.push({
    label: "Reverses",
    links: decision.reverses.map((rel) => ({ href: rel.href ?? "#", title: rel.title })),
  });
}
if (decision.reversedBy.length > 0) {
  relations.push({
    label: "Reversed by",
    links: decision.reversedBy.map((rel) => ({ href: rel.href ?? "#", title: rel.title })),
  });
}
const related = [...decision.relatedClaims, ...decision.relatedProjects];
if (related.length > 0) {
  relations.push({
    label: "Related",
    links: related.map((rel) => ({
      href: rel.href ?? "#",
      title: rel.title,
      ...(rel.value !== undefined ? { value: rel.value } : {}),
    })),
  });
}

const hasOptions = decision.options.length > 0;
---

<EntityDetail
  title={decision.title}
  dates={[{ label: decision.date }]}
  tags={decision.tags}
  heroImage={heroImage}
  relations={relations}
>
  <EntityFacts slot="meta" facts={facts} />

  <p class="tl-chosen">{decision.chosen}</p>

  <div class="tl-lede">
    <p class="tl-eyebrow">Context</p>
    <p class="tl-lede-text">{decision.context}</p>
  </div>
  <div class="tl-lede">
    <p class="tl-eyebrow">Why</p>
    <p class="tl-lede-text">{decision.why}</p>
  </div>
  <div class="tl-lede">
    <p class="tl-eyebrow">Reconsider if</p>
    <p class="tl-lede-text">{decision.changeTrigger}</p>
  </div>

  <slot />

  {
    hasOptions && (
      <div class="tl-lede">
        <p class="tl-eyebrow">Options considered</p>
        <ol class="tl-options">
          {decision.options.map((option) => (
            <li>{option}</li>
          ))}
        </ol>
      </div>
    )
  }
</EntityDetail>

<style>
  .tl-chosen {
    margin-block: 1.5em;
    font-size: 1.4rem;
    font-weight: 560;
    line-height: 1.3;
  }

  .tl-lede {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-block: 1.5em;
  }

  .tl-eyebrow {
    margin: 0;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  .tl-lede-text {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.4;
  }

  .tl-options {
    margin: 0;
    padding-left: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
</style>
