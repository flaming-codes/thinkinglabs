---
import AppShell from "../components/AppShell.astro";
import EntityConicGradient from "../components/EntityConicGradient.astro";
import type { DecisionDetail } from "../types";

interface Props {
  decision: DecisionDetail;
}

const { decision } = Astro.props;
const hasReverseLinks = decision.reverses.length > 0 || decision.reversedBy.length > 0;
const related = [...decision.relatedClaims, ...decision.relatedProjects];
const hasTags = decision.tags.length > 0;
---

<AppShell activeNav="Index">
  <article class="tl-decision-minimal" data-selected-label={decision.title} data-entity="decisions">
    <header class="tl-decision-minimal-hero" aria-labelledby="decision-title">
      <h1 id="decision-title">{decision.title}</h1>
      <p class="tl-decision-minimal-chosen">{decision.chosen}</p>
      <EntityConicGradient class="tl-decision-minimal-mark" entity="decisions" />
    </header>

    <div class="tl-decision-minimal-flow">
      <section class="tl-decision-minimal-meta" aria-label="Decision metadata">
        <p>{decision.followUp ? `Follow up ${decision.followUp}` : "No follow-up scheduled"}</p>
        {hasTags ? <p>{decision.tags.map((tag) => `#${tag}`).join(" ")}</p> : null}
      </section>

      <section class="tl-decision-minimal-section" aria-label="Context">
        <h2>Context</h2>
        <p>{decision.context}</p>
      </section>

      <section class="tl-decision-minimal-section" aria-label="Rationale">
        <h2>Why</h2>
        <p>{decision.why}</p>
      </section>

      <section class="tl-decision-minimal-section is-emphasis" aria-label="Reversal condition">
        <h2>Reconsider if</h2>
        <p>{decision.changeTrigger}</p>
      </section>

      <section class="tl-decision-minimal-prose" aria-label="Decision notes">
        <slot />
      </section>

      {decision.options.length > 0 ? (
        <section class="tl-decision-minimal-section" aria-label="Options considered">
          <h2>Options</h2>
          <ol class="tl-decision-minimal-options">
            {decision.options.map((option, index) => (
              <li>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <p>{option}</p>
              </li>
            ))}
          </ol>
        </section>
      ) : null}

      {hasReverseLinks ? (
        <section class="tl-decision-minimal-section" aria-label="Decision reversals">
          <h2>Reversals</h2>
          <div class="tl-decision-minimal-links">
            {decision.reverses.map((rel) => (
              <p>
                <span>Reverses</span>
                {rel.href ? <a href={rel.href}>{rel.title}</a> : rel.title}
              </p>
            ))}
            {decision.reversedBy.map((rel) => (
              <p>
                <span>Reversed by</span>
                {rel.href ? <a href={rel.href}>{rel.title}</a> : rel.title}
              </p>
            ))}
          </div>
        </section>
      ) : null}

      {related.length > 0 ? (
        <section class="tl-decision-minimal-section" aria-label="Related entries">
          <h2>Related</h2>
          <div class="tl-decision-minimal-links">
            {related.map((rel) => (
              <p>
                <span>{rel.value ? `${rel.kind} ${rel.value}` : rel.kind}</span>
                {rel.href ? <a href={rel.href}>{rel.title}</a> : rel.title}
              </p>
            ))}
          </div>
        </section>
      ) : null}
    </div>
  </article>
</AppShell>

<style>
  .tl-decision-minimal {
    --tl-decision-minimal-measure: min(100%, 720px);
    padding: clamp(7rem, 15vh, 10rem) 24px clamp(7rem, 16vh, 11rem);
    background: var(--tl-bg);
    color: var(--tl-ink);
  }

  .tl-decision-minimal-hero,
  .tl-decision-minimal-flow {
    width: var(--tl-decision-minimal-measure);
    margin-inline: auto;
  }

  .tl-decision-minimal-hero {
    display: grid;
    gap: 24px;
    align-content: end;
    min-height: clamp(24rem, 62vh, 38rem);
  }

  :global(.tl-decision-minimal-mark) {
    width: 100%;
    height: clamp(13rem, 32vh, 22rem);
    margin-top: clamp(2.75rem, 8vh, 5.75rem);
    background: var(--tl-media-bg);
  }

  .tl-decision-minimal-hero h1 {
    max-width: 18ch;
    color: var(--tl-ink);
    font-size: clamp(34px, 4.8vw, 58px);
    font-weight: 610;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .tl-decision-minimal-chosen {
    max-width: 35rem;
    margin-top: 10px;
    color: var(--tl-prose-ink);
    font-size: clamp(22px, 2.5vw, 30px);
    font-weight: 560;
    line-height: 1.24;
    letter-spacing: 0;
  }

  .tl-decision-minimal-flow {
    display: grid;
    gap: clamp(3.75rem, 9vh, 6.5rem);
    margin-top: clamp(4.5rem, 13vh, 8.5rem);
  }

  .tl-decision-minimal-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 28px;
    color: var(--tl-muted);
    font-size: 14px;
    font-weight: var(--tl-detail-body-weight);
    line-height: 1.55;
  }

  .tl-decision-minimal-section,
  .tl-decision-minimal-prose {
    display: grid;
    gap: 16px;
  }

  .tl-decision-minimal-section h2 {
    color: var(--tl-ink);
    font-size: 15px;
    font-weight: 680;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .tl-decision-minimal-section p,
  .tl-decision-minimal-prose {
    color: var(--tl-prose-ink);
    font-size: 18px;
    font-weight: var(--tl-detail-body-weight);
    line-height: 1.72;
    letter-spacing: 0;
  }

  .tl-decision-minimal-section.is-emphasis p {
    color: var(--tl-ink);
    font-size: clamp(22px, 2.3vw, 28px);
    font-weight: 540;
    line-height: 1.36;
  }

  .tl-decision-minimal-prose :global(p) {
    margin: 0 0 1.2rem;
  }

  .tl-decision-minimal-prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .tl-decision-minimal-prose :global(a),
  .tl-decision-minimal-links :global(a) {
    color: var(--tl-ink);
    font-weight: 570;
    text-decoration: none;
  }

  .tl-decision-minimal-options {
    display: grid;
    gap: 22px;
    margin: 4px 0 0;
    padding: 0;
    list-style: none;
  }

  .tl-decision-minimal-options li {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    gap: 20px;
    align-items: baseline;
  }

  .tl-decision-minimal-options li > span,
  .tl-decision-minimal-links span {
    color: var(--tl-muted);
    font-size: var(--tl-type-mono-xs);
    font-weight: var(--tl-type-metadata-weight);
    line-height: 1.2;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tl-decision-minimal-options p,
  .tl-decision-minimal-links p {
    margin: 0;
  }

  .tl-decision-minimal-links {
    display: grid;
    gap: 24px;
    margin-top: 4px;
  }

  .tl-decision-minimal-links p {
    display: grid;
    gap: 8px;
  }

  @media (max-width: 640px) {
    .tl-decision-minimal {
      padding: 6rem 16px 6.5rem;
    }

    .tl-decision-minimal-hero {
      min-height: 0;
    }

    :global(.tl-decision-minimal-mark) {
      height: 12rem;
      margin-top: 3rem;
    }

    .tl-decision-minimal-hero h1 {
      max-width: 17ch;
      font-size: 31px;
      line-height: 1.12;
    }

    .tl-decision-minimal-chosen {
      font-size: 21px;
    }

    .tl-decision-minimal-flow {
      gap: 4rem;
      margin-top: 5rem;
    }

    .tl-decision-minimal-section p,
    .tl-decision-minimal-prose {
      font-size: 17px;
    }

    .tl-decision-minimal-options li {
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 14px;
    }
  }
</style>
