---
import EntityIndexPageComposition from "./EntityIndexPageComposition.astro";
import type { EntityIndexPage, PostSummary } from "../types";

interface Props {
  posts: PostSummary[];
}

const { posts } = Astro.props;
const words = posts.reduce((sum, post) => sum + post.words, 0);
const minutes = posts.reduce((sum, post) => sum + post.minutes, 0);
const featured = posts.find((post) => post.featured) ?? posts[0];

const page: EntityIndexPage = {
  slug: "posts",
  eyebrow: "/posts",
  title: "Posts",
  deck: "Long-form pieces polished enough to stand alone. Fewer than thoughts, slower to publish, and easier to cite.",
  count: `${posts.length} essays`,
  stats: [
    { label: "Essays", value: String(posts.length), sub: "published here" },
    {
      label: "Words",
      value: words.toLocaleString(),
      sub: "across the archive",
    },
    { label: "Read time", value: `${minutes}m`, sub: "estimated total" },
  ],
  sections: [
    {
      label: featured ? "Latest first" : "Archive",
      title: "Finished writing.",
      rows: posts.map((post) => ({
        kicker: post.date,
        title: post.title,
        href: post.href,
        summary: post.deck,
        meta: [
          post.topic,
          `${post.minutes} min`,
          `${post.words.toLocaleString()} words`,
        ],
        value: post.featured ? "latest" : post.topic,
        valueLabel: "filed",
      })),
    },
  ],
  footer: "If a piece is here, it is because I would be willing to defend it.",
};
---

<EntityIndexPageComposition page={page} />
