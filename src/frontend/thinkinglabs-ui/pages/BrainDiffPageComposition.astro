---
import AppShell from "../components/AppShell.astro";
import type { DiffDay, DiffEntry } from "../types";

interface Props {
  days: DiffDay[];
}

const { days } = Astro.props;

function deltaLabel(entry: DiffEntry): string {
  if (entry.outcome) {
    return `resolved · ${entry.outcome}`;
  }

  if (entry.from !== undefined && entry.to !== undefined) {
    return `conf ${entry.from.toFixed(2)} → ${entry.to.toFixed(2)}`;
  }

  if (entry.conf !== undefined) {
    return `conf ${entry.conf.toFixed(2)}`;
  }

  if (entry.words !== undefined) {
    return `${entry.words.toLocaleString()} words`;
  }

  return "—";
}

function deltaTone(entry: DiffEntry): "up" | "down" | "neutral" {
  if (entry.from === undefined || entry.to === undefined) {
    return "neutral";
  }

  if (entry.to > entry.from) {
    return "up";
  }

  if (entry.to < entry.from) {
    return "down";
  }

  return "neutral";
}
---

<AppShell activeNav="Brain-diff">
  <section class="tl-page-head">
    <div class="tl-eyebrow">/feed/brain-diff</div>
    <div class="tl-page-head-grid">
      <h1>Diff.</h1>
      <p>
        Substantive changes across all kinds, generated from git history. Boring edits are filtered
        out so review focuses on meaningful updates.
      </p>
    </div>
  </section>

  {days.map((day) => (
    <section class="tl-day-section">
      <header class="tl-day-head">
        <h2>{day.day}</h2>
        <div></div>
      </header>

      {day.entries.map((entry) => (
        <article class="tl-day-entry">
          <div class="tl-mono">
            {entry.kind}
            <span>{entry.action}</span>
          </div>
          <div>
            <h3>{entry.title}</h3>
            {entry.why && <p>“{entry.why}”</p>}
          </div>
          <div class:list={["tl-mono", "is-right", `is-${deltaTone(entry)}`]}>{deltaLabel(entry)}</div>
        </article>
      ))}
    </section>
  ))}

  <footer class="tl-quote-foot is-inline">
    <span>/feed/brain-diff.xml · /feed/brain-diff.json</span>
    <span>last build 2026-05-03 14:22 UTC</span>
  </footer>
</AppShell>

<style>
  .tl-day-section {
    width: var(--tl-center);
    margin-inline: auto;
  }

  .tl-day-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    padding: 0 0 18px;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-day-entry {
    position: relative;
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto;
    gap: 22px;
    align-items: baseline;
    padding: 30px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-quote-foot {
    padding-bottom: 18vh;
  }

  @media (max-width: 767px) {
    .tl-day-section {
      width: min(100% - 40px, 43.75rem);
    }

    .tl-day-entry {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
