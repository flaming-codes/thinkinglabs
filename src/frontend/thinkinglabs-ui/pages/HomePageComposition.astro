---
import AppShell from "../components/AppShell.astro";
import HandDrawnWordmark from "../components/HandDrawnWordmark.astro";
import type { KindSummary } from "../types";

interface Props {
  kinds: KindSummary[];
}

const { kinds } = Astro.props;
const total = kinds.reduce((sum, kind) => sum + kind.count, 0);
---

<AppShell activeNav="Index">
  <section class="tl-home-hero">
    <div class="tl-home-mark">
      <h1 class="tl-home-wordmark-heading">
        <span class="tl-visually-hidden">thinkinglabs</span>
        <HandDrawnWordmark />
      </h1>
      <div class="tl-gradient-block tl-home-gradient" aria-hidden="true"></div>
      <p class="tl-home-subline">A public thinking system for claims, reversals, and predictions.</p>
    </div>
  </section>

  <section class="tl-home-thesis-row">
    <div class="tl-eyebrow">The thesis</div>
    <p>
      Most personal sites are static essays. This one is a queryable corpus: each claim has confidence
      in [0,1], each prediction is graded against reality, and reversals stay visible rather than
      quietly edited.
    </p>
  </section>

  <section class="tl-home-index">
    <header class="tl-split-header">
      <div class="tl-eyebrow">Index of kinds</div>
      <div class="tl-mono">{total} entries · last build 2026-05-03</div>
    </header>
      <div class="tl-kind-list">
        {kinds.map((kind, index) => (
          <article class="tl-kind-row">
            <div class="tl-mono">{String(index + 1).padStart(2, "0")}</div>
            <h3>{kind.href ? <a href={kind.href}>{kind.title}</a> : kind.title}</h3>
            <p>{kind.description}</p>
            <div class="tl-kind-count">{kind.count}</div>
          </article>
        ))}
      </div>
  </section>

  <section class="tl-home-agents">
    <div class="tl-gradient-block tl-gradient-block--short" aria-hidden="true"></div>
    <div class="tl-home-agents-body">
      <h2>
        Readable by humans.
        <span class="tl-home-agents-accent">Queryable by everything else.</span>
      </h2>
      <p>
        Every page above has a structured analogue: a single
        <a href="/llms.txt">llms.txt</a> index, a remote
        <a href="/agents">MCP endpoint</a> at <code>mcp.thinkinglabs.run/mcp</code> with public
        resources and five tools, JSON dumps at <code>/api/&lt;kind&gt;.json</code>, and Atom/JSON
        brain-diff feeds for the deltas. No clone required.
      </p>
      <a class="tl-home-agents-cta" href="/agents">Open the agents surface →</a>
    </div>
  </section>

</AppShell>
