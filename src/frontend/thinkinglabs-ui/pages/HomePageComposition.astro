---
import AppShell from "../components/AppShell.astro";
import ScrollArrows from "../components/ScrollArrows.astro";
import type { KindSummary } from "../types";

interface Props {
  kinds: KindSummary[];
}

const { kinds } = Astro.props;
---

<AppShell activeNav="Index" mode="gallery">
  <div class="tl-home-stage">
    <section class="tl-gallery-section" data-selected-label="Entities">
      <div class="tl-home-gallery">
        {kinds.map((kind) => (
          <article class="tl-gallery-card" data-selected-label={kind.title}>
            <a class="tl-gallery-link" href={kind.href} aria-label={`${kind.title}: ${kind.description}`}>
              <span class="tl-gallery-label" aria-hidden="true">
                <span>{kind.title}</span>
                <span>{kind.count} {kind.count === 1 ? "entry" : "entries"}</span>
              </span>
              <span class="tl-gallery-media">
                <span class="tl-gallery-visual" data-entity={kind.slug}></span>
                <span class="tl-gallery-title" aria-hidden="true">{kind.title}</span>
              </span>
              <span class="tl-gallery-copy" aria-hidden="true">
                <span class="tl-gallery-copy-kicker">
                  {kind.count} {kind.count === 1 ? "entry" : "entries"}
                </span>
                <span class="tl-gallery-copy-title">{kind.title}</span>
                <span class="tl-gallery-copy-description">{kind.description}</span>
              </span>
            </a>
          </article>
        ))}
      </div>
      <ScrollArrows target="[data-tl-scroll]" items=".tl-gallery-card" label="Landing cards" rowOnly />
    </section>
  </div>
</AppShell>

<style>
  .tl-home-stage {
    display: grid;
  }

  .tl-gallery-section {
    position: relative;
    display: grid;
    align-items: center;
    min-height: var(--tl-viewport-height);
    padding:
      clamp(4.5rem, 8vw, 9rem)
      max(clamp(1.5rem, 4vw, 3.5rem), var(--tl-safe-right))
      clamp(4.5rem, 8vw, 9rem)
      max(clamp(1.5rem, 4vw, 3.5rem), var(--tl-safe-left));
  }

  .tl-home-gallery {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
    width: min(100%, 1120px);
    margin: 0 auto;
    padding: 25vh 0;
  }

  .tl-gallery-card {
    position: relative;
    width: min(100%, clamp(var(--card-width, 16rem), 18vw, calc(var(--card-width, 16rem) + 9rem)));
    margin: 0 auto;
    --card-aspect: 1 / 1;
    --tl-card-shadow: var(--tl-gallery-shadow);
    --tl-card-hover-shadow: var(--tl-gallery-hover-shadow);
  }

  /* Per-card variants rotate by index modulo 7 (desktop width and aspect)
     and modulo 3 (mobile width). Values mirror the original index arrays. */
  .tl-gallery-card:nth-child(7n+1) { --card-width: 16rem; --card-half-width: clamp(8rem, 9vw, 12.5rem); --card-aspect: 3 / 4; }
  .tl-gallery-card:nth-child(7n+2) { --card-width: 22rem; --card-half-width: clamp(11rem, 9vw, 15.5rem); --card-aspect: 4 / 3; }
  .tl-gallery-card:nth-child(7n+3) { --card-width: 16rem; --card-half-width: clamp(8rem, 9vw, 12.5rem); --card-aspect: 3 / 4; }
  .tl-gallery-card:nth-child(7n+4) { --card-width: 17.5rem; --card-half-width: clamp(8.75rem, 9vw, 13.25rem); --card-aspect: 1 / 1; }
  .tl-gallery-card:nth-child(7n+5) { --card-width: 22rem; --card-half-width: clamp(11rem, 9vw, 15.5rem); --card-aspect: 4 / 3; }
  .tl-gallery-card:nth-child(7n+6) { --card-width: 16rem; --card-half-width: clamp(8rem, 9vw, 12.5rem); --card-aspect: 3 / 4; }
  .tl-gallery-card:nth-child(7n+7) { --card-width: 17.5rem; --card-half-width: clamp(8.75rem, 9vw, 13.25rem); --card-aspect: 1 / 1; }

  .tl-gallery-link {
    display: block;
    overflow: hidden;
    background: var(--tl-panel);
    color: inherit;
    box-shadow: var(--tl-card-shadow);
    text-decoration: none;
    transition: box-shadow 0.55s ease;
  }

  .tl-gallery-link:focus-visible {
    outline: 2px solid var(--tl-focus);
    outline-offset: 4px;
  }

  .tl-gallery-label {
    position: absolute;
    z-index: 2;
    top: 50%;
    left: calc(100% + clamp(0.5rem, 1.2vw, 0.9rem));
    display: grid;
    gap: 0.18rem;
    color: var(--tl-ink);
    pointer-events: none;
    transform: translateY(-50%);
  }

  .tl-gallery-label span {
    color: var(--tl-ink);
    font-size: 12px;
    font-weight: 550;
    line-height: 1;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .tl-gallery-label span:first-child {
    font-weight: 650;
  }

  .tl-gallery-label span:last-child {
    color: var(--tl-muted);
    font-weight: 420;
  }

  .tl-gallery-media {
    position: relative;
    display: block;
    aspect-ratio: var(--card-aspect, 1 / 1);
    overflow: hidden;
  }

  .tl-gallery-visual {
    position: absolute;
    inset: 0;
    --tl-gradient-base-rotate: 0deg;
    --tl-gradient-base-scale: 1.2;
    background: var(--tl-entity-gradient-luster), var(--tl-entity-gradient);
    background-blend-mode: var(--tl-entity-gradient-blend);
    transform: rotate(var(--tl-gradient-base-rotate)) scale(var(--tl-gradient-base-scale));
    transform-origin: var(--tl-gradient-origin, 50% 50%);
    animation: tl-entity-tile-drift var(--tl-gradient-duration, 26s) ease-in-out infinite
      alternate;
  }

  .tl-gallery-link:hover,
  .tl-gallery-link:focus-visible {
    box-shadow: var(--tl-card-hover-shadow);
  }

  :global(.tl-shell) .tl-gallery-link:hover,
  :global(.tl-shell) .tl-gallery-link:focus-visible {
    opacity: 1;
  }

  .tl-gallery-title {
    display: none;
  }

  .tl-gallery-copy {
    display: none;
  }

  @media (min-width: 768px) {
    :global(.tl-shell[data-layout="gallery"][data-active-nav="Index"]) :global(.tl-scroll) {
      overflow: auto hidden;
    }

    :global(.tl-shell[data-layout="gallery"][data-active-nav="Index"]) :global(.tl-scroll-content),
    .tl-home-stage {
      min-width: max-content;
    }

    .tl-gallery-section {
      width: max-content;
      min-width: 100vw;
      padding-block: clamp(5rem, 8vw, 9rem);
      padding-inline: 0;
    }

    .tl-home-gallery {
      flex-direction: row;
      align-items: center;
      gap: clamp(9rem, 13vw, 15rem);
      width: max-content;
      max-width: none;
      margin: 0;
      padding: 0;
    }

    .tl-gallery-card {
      flex: 0 0 auto;
      width: clamp(var(--card-width, 16rem), 18vw, calc(var(--card-width, 16rem) + 9rem));
    }

    .tl-gallery-card:first-child {
      margin-inline-start: calc(50vw - var(--card-half-width, clamp(8rem, 9vw, 12.5rem)));
    }

    .tl-gallery-card:last-child {
      margin-inline-end: calc(50vw - var(--card-half-width, clamp(8rem, 9vw, 12.5rem)));
    }
  }

  @media (max-width: 767px) {
    .tl-gallery-section {
      padding-inline: 20px;
    }

    .tl-home-gallery {
      gap: 6.5rem;
      padding: 23vh 0;
    }

    .tl-gallery-card {
      width: min(100%, var(--card-width-mobile, 13.5rem));
    }

    .tl-gallery-link {
      overflow: visible;
      background: transparent;
      box-shadow: none;
    }

    .tl-gallery-media {
      box-shadow: var(--tl-card-shadow);
      transition: box-shadow 0.55s ease;
    }

    .tl-gallery-link:hover,
    .tl-gallery-link:focus-visible {
      box-shadow: none;
    }

    .tl-gallery-link:hover .tl-gallery-media,
    .tl-gallery-link:focus-visible .tl-gallery-media {
      box-shadow: var(--tl-card-hover-shadow);
    }

    /* Mobile width rotates by index modulo 3: idx 1, 4, 7, ... use 18rem; others 13.5rem. */
    .tl-gallery-card:nth-child(3n+2) {
      --card-width-mobile: 18rem;
    }

    .tl-gallery-label {
      display: none;
    }

    .tl-gallery-copy {
      display: grid;
      gap: 0.42rem;
      padding-block-start: 0.95rem;
      text-align: left;
    }

    .tl-gallery-copy-kicker {
      color: var(--tl-muted);
      font-size: 11px;
      font-weight: 540;
      line-height: 1;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .tl-gallery-copy-title {
      color: var(--tl-ink);
      font-size: 17px;
      font-weight: 650;
      line-height: 1.08;
    }

    .tl-gallery-copy-description {
      color: var(--tl-prose-soft);
      font-size: 13px;
      font-weight: 420;
      line-height: 1.42;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-gallery-visual {
      animation: none;
    }
  }
</style>
