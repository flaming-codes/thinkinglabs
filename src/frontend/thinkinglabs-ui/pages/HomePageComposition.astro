---
import AppShell from "../components/AppShell.astro";
import ScrollArrows from "../components/ScrollArrows.astro";
import type { KindSummary } from "../types";

interface Props {
  kinds: KindSummary[];
}

const { kinds } = Astro.props;
---

<AppShell activeNav="Index" mode="gallery">
  <div class="tl-home-stage">
    <section class="tl-gallery-section" data-selected-label="Entities">
      <div class="tl-home-gallery">
        {kinds.map((kind) => (
          <article class="tl-gallery-card" data-selected-label={kind.title}>
            <a class="tl-gallery-link" href={kind.href} aria-label={`${kind.title}: ${kind.description}`}>
              <span class="tl-gallery-label" aria-hidden="true">
                <span>{kind.title}</span>
                <span>{kind.count} {kind.count === 1 ? "entry" : "entries"}</span>
              </span>
              <span class="tl-gallery-media">
                <span class="tl-gallery-visual" data-entity={kind.slug}></span>
                <span class="tl-gallery-title" aria-hidden="true">{kind.title}</span>
              </span>
              <span class="tl-gallery-copy" aria-hidden="true">
                <span class="tl-gallery-copy-kicker">
                  {kind.count} {kind.count === 1 ? "entry" : "entries"}
                </span>
                <span class="tl-gallery-copy-title">{kind.title}</span>
                <span class="tl-gallery-copy-description">{kind.description}</span>
              </span>
            </a>
          </article>
        ))}
      </div>
      <ScrollArrows target="[data-tl-scroll]" items=".tl-gallery-card" label="Landing cards" rowOnly />
    </section>
  </div>
</AppShell>

<style>
  .tl-home-stage {
    display: grid;
  }

  .tl-gallery-section {
    position: relative;
    display: grid;
    align-items: center;
    min-height: 100vh;
    padding: clamp(4.5rem, 8vw, 9rem) clamp(1.5rem, 4vw, 3.5rem);
  }

  .tl-home-gallery {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
    width: min(100%, 1120px);
    margin: 0 auto;
    padding: 25vh 0;
  }

  .tl-gallery-card {
    position: relative;
    width: min(100%, clamp(var(--card-width, 16rem), 18vw, calc(var(--card-width, 16rem) + 9rem)));
    margin: 0 auto;
    --card-aspect: 1 / 1;
    --tl-card-shadow: var(--tl-gallery-shadow);
    --tl-card-hover-shadow:
      0 2px 3px rgba(7, 9, 13, 0.03),
      0 16px 34px -18px rgba(7, 9, 13, 0.22),
      0 40px 82px -42px rgba(7, 9, 13, 0.22),
      0 96px 154px -82px rgba(7, 9, 13, 0.18);
    animation: tl-item-card-mount 620ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* Per-card variants rotate by index modulo 7 (desktop width and aspect)
     and modulo 3 (mobile width). Values mirror the original index arrays. */
  .tl-gallery-card:nth-child(7n+1) { --card-width: 16rem; --card-half-width: clamp(8rem, 9vw, 12.5rem); --card-aspect: 3 / 4; }
  .tl-gallery-card:nth-child(7n+2) { --card-width: 22rem; --card-half-width: clamp(11rem, 9vw, 15.5rem); --card-aspect: 4 / 3; --tl-card-hover-shadow: 0 2px 3px rgba(7, 9, 13, 0.03), 0 18px 38px -20px rgba(7, 9, 13, 0.2), 0 48px 88px -46px rgba(7, 9, 13, 0.18), 0 106px 168px -90px rgba(7, 9, 13, 0.16); }
  .tl-gallery-card:nth-child(7n+3) { --card-width: 16rem; --card-half-width: clamp(8rem, 9vw, 12.5rem); --card-aspect: 3 / 4; --tl-card-hover-shadow: 0 2px 3px rgba(7, 9, 13, 0.035), 0 14px 32px -17px rgba(7, 9, 13, 0.24), 0 38px 78px -40px rgba(7, 9, 13, 0.2), 0 88px 148px -78px rgba(7, 9, 13, 0.18); }
  .tl-gallery-card:nth-child(7n+4) { --card-width: 17.5rem; --card-half-width: clamp(8.75rem, 9vw, 13.25rem); --card-aspect: 1 / 1; --tl-card-hover-shadow: 0 2px 3px rgba(7, 9, 13, 0.03), 0 16px 36px -18px rgba(7, 9, 13, 0.18), 0 46px 92px -46px rgba(7, 9, 13, 0.2), 0 112px 172px -92px rgba(7, 9, 13, 0.17); }
  .tl-gallery-card:nth-child(7n+5) { --card-width: 22rem; --card-half-width: clamp(11rem, 9vw, 15.5rem); --card-aspect: 4 / 3; --tl-card-hover-shadow: 0 2px 3px rgba(7, 9, 13, 0.035), 0 20px 42px -22px rgba(7, 9, 13, 0.22), 0 52px 96px -50px rgba(7, 9, 13, 0.18), 0 118px 176px -98px rgba(7, 9, 13, 0.16); }
  .tl-gallery-card:nth-child(7n+6) { --card-width: 16rem; --card-half-width: clamp(8rem, 9vw, 12.5rem); --card-aspect: 3 / 4; --tl-card-hover-shadow: 0 2px 3px rgba(7, 9, 13, 0.03), 0 15px 32px -17px rgba(7, 9, 13, 0.2), 0 42px 84px -43px rgba(7, 9, 13, 0.22), 0 102px 158px -84px rgba(7, 9, 13, 0.16); }
  .tl-gallery-card:nth-child(7n+7) { --card-width: 17.5rem; --card-half-width: clamp(8.75rem, 9vw, 13.25rem); --card-aspect: 1 / 1; --tl-card-hover-shadow: 0 2px 3px rgba(7, 9, 13, 0.03), 0 17px 36px -19px rgba(7, 9, 13, 0.2), 0 44px 86px -44px rgba(7, 9, 13, 0.2), 0 100px 160px -86px rgba(7, 9, 13, 0.18); }

  .tl-gallery-card:nth-child(1) { animation-delay: 40ms; }
  .tl-gallery-card:nth-child(2) { animation-delay: 80ms; }
  .tl-gallery-card:nth-child(3) { animation-delay: 120ms; }
  .tl-gallery-card:nth-child(4) { animation-delay: 160ms; }
  .tl-gallery-card:nth-child(5) { animation-delay: 200ms; }
  .tl-gallery-card:nth-child(6) { animation-delay: 240ms; }
  .tl-gallery-card:nth-child(7) { animation-delay: 280ms; }
  .tl-gallery-card:nth-child(8) { animation-delay: 320ms; }
  .tl-gallery-card:nth-child(9) { animation-delay: 360ms; }

  @keyframes tl-item-card-mount {
    from {
      opacity: 0;
      transform: translate3d(0, 10px, 0);
    }

    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  .tl-gallery-link {
    display: block;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.96);
    color: inherit;
    box-shadow: var(--tl-card-shadow);
    text-decoration: none;
    transition: box-shadow 0.55s ease;
  }

  .tl-gallery-link:focus-visible {
    outline: 2px solid #2f6bff;
    outline-offset: 4px;
  }

  .tl-gallery-label {
    position: absolute;
    z-index: 2;
    top: 50%;
    left: calc(100% + clamp(0.5rem, 1.2vw, 0.9rem));
    display: grid;
    gap: 0.18rem;
    color: var(--tl-ink);
    pointer-events: none;
    transform: translateY(-50%);
  }

  .tl-gallery-label span {
    color: #0c1424;
    font-size: 12px;
    font-weight: 550;
    line-height: 1;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .tl-gallery-label span:first-child {
    font-weight: 650;
  }

  .tl-gallery-label span:last-child {
    color: rgba(12, 20, 36, 0.6);
    font-weight: 420;
  }

  .tl-gallery-media {
    position: relative;
    display: block;
    aspect-ratio: var(--card-aspect, 1 / 1);
    overflow: hidden;
  }

  .tl-gallery-visual {
    position: absolute;
    inset: 0;
    --tl-gradient-base-rotate: 0deg;
    --tl-gradient-base-scale: 1.2;
    background: var(--tl-entity-gradient);
    transform: rotate(var(--tl-gradient-base-rotate)) scale(var(--tl-gradient-base-scale));
    transform-origin: var(--tl-gradient-origin, 50% 50%);
    animation: tl-gallery-gradient-drift var(--tl-gradient-duration, 26s) ease-in-out infinite
      alternate;
  }

  @keyframes tl-gallery-gradient-drift {
    0% {
      transform: rotate(0deg) scale(1.2) translate3d(-0.4%, -0.25%, 0);
    }

    50% {
      transform: rotate(2.4deg) scale(1.215) translate3d(0.25%, 0.45%, 0);
    }

    100% {
      transform: rotate(-2deg) scale(1.21) translate3d(0.5%, -0.2%, 0);
    }
  }

  .tl-gallery-link:hover,
  .tl-gallery-link:focus-visible {
    box-shadow: var(--tl-card-hover-shadow);
  }

  :global(.tl-shell) .tl-gallery-link:hover,
  :global(.tl-shell) .tl-gallery-link:focus-visible {
    opacity: 1;
  }

  .tl-gallery-visual[data-entity="claims"] {
    --tl-entity-gradient: var(--tl-entity-gradient-claims);
    --tl-gradient-duration: 29s;
    --tl-gradient-origin: 44% 48%;
  }

  .tl-gallery-visual[data-entity="thoughts"] {
    --tl-entity-gradient: var(--tl-entity-gradient-thoughts);
    --tl-gradient-duration: 34s;
    --tl-gradient-origin: 42% 55%;
  }

  .tl-gallery-visual[data-entity="inputs"] {
    --tl-entity-gradient: var(--tl-entity-gradient-inputs);
    --tl-gradient-duration: 27s;
    --tl-gradient-origin: 46% 50%;
  }

  .tl-gallery-visual[data-entity="projects"] {
    --tl-entity-gradient: var(--tl-entity-gradient-projects);
    --tl-gradient-duration: 24s;
    --tl-gradient-origin: 48% 52%;
  }

  .tl-gallery-visual[data-entity="predictions"] {
    --tl-entity-gradient: var(--tl-entity-gradient-predictions);
    --tl-gradient-duration: 32s;
    --tl-gradient-origin: 50% 50%;
  }

  .tl-gallery-visual[data-entity="changed-my-mind"] {
    --tl-entity-gradient: var(--tl-entity-gradient-changed-my-mind);
    --tl-gradient-duration: 31s;
    --tl-gradient-origin: 48% 50%;
  }

  .tl-gallery-visual[data-entity="decisions"] {
    --tl-entity-gradient: var(--tl-entity-gradient-decisions);
    --tl-gradient-duration: 36s;
    --tl-gradient-origin: 44% 54%;
  }

  .tl-gallery-visual[data-entity="questions"] {
    --tl-entity-gradient: var(--tl-entity-gradient-questions);
    --tl-gradient-duration: 25s;
    --tl-gradient-origin: 46% 50%;
  }

  .tl-gallery-visual[data-entity="posts"] {
    --tl-entity-gradient: var(--tl-entity-gradient-posts);
    --tl-gradient-duration: 30s;
    --tl-gradient-origin: 44% 52%;
  }

  .tl-gallery-title {
    display: none;
  }

  .tl-gallery-copy {
    display: none;
  }

  @media (min-width: 768px) {
    :global(.tl-shell[data-layout="gallery"][data-active-nav="Index"]) :global(.tl-scroll) {
      overflow: auto hidden;
    }

    :global(.tl-shell[data-layout="gallery"][data-active-nav="Index"]) :global(.tl-scroll-content),
    .tl-home-stage {
      min-width: max-content;
    }

    .tl-gallery-section {
      width: max-content;
      min-width: 100vw;
      padding-block: clamp(5rem, 8vw, 9rem);
      padding-inline: 0;
    }

    .tl-home-gallery {
      flex-direction: row;
      align-items: center;
      gap: clamp(9rem, 13vw, 15rem);
      width: max-content;
      max-width: none;
      margin: 0;
      padding: 0;
    }

    .tl-gallery-card {
      flex: 0 0 auto;
      width: clamp(var(--card-width, 16rem), 18vw, calc(var(--card-width, 16rem) + 9rem));
    }

    .tl-gallery-card:first-child {
      margin-inline-start: calc(50vw - var(--card-half-width, clamp(8rem, 9vw, 12.5rem)));
    }

    .tl-gallery-card:last-child {
      margin-inline-end: calc(50vw - var(--card-half-width, clamp(8rem, 9vw, 12.5rem)));
    }
  }

  @media (max-width: 767px) {
    .tl-gallery-section {
      padding-inline: 20px;
    }

    .tl-home-gallery {
      gap: 3.6rem;
      padding: 23vh 0;
    }

    .tl-gallery-card {
      width: min(100%, var(--card-width-mobile, 13.5rem));
    }

    /* Mobile width rotates by index modulo 3: idx 1, 4, 7, ... use 18rem; others 13.5rem. */
    .tl-gallery-card:nth-child(3n+2) {
      --card-width-mobile: 18rem;
    }

    .tl-gallery-label {
      display: none;
    }

    .tl-gallery-copy {
      display: grid;
      gap: 0.42rem;
      padding: 1rem;
    }

    .tl-gallery-copy-kicker {
      color: rgba(12, 20, 36, 0.56);
      font-size: 11px;
      font-weight: 540;
      line-height: 1;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .tl-gallery-copy-title {
      color: #0c1424;
      font-size: 17px;
      font-weight: 650;
      line-height: 1.08;
    }

    .tl-gallery-copy-description {
      color: rgba(12, 20, 36, 0.66);
      font-size: 13px;
      font-weight: 420;
      line-height: 1.42;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-gallery-card {
      animation: none;
    }

    .tl-gallery-visual {
      animation: none;
    }
  }
</style>
