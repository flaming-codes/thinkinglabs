---
import AppShell from "../components/AppShell.astro";
import type { AboutKind } from "../types";

interface Props {
  kinds: AboutKind[];
}

const { kinds } = Astro.props;
---

<AppShell activeNav="About">
  <section class="tl-page-head is-spacious">
    <div class="tl-eyebrow">§ /about</div>
    <h1>About.</h1>
  </section>

  <section class="tl-about-lede">
    <p>thinkinglabs is a single person's working surface, made public.</p>
    <p>
      I'm Tom. I work mostly on AI systems and the boring parts of getting them to behave. This site
      is the room I think in — a filtered view of a markdown repo I edit every day.
    </p>
  </section>

  <section>
    <header class="tl-about-section-head">
      <div class="tl-eyebrow">§ 01 / structure</div>
      <h2>
        Nine kinds of entry,
        <br />
        one graph.
      </h2>
    </header>

    <div class="tl-about-kind-list">
      {kinds.map((kind, index) => (
        <article class="tl-about-kind-row">
          <div class="tl-mono">{String(index + 1).padStart(2, "0")}</div>
          <div>
            <h3>{kind.href ? <a href={kind.href}>{kind.name}</a> : kind.name}</h3>
            <p>{kind.gloss}</p>
          </div>
          <div class="tl-mono is-right">{kind.count} entries</div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <header class="tl-about-section-head">
      <div class="tl-eyebrow">§ 02 / how it works</div>
      <h2>
        The site is the by-product,
        <br />
        not the point.
      </h2>
    </header>
    <div class="tl-about-prose-grid">
      <article>
        <div class="tl-eyebrow">Markdown is canonical</div>
        <h3>Every entry is a file in a git repository.</h3>
        <p>
          The site is rebuilt from those files. If the rendering layer disappeared tomorrow, the
          source of truth would still exist.
        </p>
      </article>
      <article>
        <div class="tl-eyebrow">Calibration over rhetoric</div>
        <h3>The numbers are not a performance.</h3>
        <p>
          Claims carry confidence values. Predictions resolve. Both are tracked over time so it is
          harder to drift quietly.
        </p>
      </article>
    </div>
  </section>

  <section class="tl-about-colophon">
    <div class="tl-eyebrow">§ colophon</div>
    <div>
      <h3>Type</h3>
      <p>Forum</p>
      <p>Inter</p>
    </div>
    <div>
      <h3>Stack</h3>
      <p>Markdown, git-tracked</p>
      <p>Static build</p>
      <p>SQLite as derived index</p>
      <p>MCP for agent access</p>
    </div>
    <div>
      <h3>Feeds</h3>
      <p>brain-diff.xml</p>
      <p>posts.xml</p>
      <p>predictions.json</p>
    </div>
  </section>
</AppShell>
