---
import EntityIndexPageComposition from "./EntityIndexPageComposition.astro";
import type { EntityIndexPage, ThoughtSummary } from "../types";

interface Props {
  thoughts: ThoughtSummary[];
}

const { thoughts } = Astro.props;
const words = thoughts.reduce((sum, thought) => sum + thought.words, 0);
const backlinks = thoughts.reduce((sum, thought) => sum + thought.backlinks, 0);
const settled = thoughts.filter(
  (thought) => thought.state === "settled",
).length;

const page: EntityIndexPage = {
  slug: "thoughts",
  eyebrow: "/thoughts",
  title: "Thoughts",
  deck: "Draft prose and working arguments. Some entries are finished, some are still warm, and some are preserved because the unfinished shape is useful.",
  count: `${thoughts.length} entries`,
  stats: [
    { label: "Settled", value: String(settled), sub: "marked as durable" },
    { label: "Words", value: words.toLocaleString(), sub: "roughly on file" },
    { label: "Backlinks", value: String(backlinks), sub: "claims and inputs" },
  ],
  sections: [
    {
      label: "Last touched",
      title: "Open notebooks.",
      rows: thoughts.map((thought, index) => ({
        kicker: String(thoughts.length - index).padStart(3, "0"),
        title: thought.title,
        href: thought.href,
        summary: thought.excerpt,
        meta: [
          `${thought.state.replace("-", " ")}`,
          `touched ${thought.touched}`,
          `${thought.minutes} min`,
          `${thought.backlinks} backlinks`,
        ],
        value: thought.words.toLocaleString(),
        valueLabel: "words",
      })),
    },
  ],
  footer:
    "Most thoughts are wrong somewhere. The useful part is making the wrongness visible.",
};
---

<EntityIndexPageComposition page={page} />
