---
import EntityIndexPageComposition from "./EntityIndexPageComposition.astro";
import type { DecisionRow, DecisionsView, EntityIndexPage } from "../types";

interface Props {
  view: DecisionsView;
}

const { view } = Astro.props;
const row = (decision: DecisionRow) => ({
  kicker: decision.date,
  title: decision.title,
  href: decision.href,
  summary: decision.summary,
  meta: [
    `status ${decision.state}`,
    decision.review ? `review ${decision.review}` : "no scheduled review",
    ...(decision.reversedBy ? [`reversed by ${decision.reversedBy}`] : []),
  ],
  value: decision.state,
  valueLabel: "state",
});

const page: EntityIndexPage = {
  slug: "decisions",
  eyebrow: "/decisions",
  title: "Decisions.",
  deck: "Choices, rejected alternatives, and the question that would make a decision worth revisiting. Reversals stay on file.",
  count: `${view.total} decisions`,
  stats: view.stats,
  sections: [
    { label: "Active", title: "In force.", rows: view.active.map(row) },
    { label: "Reversed", title: "Changed later.", rows: view.reversed.map(row) },
    { label: "Archived", title: "Retired.", rows: view.archived.map(row) },
  ],
};
---

<EntityIndexPageComposition page={page} />
