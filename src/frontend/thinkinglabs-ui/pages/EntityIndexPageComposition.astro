---
import HalfHeroLayout from "../components/HalfHeroLayout.astro";
import type { EntityIndexPage } from "../types";

interface Props {
  page: EntityIndexPage;
}

const { page } = Astro.props;
---

<HalfHeroLayout title={page.title} heroSlug={page.slug}>
  <Fragment slot="deck">
    <p>{page.deck}</p>

    {
      page.stats.length > 0 ? (
        <dl class="flex flex-wrap gap-x-6 gap-y-3">
          {page.stats.map((stat) => (
            <div class="flex flex-col gap-0.5">
              <dt class="text-[9px] font-semibold uppercase tracking-[0.14em]">{stat.label}</dt>
              <dd class="m-0">{stat.value}</dd>
              <small class="text-[10px] opacity-60">{stat.sub}</small>
            </div>
          ))}
        </dl>
      ) : null
    }
  </Fragment>

  {
    page.sections.map((section) => {
      const rows = section.rows ?? [];
      const hasBody = Boolean(section.body?.length);
      return (
        <section class="flex flex-col gap-6">
          <header class="flex flex-col gap-1">
            <span class="text-[9px] font-semibold uppercase tracking-[0.14em]">{section.label}</span>
            <h2 class="opacity-70">{section.title}</h2>
          </header>

          {hasBody ? (
            <div class="flex flex-col gap-2 opacity-70">
              {section.body?.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          ) : null}

          {rows.length > 0 ? (
            <ul class="flex flex-col gap-7">
              {rows.map((row) => (
                <li>
                  {row.href ? (
                    <a href={row.href} class="tl-hover-link block no-underline">
                      <div class="flex flex-col gap-1">
                        <div class="flex items-baseline justify-between gap-4">
                          <span class="text-[9px] font-semibold uppercase tracking-[0.14em] opacity-40">{row.kicker}</span>
                          {row.value ? (
                            <span class="opacity-60">
                              {row.value}
                              {row.valueLabel ? ` ${row.valueLabel}` : ""}
                            </span>
                          ) : null}
                        </div>
                        <h3 class="m-0">{row.title}</h3>
                        {row.summary ? <p class="opacity-70">{row.summary}</p> : null}
                        {row.meta?.length ? (
                          <p class="text-[9px] font-semibold uppercase tracking-[0.14em] opacity-40">{row.meta.join(" · ")}</p>
                        ) : null}
                      </div>
                    </a>
                  ) : (
                    <div class="flex flex-col gap-1">
                      <div class="flex items-baseline justify-between gap-4">
                        <span class="text-[9px] font-semibold uppercase tracking-[0.14em] opacity-40">{row.kicker}</span>
                        {row.value ? (
                          <span class="opacity-60">
                            {row.value}
                            {row.valueLabel ? ` ${row.valueLabel}` : ""}
                          </span>
                        ) : null}
                      </div>
                      <h3 class="m-0">
                        {row.title}
                      </h3>
                      {row.summary ? <p class="opacity-70">{row.summary}</p> : null}
                      {row.meta?.length ? (
                        <p class="text-[9px] font-semibold uppercase tracking-[0.14em] opacity-40">{row.meta.join(" · ")}</p>
                      ) : null}
                    </div>
                  )}
                </li>
              ))}
            </ul>
          ) : !hasBody ? (
            <p class="opacity-50">Nothing filed here yet.</p>
          ) : null}
        </section>
      );
    })
  }

  {page.footer ? <footer class="opacity-60">{page.footer}</footer> : null}
</HalfHeroLayout>
