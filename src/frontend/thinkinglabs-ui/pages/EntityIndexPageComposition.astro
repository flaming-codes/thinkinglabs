---
import AppShell from "../components/AppShell.astro";
import type { EntityIndexPage } from "../types";

interface Props {
  page: EntityIndexPage;
}

const { page } = Astro.props;
---

<AppShell activeNav="Index">
  <section class="tl-entity-page" data-selected-label={page.title}>
    <article class="tl-entity-document">
      <div class="tl-entity-visual" data-entity={page.slug}></div>

      <div class="tl-entity-content">
        <div class="tl-entity-head">
          <div>
            <h1>{page.title}</h1>
            <p>{page.deck}</p>
          </div>
          <dl class="tl-entity-stats">
            {page.stats.map((stat) => (
              <div>
                <dt>{stat.label}</dt>
                <dd>{stat.value}</dd>
                <small>{stat.sub}</small>
              </div>
            ))}
          </dl>
        </div>

        {page.sections.map((section) => (
          <section class="tl-entity-section">
            <header>
              <span>{section.label}</span>
              <h2>{section.title}</h2>
            </header>

            <div class="tl-entity-list">
              {section.rows.length > 0 ? (
                section.rows.map((row) => (
                  <article class="tl-entity-row">
                    <div class="tl-entity-row-kicker">{row.kicker}</div>
                    <div>
                      <h3>{row.href ? <a href={row.href}>{row.title}</a> : row.title}</h3>
                      {row.summary ? <p>{row.summary}</p> : null}
                      {row.meta && row.meta.length > 0 ? (
                        <div class="tl-entity-row-meta">
                          {row.meta.map((item) => <span>{item}</span>)}
                        </div>
                      ) : null}
                    </div>
                    <div class="tl-entity-row-value">
                      {row.value ? <strong>{row.value}</strong> : null}
                      {row.valueLabel ? <span>{row.valueLabel}</span> : null}
                    </div>
                  </article>
                ))
              ) : (
                <p class="tl-entity-empty">Nothing filed here yet.</p>
              )}
            </div>
          </section>
        ))}

        {page.footer ? <footer class="tl-entity-footer">{page.footer}</footer> : null}
      </div>
    </article>
  </section>
</AppShell>

<style>
  .tl-entity-page {
    min-height: 100vh;
    padding: clamp(5.75rem, 10vh, 8rem) 20px clamp(4rem, 9vh, 7rem);
    background: var(--tl-bg);
  }

  .tl-entity-document {
    width: min(100%, 920px);
    margin: 0 auto;
  }

  .tl-entity-visual {
    position: relative;
    display: grid;
    min-height: clamp(19rem, 45vh, 34rem);
    place-items: center;
    overflow: hidden;
    color: var(--tl-ink);
    background: var(--tl-entity-gradient);
  }

  .tl-entity-visual::before {
    position: absolute;
    inset: -18%;
    --tl-gradient-base-rotate: -4deg;
    --tl-gradient-base-scale: 1.08;
    background: var(--tl-entity-gradient);
    content: "";
    transform: rotate(var(--tl-gradient-base-rotate)) scale(var(--tl-gradient-base-scale));
    transform-origin: var(--tl-gradient-origin, 50% 50%);
    animation: tl-entity-gradient-drift var(--tl-gradient-duration, 28s) ease-in-out infinite
      alternate;
  }

  @keyframes tl-entity-gradient-drift {
    0% {
      transform: rotate(-4deg) scale(1.08) translate3d(-0.25%, -0.2%, 0);
    }

    50% {
      transform: rotate(-1.6deg) scale(1.095) translate3d(0.25%, 0.35%, 0);
    }

    100% {
      transform: rotate(-6deg) scale(1.09) translate3d(0.35%, -0.15%, 0);
    }
  }

  .tl-entity-visual::after {
    content: none;
  }

  .tl-entity-visual[data-entity="claims"] {
    --tl-entity-gradient: var(--tl-entity-gradient-claims);
    --tl-gradient-duration: 29s;
    --tl-gradient-origin: 44% 48%;
  }

  .tl-entity-visual[data-entity="thoughts"] {
    --tl-entity-gradient: var(--tl-entity-gradient-thoughts);
    --tl-gradient-duration: 34s;
    --tl-gradient-origin: 42% 55%;
  }

  .tl-entity-visual[data-entity="inputs"] {
    --tl-entity-gradient: var(--tl-entity-gradient-inputs);
    --tl-gradient-duration: 27s;
    --tl-gradient-origin: 46% 50%;
  }

  .tl-entity-visual[data-entity="projects"] {
    --tl-entity-gradient: var(--tl-entity-gradient-projects);
    --tl-gradient-duration: 24s;
    --tl-gradient-origin: 48% 52%;
  }

  .tl-entity-visual[data-entity="predictions"] {
    --tl-entity-gradient: var(--tl-entity-gradient-predictions);
    --tl-gradient-duration: 32s;
    --tl-gradient-origin: 50% 50%;
  }

  .tl-entity-visual[data-entity="changed-my-mind"] {
    --tl-entity-gradient: var(--tl-entity-gradient-changed-my-mind);
    --tl-gradient-duration: 31s;
    --tl-gradient-origin: 48% 50%;
  }

  .tl-entity-visual[data-entity="decisions"] {
    --tl-entity-gradient: var(--tl-entity-gradient-decisions);
    --tl-gradient-duration: 36s;
    --tl-gradient-origin: 44% 54%;
  }

  .tl-entity-visual[data-entity="questions"] {
    --tl-entity-gradient: var(--tl-entity-gradient-questions);
    --tl-gradient-duration: 25s;
    --tl-gradient-origin: 46% 50%;
  }

  .tl-entity-visual[data-entity="posts"] {
    --tl-entity-gradient: var(--tl-entity-gradient-posts);
    --tl-gradient-duration: 30s;
    --tl-gradient-origin: 44% 52%;
  }

  .tl-entity-visual > span {
    position: absolute;
    z-index: 1;
    color: rgba(7, 9, 13, 0.72);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .tl-entity-content {
    padding: clamp(1.8rem, 5vw, 3.4rem) 0 0;
  }

  .tl-entity-kicker,
  .tl-entity-section header span,
  .tl-entity-row-kicker,
  .tl-entity-row-meta,
  .tl-entity-row-value span,
  .tl-entity-stats dt,
  .tl-entity-stats small {
    color: var(--tl-muted);
    font-size: 11px;
    font-weight: 650;
    line-height: 1.2;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .tl-entity-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(11rem, 17rem);
    gap: clamp(1.8rem, 5vw, 4rem);
    align-items: start;
    padding-top: 10px;
  }

  .tl-entity-head h1 {
    max-width: 11ch;
    font-size: clamp(38px, 7vw, 70px);
    font-weight: 620;
    line-height: 0.9;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }

  .tl-entity-head p {
    max-width: 46rem;
    margin-top: 24px;
    color: rgba(7, 9, 13, 0.68);
    font-size: 15px;
    line-height: 1.7;
  }

  .tl-entity-stats {
    display: grid;
    gap: 18px;
    margin: 0;
  }

  .tl-entity-stats div {
    padding-top: 14px;
    border-top: 1px solid var(--tl-line);
  }

  .tl-entity-stats dd {
    margin: 7px 0 4px;
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 650;
    line-height: 0.95;
    letter-spacing: -0.045em;
  }

  .tl-entity-section {
    margin-top: clamp(3.5rem, 9vh, 6.5rem);
  }

  .tl-entity-section header {
    display: grid;
    grid-template-columns: 9rem minmax(0, 1fr);
    gap: 24px;
    align-items: end;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-entity-section h2 {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .tl-entity-list {
    display: grid;
  }

  .tl-entity-row {
    display: grid;
    grid-template-columns: 7rem minmax(0, 1fr) minmax(5.5rem, 8rem);
    gap: clamp(1rem, 3vw, 2.4rem);
    padding: 25px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-entity-row h3 {
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: -0.035em;
  }

  .tl-entity-row p {
    margin-top: 10px;
    color: rgba(7, 9, 13, 0.64);
    font-size: 14px;
    line-height: 1.55;
  }

  .tl-entity-row-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 7px 12px;
    margin-top: 15px;
    letter-spacing: 0.08em;
  }

  .tl-entity-row-value {
    display: grid;
    align-content: start;
    justify-items: end;
    gap: 7px;
    text-align: right;
  }

  .tl-entity-row-value strong {
    font-size: clamp(20px, 3vw, 32px);
    font-weight: 650;
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .tl-entity-empty,
  .tl-entity-footer {
    color: rgba(7, 9, 13, 0.6);
    font-size: 14px;
    line-height: 1.6;
  }

  .tl-entity-empty {
    padding: 25px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-entity-footer {
    margin-top: clamp(3rem, 7vh, 5rem);
    padding-top: 18px;
    border-top: 1px solid var(--tl-line);
  }

  @media (max-width: 767px) {
    .tl-entity-page {
      padding: 5rem 14px 3rem;
    }

    .tl-entity-content {
      padding: 24px 20px 28px;
    }

    .tl-entity-head,
    .tl-entity-section header,
    .tl-entity-row {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .tl-entity-visual {
      min-height: 18rem;
    }

    .tl-entity-head h1 {
      max-width: none;
      font-size: clamp(40px, 13vw, 58px);
    }

    .tl-entity-stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .tl-entity-stats dd {
      font-size: clamp(24px, 8vw, 34px);
    }

    .tl-entity-row-value {
      justify-items: start;
      text-align: left;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-entity-visual::before {
      animation: none;
    }
  }
</style>
