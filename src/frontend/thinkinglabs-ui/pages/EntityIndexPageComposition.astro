---
import AppShell from "../components/AppShell.astro";
import type { EntityIndexPage } from "../types";

interface Props {
  page: EntityIndexPage;
}

const { page } = Astro.props;
---

<AppShell activeNav="Index">
  <section class="tl-entity-page" data-selected-label={page.title}>
    <article class="tl-entity-document">
      <div class="tl-entity-visual" data-entity={page.slug} aria-hidden="true"></div>

      <header class="tl-entity-head">
        <h1>{page.title}</h1>
        <p class="tl-entity-deck">{page.deck}</p>

        <dl class="tl-entity-stats">
          {page.stats.map((stat) => (
            <div>
              <dt>{stat.label}</dt>
              <dd>{stat.value}</dd>
              <small>{stat.sub}</small>
            </div>
          ))}
        </dl>
      </header>

      <div class="tl-entity-body">
        {page.sections.map((section) => {
          const rows = section.rows ?? [];
          const hasBody = Boolean(section.body?.length);
          return (
            <section class="tl-entity-section">
              <header>
                <span>{section.label}</span>
                <h2>{section.title}</h2>
              </header>

              <div class="tl-entity-list">
                {hasBody ? (
                  <div class="tl-entity-section-body">
                    {section.body?.map((paragraph) => <p>{paragraph}</p>)}
                  </div>
                ) : null}
                {rows.length > 0 ? (
                  rows.map((row) => (
                    <article class="tl-entity-row">
                      <div class="tl-entity-row-kicker">{row.kicker}</div>
                      <div class="tl-entity-row-main">
                        <h3>{row.href ? <a href={row.href}>{row.title}</a> : row.title}</h3>
                        {row.summary ? <p>{row.summary}</p> : null}
                        {(row.meta && row.meta.length > 0) || row.value ? (
                          <div class="tl-entity-row-meta">
                            {row.value ? (
                              <span class="tl-entity-row-status">
                                <strong>{row.value}</strong>
                                {row.valueLabel ? <em>{row.valueLabel}</em> : null}
                              </span>
                            ) : null}
                            {row.meta?.map((item) => <span>{item}</span>)}
                          </div>
                        ) : null}
                      </div>
                    </article>
                  ))
                ) : !hasBody ? (
                  <p class="tl-entity-empty">Nothing filed here yet.</p>
                ) : null}
              </div>
            </section>
          );
        })}

        {page.footer ? <footer class="tl-entity-footer">{page.footer}</footer> : null}
      </div>
    </article>
  </section>
</AppShell>

<style>
  .tl-entity-page {
    min-height: var(--tl-viewport-height);
    padding:
      clamp(5.75rem, 10vh, 8rem)
      var(--tl-ui-right)
      max(clamp(4rem, 9vh, 7rem), var(--tl-safe-bottom))
      var(--tl-ui-left);
    background: var(--tl-bg);
    color: var(--tl-ink);
  }

  .tl-entity-document {
    display: grid;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
    width: min(100%, 920px);
    margin: 0 auto;
  }

  .tl-entity-visual {
    position: relative;
    overflow: hidden;
    width: 100%;
    min-height: clamp(19rem, 45vh, 34rem);
    background: var(--tl-entity-gradient);
  }

  .tl-entity-visual::before {
    position: absolute;
    inset: -18%;
    background: var(--tl-entity-gradient);
    content: "";
    transform: rotate(-4deg) scale(1.08);
    transform-origin: var(--tl-gradient-origin, 50% 50%);
    animation: tl-entity-gradient-drift var(--tl-gradient-duration, 28s) ease-in-out infinite
      alternate;
  }

  @keyframes tl-entity-gradient-drift {
    0% {
      transform: rotate(-4deg) scale(1.08) translate3d(-0.25%, -0.2%, 0);
    }

    50% {
      transform: rotate(-1.6deg) scale(1.095) translate3d(0.25%, 0.35%, 0);
    }

    100% {
      transform: rotate(-6deg) scale(1.09) translate3d(0.35%, -0.15%, 0);
    }
  }


  .tl-entity-head {
    display: grid;
    gap: 10px;
    max-width: 42rem;
    padding-top: clamp(1.35rem, 3vw, 2.25rem);
  }

  .tl-entity-head h1 {
    font-size: clamp(20px, 2.1vw, 29px);
    font-weight: 560;
    line-height: 1.08;
    letter-spacing: -0.018em;
  }

  .tl-entity-deck,
  .tl-entity-row-main p,
  .tl-entity-footer {
    color: rgba(7, 9, 13, 0.58);
    font-size: 13px;
    line-height: 1.62;
  }

  .tl-entity-stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
    align-items: start;
    width: max-content;
    margin: 0;
    padding-top: 1.15rem;
  }

  .tl-entity-stats div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: baseline;
  }

  .tl-entity-stats dt,
  .tl-entity-section header span,
  .tl-entity-row-kicker,
  .tl-entity-row-meta,
  .tl-entity-row-status em {
    color: var(--tl-muted);
    font-size: 11px;
    font-weight: 650;
    line-height: 1.1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .tl-entity-stats dd {
    margin: 0;
    font-size: 18px;
    font-weight: 560;
    line-height: 1;
    letter-spacing: -0.018em;
  }

  .tl-entity-stats small {
    color: rgba(7, 9, 13, 0.5);
    font-size: 11px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0;
    text-transform: none;
  }

  .tl-entity-body {
    display: grid;
    gap: clamp(2rem, 6vh, 4rem);
    width: 100%;
    padding-top: clamp(3rem, 8vh, 5.5rem);
  }

  .tl-entity-section {
    display: grid;
    grid-template-columns: minmax(7rem, 9rem) minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
  }

  .tl-entity-section header {
    display: block;
    padding: 0;
  }

  .tl-entity-section h2 {
    margin-top: 7px;
    color: rgba(7, 9, 13, 0.7);
    font-size: 13px;
    font-weight: 560;
    line-height: 1.2;
  }

  .tl-entity-list {
    display: grid;
  }

  .tl-entity-row {
    display: grid;
    grid-template-columns: 4.5rem minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 1.7rem);
    padding: 0 0 24px;
  }

  .tl-entity-row + .tl-entity-row {
    padding-top: 2px;
  }

  .tl-entity-row-main h3 {
    font-size: clamp(15px, 1.4vw, 18px);
    font-weight: 560;
    line-height: 1.22;
    letter-spacing: -0.012em;
  }

  .tl-entity-row-main h3 a {
    color: inherit;
    text-decoration: none;
  }

  .tl-entity-row-main h3 a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .tl-entity-row-main p {
    max-width: 54ch;
    margin-top: 6px;
  }

  .tl-entity-section-body {
    display: grid;
    gap: 0.85rem;
    max-width: 58ch;
    padding-bottom: 24px;
  }

  .tl-entity-section-body p {
    color: rgba(7, 9, 13, 0.62);
    font-size: 13px;
    line-height: 1.65;
  }

  .tl-entity-row-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
    align-items: baseline;
    margin-top: 9px;
    font-size: 10px;
    letter-spacing: 0.12em;
  }

  .tl-entity-row-status {
    display: inline-flex;
    gap: 6px;
    align-items: baseline;
  }

  .tl-entity-row-status strong {
    color: var(--tl-ink);
    font-size: 10px;
    font-weight: 650;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .tl-entity-empty {
    padding: 6px 0 24px;
    color: rgba(7, 9, 13, 0.5);
    font-size: 13px;
    line-height: 1.6;
  }

  .tl-entity-footer {
    grid-column: 1 / -1;
    margin-top: clamp(1rem, 3vw, 2rem);
    padding-top: 18px;
    border-top: 1px solid var(--tl-line);
  }

  @media (max-width: 767px) {
    .tl-entity-page {
      padding: 5rem 14px 3rem;
    }

    .tl-entity-visual {
      min-height: 18rem;
    }

    .tl-entity-stats {
      grid-template-columns: 1fr;
      gap: 8px;
      width: auto;
    }

    .tl-entity-section {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .tl-entity-row {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-entity-visual::before {
      animation: none;
    }
  }
</style>
