---
import AppShell from "../components/AppShell.astro";
import type { EntityIndexPage } from "../types";

interface Props {
  page: EntityIndexPage;
}

const { page } = Astro.props;
---

<AppShell activeNav="Index">
  <section class="tl-entity-page" data-selected-label={page.title}>
    <article class="tl-entity-document">
      <div class="tl-entity-visual" data-entity={page.slug}></div>

      <div class="tl-entity-content">
        <div class="tl-entity-head">
          <div>
            <h1>{page.title}</h1>
            <p>{page.deck}</p>
          </div>
          <dl class="tl-entity-stats">
            {page.stats.map((stat) => (
              <div>
                <dt>{stat.label}</dt>
                <dd>{stat.value}</dd>
                <small>{stat.sub}</small>
              </div>
            ))}
          </dl>
        </div>

        {page.sections.map((section) => (
          <section class="tl-entity-section">
            <header>
              <span>{section.label}</span>
              <h2>{section.title}</h2>
            </header>

            <div class="tl-entity-list">
              {section.rows.length > 0 ? (
                section.rows.map((row) => (
                  <article class="tl-entity-row">
                    <div class="tl-entity-row-kicker">{row.kicker}</div>
                    <div>
                      <h3>{row.href ? <a href={row.href}>{row.title}</a> : row.title}</h3>
                      {row.summary ? <p>{row.summary}</p> : null}
                      {row.meta && row.meta.length > 0 ? (
                        <div class="tl-entity-row-meta">
                          {row.meta.map((item) => <span>{item}</span>)}
                        </div>
                      ) : null}
                    </div>
                    <div class="tl-entity-row-value">
                      {row.value ? <strong>{row.value}</strong> : null}
                      {row.valueLabel ? <span>{row.valueLabel}</span> : null}
                    </div>
                  </article>
                ))
              ) : (
                <p class="tl-entity-empty">Nothing filed here yet.</p>
              )}
            </div>
          </section>
        ))}

        {page.footer ? <footer class="tl-entity-footer">{page.footer}</footer> : null}
      </div>
    </article>
  </section>
</AppShell>
