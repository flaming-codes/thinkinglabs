---
import { resolveEntityHero } from "../lib/entity-hero.ts";
import EntityDetail from "../components/EntityDetail.astro";
import type { EntityRelationGroup } from "../components/EntityDetail.astro";
import EntityFacts from "../components/EntityFacts.astro";
import type { QuestionDetail } from "../types";

interface Props {
  question: QuestionDetail;
}

const { question } = Astro.props;
const heroImage = resolveEntityHero("questions", question.slug);

const related = [...question.relatedClaims, ...question.relatedProjects];
const relations: EntityRelationGroup[] =
  related.length > 0
    ? [
        {
          label: "Related",
          links: related.map((rel) => ({
            href: rel.href ?? "#",
            title: rel.title,
            ...(rel.value !== undefined ? { value: rel.value } : {}),
          })),
        },
      ]
    : [];

const hasAttempts = question.attempts.length > 0;
---

<EntityDetail
  title={question.question}
  dates={[{ label: `asked ${question.asked}` }]}
  tags={question.tags}
  heroImage={heroImage}
  relations={relations}
>
  <EntityFacts slot="meta" facts={[{ label: "Status", value: question.status }]} />

  <div class="tl-lede">
    <p class="tl-eyebrow">Context</p>
    <p class="tl-lede-text">{question.context}</p>
  </div>
  <div class="tl-lede">
    <p class="tl-eyebrow">Ideal responder</p>
    <p class="tl-lede-text">{question.idealResponder}</p>
  </div>

  <slot />

  {
    hasAttempts && (
      <div class="tl-lede">
        <p class="tl-eyebrow">Attempts</p>
        <ol class="tl-attempts">
          {question.attempts.map((attempt) => (
            <li>{attempt}</li>
          ))}
        </ol>
      </div>
    )
  }

  <form class="tl-answer" method="post" action={question.responseAction} enctype="text/plain">
    <p class="tl-eyebrow">Submit an answer</p>
    <p class="tl-answer-deck">Send a concise answer, pointers, or a route to someone who knows.</p>
    <input type="hidden" name="questionSlug" value={question.slug} />
    <label>
      <span>Name</span>
      <input name="responder.name" required />
    </label>
    <label>
      <span>Contact</span>
      <input name="responder.contact" />
    </label>
    <label>
      <span>Pointers</span>
      <input name="pointers" placeholder="URLs or references" />
    </label>
    <label class="is-wide">
      <span>Answer</span>
      <textarea name="body" required></textarea>
    </label>
    <button type="submit">Send for triage</button>
  </form>
</EntityDetail>

<style>
  .tl-lede {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-block: 1.5em;
  }

  .tl-eyebrow {
    margin: 0;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  .tl-lede-text {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.4;
  }

  .tl-attempts {
    margin: 0;
    padding-left: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .tl-answer {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-block: 2.5em 1.5em;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
  }

  .tl-answer .tl-eyebrow,
  .tl-answer-deck {
    grid-column: 1 / -1;
  }

  .tl-answer-deck {
    margin: 0;
    font-size: 0.95rem;
    opacity: 0.6;
  }

  .tl-answer label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
  }

  .tl-answer label.is-wide,
  .tl-answer button {
    grid-column: 1 / -1;
  }

  .tl-answer input,
  .tl-answer textarea {
    width: 100%;
    padding: 0.55rem 0.7rem;
    border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
    background: transparent;
    color: inherit;
    font: inherit;
    text-transform: none;
    letter-spacing: 0;
  }

  .tl-answer textarea {
    min-height: 8rem;
    resize: vertical;
  }

  .tl-answer button {
    padding: 0.7rem 1rem;
    border: 1px solid currentColor;
    background: var(--tl-ink);
    color: var(--tl-bg);
    cursor: pointer;
    font: inherit;
  }

  @media (max-width: 640px) {
    .tl-answer {
      grid-template-columns: 1fr;
    }
  }
</style>
