---
import AppShell from "../components/AppShell.astro";
import CalibrationChart from "../components/CalibrationChart.astro";
import MetricTile from "../components/MetricTile.astro";
import StatusTag from "../components/StatusTag.astro";
import type { CalibrationData } from "../types";

interface Props {
  calibration: CalibrationData;
}

const { calibration } = Astro.props;
---

<AppShell activeNav="Calibration">
  <section class="tl-page-head">
    <div class="tl-eyebrow">/predictions/calibration</div>
    <div class="tl-page-head-grid">
      <h1>Kept score.</h1>
      <p>
        Stated confidence on the x-axis, realised accuracy on the y-axis. The 45° line is perfect
        calibration. Bubble size represents bucket count.
      </p>
    </div>
  </section>

  <section class="tl-metric-grid">
    <MetricTile label="Brier" value={calibration.brier.toFixed(2)} hint="lower is better" />
    <MetricTile label="Log loss" value={calibration.log.toFixed(2)} hint="natural log" />
    <MetricTile label="Resolved" value={String(calibration.resolved)} hint={`of ${calibration.count} total`} />
    <MetricTile label="Pending" value={String(calibration.pending)} hint="not yet due" />
  </section>

  <section class="tl-chart-shell">
    <header class="tl-split-header is-tight">
      <h2>Stated vs realised.</h2>
      <div class="tl-mono">n = {calibration.resolved} resolved</div>
    </header>
    <CalibrationChart bins={calibration.bins} />
  </section>

  <section class="embedded-tool" data-embedded-tool="local-prediction-calibration-logger">
    <header class="tl-split-header is-tight">
      <h2>Local calibration log.</h2>
      <div class="tl-mono" data-local-summary aria-live="polite">No local entries stored.</div>
    </header>
    <form class="tl-embed-form" data-local-calibration-form>
      <label>
        Confidence
        <input name="confidence" type="number" min="0" max="100" step="1" value="50" />
      </label>
      <label>
        Resolved
        <select name="resolved">
          <option value="true">True</option>
          <option value="false">False</option>
        </select>
      </label>
      <button type="submit" data-record disabled>Record</button>
    </form>
    <table class="embedded-tool__fallback">
      <thead>
        <tr>
          <th scope="col">Metric</th>
          <th scope="col">Value</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Resolved predictions</td>
          <td>{calibration.resolved}</td>
        </tr>
        <tr>
          <td>Pending predictions</td>
          <td>{calibration.pending}</td>
        </tr>
        <tr>
          <td>Brier score</td>
          <td>{calibration.brier.toFixed(2)}</td>
        </tr>
      </tbody>
    </table>
    <noscript>Local logging requires JavaScript; the static calibration table remains available.</noscript>
  </section>

  <section>
    <header class="tl-split-header is-tight">
      <h2>Recent predictions.</h2>
      <div class="tl-mono">{calibration.recent.length} of {calibration.count}</div>
    </header>

    {calibration.recent.map((entry) => (
      <article class="tl-calibration-row">
        <div class="tl-claim-conf-big">{entry.stated.toFixed(2)}</div>
        <h3>{entry.href ? <a href={entry.href}>{entry.title}</a> : entry.title}</h3>
        <div class="tl-mono">{entry.outcome === null ? `due ${entry.due}` : `resolved ${entry.resolved}`}</div>
        <StatusTag
          label={
            entry.outcome === true ? "✓ true" : entry.outcome === false ? "✗ false" : "○ pending"
          }
          tone={entry.outcome === true ? "positive" : entry.outcome === false ? "negative" : "default"}
        />
      </article>
    ))}
  </section>
</AppShell>

<script>
  const storageKey = "me.embed.prediction-calibration-logger.v1";
  const root = document.querySelector(
    "[data-embedded-tool='local-prediction-calibration-logger']",
  );
  const form = root?.querySelector("[data-local-calibration-form]") as HTMLFormElement | null;
  const summary = root?.querySelector("[data-local-summary]");
  const button = root?.querySelector("button[data-record]") as HTMLButtonElement | null;

  function readEntries(): Array<{ confidence: number; resolved: boolean }> {
    try {
      const raw = window.localStorage.getItem(storageKey);
      return raw === null ? [] : JSON.parse(raw);
    } catch {
      return [];
    }
  }

  function writeSummary(): void {
    if (!summary) return;
    const entries = readEntries();
    summary.textContent =
      entries.length === 1
        ? "1 local entry stored"
        : `${entries.length} local entries stored`;
  }

  if (form && button) {
    button.disabled = false;
    writeSummary();
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const confidence = Number(data.get("confidence")) / 100;
      const resolved = data.get("resolved") === "true";
      const entries = readEntries();
      entries.push({ confidence, resolved });
      window.localStorage.setItem(storageKey, JSON.stringify(entries));
      writeSummary();
    });
  }
</script>

<style>
  .tl-metric-grid,
  .tl-chart-shell {
    width: var(--tl-center);
    margin-inline: auto;
  }

  .tl-metric-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    padding: 8vh 0;
  }

  .tl-chart-shell,
  .embedded-tool {
    background: var(--tl-panel);
    box-shadow: var(--tl-shadow);
    padding: clamp(1.1rem, 3vw, 2rem);
  }

  .tl-chart-shell h2 {
    font-size: clamp(25px, 3vw, 38px);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  .tl-calibration-row {
    position: relative;
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto;
    gap: 22px;
    align-items: baseline;
    padding: 30px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-claim-conf-big {
    font-size: clamp(32px, 5vw, 70px);
    font-weight: 650;
    line-height: 0.9;
    letter-spacing: -0.05em;
  }

  @media (max-width: 767px) {
    .tl-metric-grid,
    .tl-chart-shell {
      width: min(100% - 40px, 43.75rem);
    }

    .tl-metric-grid,
    .tl-calibration-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
