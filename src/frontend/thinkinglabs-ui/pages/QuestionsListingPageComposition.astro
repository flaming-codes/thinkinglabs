---
import EntityIndexPageComposition from "./EntityIndexPageComposition.astro";
import type { EntityIndexPage, QuestionsView } from "../types";

interface Props {
  view: QuestionsView;
}

const { view } = Astro.props;
const sorted = [...view.questions].sort((a, b) => b.heat - a.heat);

const page: EntityIndexPage = {
  slug: "questions",
  eyebrow: "/questions",
  title: "Questions.",
  deck: "Open questions upstream of confidence. Each one names what would actually resolve it, so it cannot hide behind more thinking.",
  count: `${view.total} open questions`,
  stats: view.stats,
  sections: [
    {
      label: "Hottest first",
      title: "What is unresolved.",
      rows: sorted.map((question) => ({
        kicker: question.asked,
        title: question.title,
        href: question.href,
        summary: question.deck,
        meta: [`would resolve: ${question.wouldResolve}`, question.topic, ...question.related],
        value: `${question.heat}/5`,
        valueLabel: "heat",
      })),
    },
  ],
  footer: "A question stays open until it becomes a claim or gets admitted as not worth pursuing.",
};
---

<EntityIndexPageComposition page={page} />
