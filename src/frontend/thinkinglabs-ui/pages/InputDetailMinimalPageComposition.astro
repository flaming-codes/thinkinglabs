---
import { resolveEntityHero } from "../lib/entity-hero.ts";
import EntityDetail from "../components/EntityDetail.astro";
import type { EntityRelationGroup } from "../components/EntityDetail.astro";
import EntityFacts from "../components/EntityFacts.astro";
import type { EntityFact } from "../components/EntityFacts.astro";
import EntitySection from "../components/EntitySection.astro";
import type { InputDetail } from "../types";

interface Props {
  input: InputDetail;
}

const { input } = Astro.props;
const heroImage = resolveEntityHero("inputs", input.slug);

const facts: EntityFact[] = [
  { label: "By", value: input.by },
  { label: "Kind", value: input.kind },
  { label: "Year", value: input.year },
];
if (input.reread.length > 0) {
  facts.push({ label: "Re-reads", value: String(input.reread.length) });
}

const relations: EntityRelationGroup[] = [];
if (input.url) {
  relations.push({
    label: "Source",
    links: [{ href: input.url, title: input.publisher !== "—" ? input.publisher : input.url }],
  });
}
if (input.citations.length > 0) {
  relations.push({
    label: "Cited by",
    links: input.citations.map((citation) => ({
      href: citation.href ?? "#",
      title: citation.title,
      ...(citation.conf !== undefined
        ? { value: citation.conf.toFixed(2) }
        : citation.date
          ? { value: citation.date }
          : {}),
    })),
  });
}

const hasOneLine = input.oneLine.trim().length > 0 && input.oneLine !== input.takeaway;
const hasMarginNotes = input.marginNotes.length > 0;
---

<EntityDetail
  title={input.title}
  dates={[{ label: `read ${input.read}` }]}
  heroImage={heroImage}
  relations={relations}
>
  <EntityFacts slot="meta" facts={facts} />

  <p class="tl-takeaway">{input.takeaway}</p>
  {hasOneLine && <p>{input.oneLine}</p>}

  {
    hasMarginNotes && (
      <Fragment slot="aside">
        <EntitySection label="Margin notes">
          {input.marginNotes.map((note) => (
            <div class="tl-note">
              <span class="opacity-50">{note.page}</span>
              <span>{note.text}</span>
            </div>
          ))}
        </EntitySection>
      </Fragment>
    )
  }
</EntityDetail>

<style>
  .tl-takeaway {
    margin-block: 1.5em;
    font-size: 1.5rem;
    font-weight: 520;
    line-height: 1.2;
  }

  .tl-note {
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    gap: 1rem;
    align-items: baseline;
  }

  @media (max-width: 640px) {
    .tl-note {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
