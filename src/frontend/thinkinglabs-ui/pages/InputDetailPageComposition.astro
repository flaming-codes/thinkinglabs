---
import AppShell from "../components/AppShell.astro";
import EntityConicGradient from "../components/EntityConicGradient.astro";
import IndexSectionHeader from "../components/IndexSectionHeader.astro";
import type { InputDetail } from "../types";

interface Props {
  input: InputDetail;
}

const { input } = Astro.props;

const meta = [
  { label: "First read", value: input.read },
  {
    label: "Re-read",
    value: input.reread.length > 0 ? `${input.reread.length} times` : "—",
  },
  { label: "Cited by", value: `${input.citations.length} pages` },
  { label: "One-line summary", value: input.oneLine },
];
---

<AppShell activeNav="Index">
  <article class="tl-input-detail-page" data-selected-label={input.title} data-entity="inputs">
    <header class="tl-input-detail-head">
      <EntityConicGradient class="tl-input-visual" entity="inputs" />
      <div class="tl-input-title">
        <p class="tl-mono">Input detail</p>
        <div class="tl-input-detail-kindline">
          {input.kind} · {input.year} · {input.publisher}
        </div>
        <h1>{input.title}</h1>
        <div class="tl-input-detail-byline">
          {input.url ? <a href={input.url}>{input.by}</a> : input.by}
        </div>
      </div>
    </header>

    <section class="tl-input-meta-band">
      {meta.map((cell) => (
        <div class="tl-input-meta-cell">
          <div class="tl-input-meta-label">{cell.label}</div>
          <div class="tl-input-meta-val">{cell.value}</div>
        </div>
      ))}
    </section>

    <IndexSectionHeader label="Takeaway" title="What stuck." />
    <section class="tl-input-takeaway">
      <p>"{input.takeaway}"</p>
    </section>

    {input.marginNotes.length > 0 && (
      <>
        <IndexSectionHeader label="Margin notes" title="What I wrote in the margins." />
        <section class="tl-input-notes">
          {input.marginNotes.map((note) => (
            <article class="tl-input-note">
              <span class="tl-input-note-page">{note.page}</span>
              <p class="tl-input-note-text">{note.text}</p>
            </article>
          ))}
        </section>
      </>
    )}

    {input.citations.length > 0 && (
      <>
        <IndexSectionHeader
          label="Cited by"
          title="Where it shows up<br/>in this system."
        />
        <section class="tl-input-citations">
          {input.citations.map((c) => (
            <article class="tl-input-citation">
              <span class="tl-input-citation-kind">{c.kind}</span>
              <span class="tl-input-citation-title">
                {c.href ? <a href={c.href}>{c.title}</a> : c.title}
              </span>
              <span class="tl-input-citation-conf">
                {c.conf !== undefined ? c.conf.toFixed(2) : (c.date ?? "")}
              </span>
            </article>
          ))}
        </section>
      </>
    )}
  </article>
</AppShell>

<style>
  .tl-input-detail-page {
    padding: clamp(7rem, 13vh, 10rem) 20px clamp(7rem, 16vh, 12rem);
  }

  .tl-input-detail-head,
  .tl-input-meta-band,
  .tl-input-notes,
  .tl-input-citations {
    width: min(100%, 980px);
    margin-inline: auto;
  }

  .tl-input-detail-head {
    display: grid;
    grid-template-columns: minmax(12rem, 0.58fr) minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: end;
    min-height: clamp(23rem, 58vh, 38rem);
  }

  :global(.tl-input-visual) {
    align-self: stretch;
    min-height: 16rem;
    background: var(--tl-media-bg);
  }

  .tl-input-title {
    display: grid;
    gap: 14px;
    padding-bottom: clamp(1rem, 4vh, 2rem);
  }

  .tl-input-detail-head h1 {
    font-size: clamp(44px, 7vw, 92px);
    font-weight: 650;
    line-height: 0.9;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }

  .tl-input-citation {
    position: relative;
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto;
    gap: 22px;
    align-items: baseline;
    padding: 30px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-input-citation-title {
    font-size: clamp(25px, 3vw, 38px);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  @media (max-width: 767px) {
    .tl-input-detail-page {
      padding: 5rem 16px 3rem;
    }

    .tl-input-detail-head {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    :global(.tl-input-visual) {
      min-height: 12rem;
    }

    .tl-input-detail-head,
    .tl-input-meta-band,
    .tl-input-notes,
    .tl-input-citations {
      width: 100%;
    }

    .tl-input-citation {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

</style>
