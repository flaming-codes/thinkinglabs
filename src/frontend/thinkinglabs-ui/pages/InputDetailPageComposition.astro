---
import AppShell from "../components/AppShell.astro";
import IndexSectionHeader from "../components/IndexSectionHeader.astro";
import type { InputDetail } from "../types";

interface Props {
  input: InputDetail;
}

const { input } = Astro.props;

const meta = [
  { label: "First read", value: input.read },
  {
    label: "Re-read",
    value: input.reread.length > 0 ? `${input.reread.length} times` : "—",
  },
  { label: "Cited by", value: `${input.citations.length} pages` },
  { label: "One-line summary", value: input.oneLine },
];
---

<AppShell activeNav="Index">
  <div class="tl-index-eyebrow">/inputs/{input.slug}</div>
  <div class="tl-index-crumb">Input · {input.kind} · {input.year}</div>

  <header class="tl-input-detail-head">
    <div class="tl-input-detail-kindline">
      {input.kind} · {input.year} · {input.publisher}
    </div>
    <h1>{input.title}</h1>
    <div class="tl-input-detail-byline">{input.by}</div>
  </header>

  <section class="tl-input-meta-band">
    {meta.map((cell) => (
      <div class="tl-input-meta-cell">
        <div class="tl-input-meta-label">{cell.label}</div>
        <div class="tl-input-meta-val">{cell.value}</div>
      </div>
    ))}
  </section>

  <IndexSectionHeader label="§ 01 / takeaway" title="What stuck." />
  <section class="tl-input-takeaway">
    <p>“{input.takeaway}”</p>
  </section>

  {input.marginNotes.length > 0 && (
    <>
      <IndexSectionHeader label="§ 02 / margin notes" title="What I wrote in the margins." />
      <section class="tl-input-notes">
        {input.marginNotes.map((note) => (
          <article class="tl-input-note">
            <span class="tl-input-note-page">{note.page}</span>
            <p class="tl-input-note-text">{note.text}</p>
          </article>
        ))}
      </section>
    </>
  )}

  {input.citations.length > 0 && (
    <>
      <IndexSectionHeader
        label="§ 03 / cited by"
        title="Where it shows up<br/>in this system."
      />
      <section class="tl-input-citations">
        {input.citations.map((c) => (
          <article class="tl-input-citation">
            <span class="tl-input-citation-kind">{c.kind}</span>
            <span class="tl-input-citation-title">
              {c.href ? <a href={c.href}>{c.title}</a> : c.title}
            </span>
            <span class="tl-input-citation-conf">
              {c.conf !== undefined ? c.conf.toFixed(2) : (c.date ?? "")}
            </span>
          </article>
        ))}
      </section>
    </>
  )}
</AppShell>

<style>
  .tl-input-detail-head,
  .tl-input-meta-band,
  .tl-input-notes,
  .tl-input-citations {
    width: var(--tl-center);
    margin-inline: auto;
  }

  .tl-input-detail-head h1 {
    margin-top: 14px;
    font-size: clamp(44px, 7vw, 92px);
    font-weight: 650;
    line-height: 0.9;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }

  .tl-input-citation {
    position: relative;
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto;
    gap: 22px;
    align-items: baseline;
    padding: 30px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-input-citation-title {
    font-size: clamp(25px, 3vw, 38px);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  @media (max-width: 767px) {
    .tl-input-detail-head,
    .tl-input-meta-band,
    .tl-input-notes,
    .tl-input-citations {
      width: min(100% - 40px, 43.75rem);
    }

    .tl-input-citation {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
