---
import EntityIndexPageComposition from "./EntityIndexPageComposition.astro";
import type { EntityIndexPage, ProjectsView } from "../types";

interface Props {
  view: ProjectsView;
}

const { view } = Astro.props;

const page: EntityIndexPage = {
  slug: "projects",
  eyebrow: "/projects",
  title: "Projects.",
  deck: "Active and dormant work with state, reason, and next move. A project without a next move is just a folder with ambition.",
  count: `${view.total} projects`,
  stats: view.stats,
  sections: [
    {
      label: "Recently touched",
      title: "What is being built.",
      rows: view.rows.map((project, index) => ({
        kicker: String(index + 1).padStart(2, "0"),
        title: project.title,
        href: project.href,
        summary: project.deck,
        meta: [`status ${project.state}`, `started ${project.started}`, `last ${project.last}`, project.stack],
        value: project.state,
        valueLabel: "state",
      })),
    },
  ],
};
---

<EntityIndexPageComposition page={page} />
