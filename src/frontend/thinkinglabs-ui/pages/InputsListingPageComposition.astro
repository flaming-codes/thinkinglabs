---
import EntityIndexPageComposition from "./EntityIndexPageComposition.astro";
import type { EntityIndexPage, InputsView } from "../types";

interface Props {
  view: InputsView;
}

const { view } = Astro.props;
const sorted = [...view.inputs].sort((a, b) => b.influence - a.influence);

const page: EntityIndexPage = {
  slug: "inputs",
  eyebrow: "/inputs",
  title: "Inputs.",
  deck: "Books, papers, essays, talks, and other outside material that changed the downstream graph. Influence is counted by citations, not vibes.",
  count: `${view.total} inputs`,
  stats: view.stats,
  sections: [
    {
      label: "Most cited",
      title: "What shaped the system.",
      rows: sorted.map((input) => ({
        kicker: input.kind,
        title: input.title,
        href: input.href,
        summary: input.note,
        meta: [input.by, `read ${input.date}`, input.year],
        value: String(input.influence),
        valueLabel: "citations",
      })),
    },
  ],
};
---

<EntityIndexPageComposition page={page} />
