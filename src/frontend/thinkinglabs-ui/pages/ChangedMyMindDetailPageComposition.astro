---
import { resolveEntityHero } from "../lib/entity-hero.ts";
import EntityDetail from "../components/EntityDetail.astro";
import type { EntityRelationGroup } from "../components/EntityDetail.astro";
import type { ChangedMyMindDetail } from "../types";

interface Props {
  flip: ChangedMyMindDetail;
}

const { flip } = Astro.props;
const heroImage = resolveEntityHero("changed-my-mind", flip.slug);

const relations: EntityRelationGroup[] =
  flip.supersededClaims.length > 0
    ? [
        {
          label: "Superseded claims",
          links: flip.supersededClaims.map((claim) => ({
            href: claim.href ?? "#",
            title: claim.title,
            ...(claim.value !== undefined ? { value: claim.value } : {}),
          })),
        },
      ]
    : [];
---

<EntityDetail
  title={flip.title}
  dates={[{ label: flip.date }]}
  tags={flip.tags}
  heroImage={heroImage}
  relations={relations}
>
  <div class="tl-triptych">
    <div class="tl-lede">
      <p class="tl-eyebrow">Used to believe</p>
      <p class="tl-lede-text">{flip.usedToBelieve}</p>
    </div>
    <div class="tl-lede">
      <p class="tl-eyebrow">What changed</p>
      <p class="tl-lede-text">{flip.whatChanged}</p>
    </div>
    <div class="tl-lede">
      <p class="tl-eyebrow">Now believe</p>
      <p class="tl-lede-text">{flip.nowBelieve}</p>
    </div>
  </div>

  <slot />
</EntityDetail>

<style>
  .tl-triptych {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-block: 1.5em;
  }

  .tl-lede {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .tl-eyebrow {
    margin: 0;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  .tl-lede-text {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.4;
  }
</style>
