---
import heroImage from "@/assets/hero.png";
import EntityDetail from "../components/EntityDetail.astro";
import type { EntityRelationGroup } from "../components/EntityDetail.astro";
import EntityFacts from "../components/EntityFacts.astro";
import type { EntityFact } from "../components/EntityFacts.astro";
import EntitySection from "../components/EntitySection.astro";

export interface PredictionEvidence {
  label: string;
  href?: string;
}

export interface PredictionDetailView {
  slug: string;
  prediction: string;
  confidence: number;
  made: string;
  resolves: string;
  resolvedOn: string | null;
  resolution: "pending" | "true" | "false" | "ambiguous";
  resolutionNote: string | null;
  daysUntil: number | null;
  daysSinceMade: number | null;
  topic: string;
  tags: readonly string[];
  evidence: readonly PredictionEvidence[];
}

interface Props {
  prediction: PredictionDetailView;
}

const { prediction } = Astro.props;
const confPct = Math.round(prediction.confidence * 100);
const isResolved = prediction.resolution !== "pending";
const statusLabel = (() => {
  if (prediction.resolution === "pending") return "Held";
  if (prediction.resolution === "true") return "Resolved true";
  if (prediction.resolution === "false") return "Resolved false";
  return "Resolved ambiguous";
})();

const dates = [
  { label: `made ${prediction.made}` },
  isResolved && prediction.resolvedOn
    ? { label: `resolved ${prediction.resolvedOn}` }
    : { label: `resolves ${prediction.resolves}` },
];

const facts: EntityFact[] = [
  { label: "Confidence", value: `${confPct}%` },
  {
    label: "Status",
    value: statusLabel,
    ...(!isResolved && prediction.daysUntil !== null
      ? { sub: prediction.daysUntil < 0 ? `overdue ${Math.abs(prediction.daysUntil)}d` : `${prediction.daysUntil}d to go` }
      : {}),
  },
  { label: "Topic", value: prediction.topic },
];

const relations: EntityRelationGroup[] =
  prediction.evidence.length > 0
    ? [
        {
          label: "Evidence at time",
          links: prediction.evidence.map((item) => ({ href: item.href ?? "#", title: item.label })),
        },
      ]
    : [];
---

<EntityDetail
  title={prediction.prediction}
  dates={dates}
  tags={[...prediction.tags]}
  heroImage={heroImage}
  relations={relations}
>
  <EntityFacts slot="meta" facts={facts} />

  {
    prediction.resolutionNote && (
      <div class="tl-lede">
        <p class="tl-eyebrow">Resolution note</p>
        <p class="tl-lede-text">{prediction.resolutionNote}</p>
      </div>
    )
  }

  <slot />

  {
    prediction.daysSinceMade !== null && prediction.daysSinceMade > 0 && (
      <Fragment slot="aside">
        <EntitySection label="Timeline">
          <p class="m-0">Held for {prediction.daysSinceMade} days since it was made.</p>
        </EntitySection>
      </Fragment>
    )
  }
</EntityDetail>

<style>
  .tl-lede {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-block: 1.5em;
  }

  .tl-eyebrow {
    margin: 0;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  .tl-lede-text {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.4;
  }
</style>
