---
import EntityIndexPageComposition from "./EntityIndexPageComposition.astro";
import type { ChangedMyMindView, EntityIndexPage } from "../types";

interface Props {
  view: ChangedMyMindView;
}

const { view } = Astro.props;

const page: EntityIndexPage = {
  slug: "changed-my-mind",
  eyebrow: "/changed-my-mind",
  title: "Changed my mind.",
  deck: "Beliefs that lost enough support to deserve a public correction. The old view stays visible because the lag is part of the record.",
  count: `${view.total} flips`,
  stats: view.stats,
  sections: [
    {
      label: "Most recent",
      title: "What broke.",
      rows: view.flips.map((flip) => ({
        kicker: flip.flippedOn,
        title: flip.title,
        href: flip.href,
        summary: flip.tipper,
        meta: [`held ${flip.held}`, flip.topic],
        value: `${flip.confThen.toFixed(2)} -> ${flip.confNow.toFixed(2)}`,
        valueLabel: "confidence",
      })),
    },
  ],
  footer: "The embarrassing part is rarely the flip. It is the time spent defending the old view after the evidence moved.",
};
---

<EntityIndexPageComposition page={page} />
