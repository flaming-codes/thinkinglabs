---
import { resolveEntityHero } from "../lib/entity-hero.ts";
import EntityDetail from "../components/EntityDetail.astro";
import type { EntityRelationGroup } from "../components/EntityDetail.astro";
import EntityFacts from "../components/EntityFacts.astro";
import EntitySection from "../components/EntitySection.astro";
import type { ProjectDetail } from "../types";

interface Props {
  project: ProjectDetail;
}

const { project } = Astro.props;
const heroImage = resolveEntityHero("projects", project.slug);

const dates = [{ label: `started ${project.started}` }, { label: `touched ${project.lastTouched}` }];

const related = [...project.relatedThoughts, ...project.relatedClaims];
const relations: EntityRelationGroup[] =
  related.length > 0
    ? [
        {
          label: "Related",
          links: related.map((rel) => ({
            href: rel.href ?? "#",
            title: rel.title,
            ...(rel.value !== undefined ? { value: rel.value } : {}),
          })),
        },
      ]
    : [];

const hasLinks = project.links.length > 0;
---

<EntityDetail
  title={project.title}
  dates={dates}
  tags={project.tags}
  heroImage={heroImage}
  relations={relations}
>
  <EntityFacts slot="meta" facts={[{ label: "Status", value: project.status }]} />

  <div class="tl-lede">
    <p class="tl-eyebrow">Current question</p>
    <p class="tl-lede-text">{project.currentQuestion}</p>
  </div>
  <div class="tl-lede">
    <p class="tl-eyebrow">Help welcome</p>
    <p class="tl-lede-text">{project.helpWelcome}</p>
  </div>

  <slot />

  {
    hasLinks && (
      <Fragment slot="aside">
        <EntitySection label="Links">
          {project.links.map((link) => (
            <div class="tl-rel">
              <span class="opacity-50">{link.kind}</span>
              <span>
                {link.href ? (
                  <a class="no-underline opacity-90 transition-opacity hover:opacity-100" href={link.href}>
                    {link.title}
                  </a>
                ) : (
                  link.title
                )}
              </span>
            </div>
          ))}
        </EntitySection>
      </Fragment>
    )
  }
</EntityDetail>

<style>
  .tl-lede {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-block: 1.5em;
  }

  .tl-eyebrow {
    margin: 0;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  .tl-lede-text {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.4;
  }

  .tl-rel {
    display: grid;
    grid-template-columns: 6rem minmax(0, 1fr);
    gap: 1rem;
    align-items: baseline;
  }

  @media (max-width: 640px) {
    .tl-rel {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
