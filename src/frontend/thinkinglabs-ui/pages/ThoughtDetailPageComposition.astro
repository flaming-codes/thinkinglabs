---
import AppShell from "../components/AppShell.astro";
import EntityShaderSurface from "../components/EntityShaderSurface.astro";
import StatusTag from "../components/StatusTag.astro";
import type { ThoughtDetail } from "../types";

interface Props {
  thought: ThoughtDetail;
}

const { thought } = Astro.props;
const hasQuestions = thought.questions.length > 0;
const hasRelated = thought.related.length > 0;
const hasHistory = thought.history.length > 1;
---

<AppShell activeNav="Index">
  <article class="tl-thought-detail" data-selected-label={thought.title} data-entity="thoughts">
    <EntityShaderSurface class="tl-thought-hero-art" entity="thoughts" region="detail" />
    <header class="tl-thought-hero">
      <div class="tl-thought-title">
        <h1>{thought.title}</h1>
        <div class="tl-thought-detail-meta">
          <StatusTag label={thought.state} tone={thought.state === "settled" ? "active" : "default"} />
          <span class="tl-mono">started {thought.started}</span>
          <span class="tl-mono">touched {thought.touched}</span>
          {hasHistory && <span class="tl-mono">{thought.history.length} revisions</span>}
        </div>
        <p class="tl-thought-deck">{thought.minutes} min read across {thought.words.toLocaleString()} words.</p>
      </div>
    </header>

    <section class="tl-prose-shell">
      <div class="tl-prose-body">
        {thought.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </section>

    {hasQuestions && (
      <section class="tl-aside-block">
        <div class="tl-eyebrow">Open questions</div>
        <div>
          {thought.questions.map((question) => (
            <p class="tl-quote-line">"{question}"</p>
          ))}
        </div>
      </section>
    )}

    {hasRelated && (
      <section class="tl-aside-block">
        <div class="tl-eyebrow">Connects to</div>
        <div class="tl-rel-list">
          {thought.related.map((rel) => (
            <article class="tl-rel-row">
              <span class="tl-mono">{rel.kind}</span>
              <h3>{rel.href ? <a href={rel.href}>{rel.title}</a> : rel.title}</h3>
              <span class="tl-mono is-right">{rel.conf !== undefined ? rel.conf.toFixed(2) : ""}</span>
            </article>
          ))}
        </div>
      </section>
    )}

    {hasHistory && (
      <section class="tl-aside-block">
        <div class="tl-eyebrow">How it got here</div>
        <div>
          {thought.history.map((entry) => (
            <article class="tl-history-row is-wide">
              <span class="tl-mono">{entry.date}</span>
              <span>{entry.note}</span>
            </article>
          ))}
        </div>
      </section>
    )}
  </article>
</AppShell>

<style>
  .tl-thought-detail {
    padding: clamp(7rem, 13vh, 10rem) 20px clamp(7rem, 16vh, 12rem);
  }

  .tl-thought-hero {
    display: grid;
    width: min(100%, 980px);
    margin-inline: auto;
    padding: 0 0 clamp(2.5rem, 8vh, 5rem);
  }

  :global(.tl-thought-hero-art) {
    width: 100%;
    max-width: 980px;
    min-height: clamp(16rem, 42vh, 28rem);
    margin-inline: auto;
    background: #000;
  }

  .tl-thought-title {
    display: grid;
    gap: clamp(1.2rem, 2.8vh, 2rem);
    margin-top: clamp(2rem, 6vw, 4.5rem);
  }

  .tl-thought-title h1 {
    max-width: 50%;
    color: #000;
    font-size: clamp(30px, 4.2vw, 56px);
    font-weight: 780;
    line-height: 0.94;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .tl-thought-deck {
    max-width: 48ch;
    color: var(--tl-muted);
    font-size: 16px;
    line-height: 1.55;
  }

  .tl-thought-detail-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    align-items: center;
  }

  .tl-prose-shell,
  .tl-aside-block {
    width: min(100%, 760px);
    margin-inline: auto;
  }

  .tl-prose-shell {
    padding: clamp(1.5rem, 4vh, 3rem) 0 clamp(4rem, 10vh, 7rem);
  }

  .tl-thought-detail .tl-prose-body {
    color: #000;
    font-weight: 430;
  }

  .tl-rel-list {
    display: grid;
  }

  .tl-rel-row,
  .tl-history-row {
    position: relative;
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto;
    gap: 22px;
    align-items: baseline;
    padding: 30px 0;
  }

  .tl-rel-row h3 {
    font-size: clamp(25px, 3vw, 38px);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: 0;
  }

  .tl-aside-block {
    padding-bottom: clamp(4rem, 12vh, 8rem);
  }

  @media (max-width: 767px) {
    .tl-thought-detail {
      padding: 5rem 16px 3rem;
    }

    .tl-thought-hero {
      padding-top: 2rem;
    }

    :global(.tl-thought-hero-art) {
      min-height: 15rem;
    }

    .tl-prose-shell,
    .tl-aside-block {
      width: 100%;
    }

    .tl-rel-row,
    .tl-history-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

</style>
