---
import AppShell from "../components/AppShell.astro";
import StatusTag from "../components/StatusTag.astro";
import type { ThoughtDetail } from "../types";

interface Props {
  thought: ThoughtDetail;
}

const { thought } = Astro.props;
---

<AppShell activeNav="Index">
  <section class="tl-page-head is-detail is-spacious">
    <div class="tl-eyebrow">/thoughts/{thought.slug}</div>
    <div class="tl-mono">Thought · {thought.minutes} min · {thought.words.toLocaleString()} words</div>
    <h1>{thought.title}</h1>
    <div class="tl-thought-detail-meta">
      <StatusTag label={thought.state} tone={thought.state === "settled" ? "active" : "default"} />
      <span class="tl-mono">started {thought.started}</span>
      <span class="tl-mono">last touched {thought.touched}</span>
      <span class="tl-mono">{thought.history.length} revisions</span>
    </div>
  </section>

  <section class="tl-prose-shell">
    <div class="tl-prose-body">
      {thought.paragraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
  </section>

  <section class="tl-aside-block">
    <div class="tl-eyebrow">Open questions</div>
    <div>
      {thought.questions.map((question) => (
        <p class="tl-quote-line">“{question}”</p>
      ))}
    </div>
  </section>

  <section class="tl-aside-block">
    <div class="tl-eyebrow">Connects to</div>
    <div class="tl-rel-list">
      {thought.related.map((rel) => (
        <article class="tl-rel-row">
          <span class="tl-mono">{rel.kind}</span>
          <h3>{rel.href ? <a href={rel.href}>{rel.title}</a> : rel.title}</h3>
          <span class="tl-mono is-right">{rel.conf !== undefined ? rel.conf.toFixed(2) : ""}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="tl-aside-block">
    <div class="tl-eyebrow">How it got here</div>
    <div>
      {thought.history.map((entry) => (
        <article class="tl-history-row is-wide">
          <span class="tl-mono">{entry.date}</span>
          <span>{entry.note}</span>
        </article>
      ))}
    </div>
  </section>
</AppShell>

<style>
  .tl-prose-shell,
  .tl-aside-block {
    width: var(--tl-center);
    margin-inline: auto;
  }

  .tl-rel-list {
    display: grid;
  }

  .tl-rel-row,
  .tl-history-row {
    position: relative;
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto;
    gap: 22px;
    align-items: baseline;
    padding: 30px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-rel-row h3 {
    font-size: clamp(25px, 3vw, 38px);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  .tl-aside-block {
    padding-bottom: 18vh;
  }

  @media (max-width: 767px) {
    .tl-prose-shell,
    .tl-aside-block {
      width: min(100% - 40px, 43.75rem);
    }

    .tl-rel-row,
    .tl-history-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
