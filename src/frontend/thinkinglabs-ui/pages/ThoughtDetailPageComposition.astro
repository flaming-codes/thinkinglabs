---
import heroImage from "@/assets/hero.png";
import EntityDetail from "../components/EntityDetail.astro";
import type { EntityRelationGroup } from "../components/EntityDetail.astro";
import EntityFacts from "../components/EntityFacts.astro";
import type { EntityFact } from "../components/EntityFacts.astro";
import EntitySection from "../components/EntitySection.astro";
import type { ThoughtDetail } from "../types";

interface Props {
  thought: ThoughtDetail;
}

const { thought } = Astro.props;

const dates =
  thought.touched === thought.started
    ? [{ label: thought.started }]
    : [{ label: thought.started }, { label: `updated ${thought.touched}` }];

const facts: EntityFact[] = [
  { label: "State", value: thought.state },
  { label: "Length", value: `${thought.minutes} min read`, sub: `${thought.words.toLocaleString()} words` },
];
if (thought.history.length > 1) {
  facts.push({ label: "Revisions", value: String(thought.history.length) });
}

const relations: EntityRelationGroup[] = [];
if (thought.related.length > 0) {
  relations.push({
    label: "Connects to",
    links: thought.related.map((rel) => ({
      href: rel.href ?? "#",
      title: rel.title,
      ...(rel.conf !== undefined ? { value: rel.conf.toFixed(2) } : {}),
    })),
  });
}
if (thought.predictionEvidence.length > 0) {
  relations.push({
    label: "Prediction evidence",
    links: thought.predictionEvidence.map((rel) => ({
      href: rel.href ?? "#",
      title: rel.title,
      ...(rel.conf !== undefined ? { value: rel.conf.toFixed(2) } : {}),
    })),
  });
}

const hasQuestions = thought.questions.length > 0;
const hasHistory = thought.history.length > 1;
---

<EntityDetail title={thought.title} dates={dates} heroImage={heroImage} relations={relations}>
  <EntityFacts slot="meta" facts={facts} />

  {thought.paragraphs.map((paragraph) => <p>{paragraph}</p>)}

  <Fragment slot="aside">
    {hasQuestions && (
      <EntitySection label="Open questions">
        {thought.questions.map((question) => (
          <p class="tl-quote">“{question}”</p>
        ))}
      </EntitySection>
    )}

    {hasHistory && (
      <EntitySection label="How it got here">
        {thought.history.map((item) => (
          <div class="tl-history-row">
            <span class="opacity-50">{item.date}</span>
            <span>{item.note}</span>
          </div>
        ))}
      </EntitySection>
    )}
  </Fragment>
</EntityDetail>

<style>
  .tl-quote {
    margin: 0;
    font-style: italic;
  }

  .tl-history-row {
    display: grid;
    grid-template-columns: 8rem minmax(0, 1fr);
    gap: 1rem;
    align-items: baseline;
  }

  @media (max-width: 640px) {
    .tl-history-row {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
