---
import { resolveEntityHero } from "../lib/entity-hero.ts";
import EntityDetail from "../components/EntityDetail.astro";
import type { EntityRelationGroup } from "../components/EntityDetail.astro";
import EntityFacts from "../components/EntityFacts.astro";
import type { EntityFact } from "../components/EntityFacts.astro";
import EntitySection from "../components/EntitySection.astro";
import FigureChartPlate from "../components/FigureChartPlate.astro";
import type { PostDetail } from "../types";

interface Props {
  post: PostDetail;
}

const { post } = Astro.props;
const heroImage = resolveEntityHero("posts", post.slug);
const hasEpigraph = post.epigraph.text.trim().length > 0 && post.epigraph.text !== post.deck;
const hasFootnotes = post.footnotes.length > 0;
const hasInputs = post.inputs.length > 0;

const dates =
  post.updated === post.date
    ? [{ label: post.date }]
    : [{ label: post.date }, { label: `updated ${post.updated}` }];

const facts: EntityFact[] = [
  { label: "Length", value: `${post.minutes} min read`, sub: `${post.words.toLocaleString()} words` },
  { label: "Filed", value: post.topic },
];
if (post.backlinks > 0) {
  facts.push({ label: "Backlinks", value: `${post.backlinks} ${post.backlinks === 1 ? "entry" : "entries"}` });
}
facts.push({ label: "License", value: post.license });

const relations: EntityRelationGroup[] =
  post.related.length > 0
    ? [
        {
          label: "Where this sits in the graph",
          links: post.related.map((rel) => ({
            href: rel.href ?? "#",
            title: rel.title,
            ...(rel.conf !== undefined ? { value: rel.conf.toFixed(2) } : {}),
          })),
        },
      ]
    : [];
---

<EntityDetail title={post.title} dates={dates} heroImage={heroImage} relations={relations}>
  <EntityFacts slot="meta" facts={facts} />

  {
    hasEpigraph && (
      <p class="tl-epigraph">
        “{post.epigraph.text}”<span class="tl-epigraph-by">— {post.epigraph.by}</span>
      </p>
    )
  }
  <p class="tl-deck">{post.deck}</p>

  {
    post.sections.map((section) => (
      <section class="tl-section">
        {section.title && <h2 class="tl-section-title">{section.title}</h2>}
        {section.blocks.map((block) => {
          if (block.type === "p") return <p set:html={block.html} />;
          if (block.type === "pull") return <blockquote class="tl-pull" set:html={block.html} />;
          if (block.type === "fig") {
            return (
              <figure class="tl-figure">
                <FigureChartPlate />
                <figcaption>
                  <span>{block.caption}</span>
                  {block.source && <span class="opacity-50"> · {block.source}</span>}
                </figcaption>
              </figure>
            );
          }
          if (block.type === "list") {
            return (
              <ol class="tl-list">
                {block.itemsHtml.map((html) => (
                  <li set:html={html} />
                ))}
              </ol>
            );
          }
          return null;
        })}
      </section>
    ))
  }

  <Fragment slot="aside">
    {hasInputs && (
      <EntitySection label="Inputs">
        {post.inputs.map((input) => (
          <div class="tl-input">
            <span>
              {input.href ? (
                <a class="no-underline opacity-90 transition-opacity hover:opacity-100" href={input.href}>
                  {input.title}
                </a>
              ) : (
                input.title
              )}
            </span>
            <span class="opacity-50">
              {[input.source, input.consumed].filter(Boolean).join(" · ")}
              {input.externalHref && (
                <>
                  {" "}
                  <a class="underline" href={input.externalHref}>
                    source
                  </a>
                </>
              )}
            </span>
          </div>
        ))}
      </EntitySection>
    )}

    {hasFootnotes && (
      <EntitySection label="Sources and asides">
        {post.footnotes.map((note, index) => (
          <div class="tl-footnote">
            <span class="opacity-50">{String(index + 1).padStart(2, "0")}</span>
            <span set:html={note.html} />
          </div>
        ))}
      </EntitySection>
    )}

    <EntitySection label="Cite">
      <p class="m-0">{post.citation}</p>
    </EntitySection>
  </Fragment>
</EntityDetail>

<style>
  .tl-epigraph {
    margin-block: 1.5em;
    font-style: italic;
    opacity: 0.7;
  }

  .tl-epigraph-by {
    margin-left: 0.4rem;
    font-style: normal;
  }

  .tl-deck {
    margin-block: 1.5em;
    font-size: 1.2rem;
    line-height: 1.5;
    opacity: 0.75;
  }

  .tl-section-title {
    margin-block: 1.8em 0.6em;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .tl-pull {
    margin-block: 1.2em;
    padding-left: 1rem;
    border-left: 2px solid currentColor;
    font-style: italic;
  }

  .tl-list {
    margin-block: 1.2em;
    padding-left: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tl-figure {
    margin-block: 1.5em;
  }

  .tl-figure figcaption {
    margin-top: 0.5rem;
    font-size: 0.85rem;
  }

  .tl-input,
  .tl-footnote {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .tl-footnote {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: 0.75rem;
    align-items: baseline;
  }
</style>
