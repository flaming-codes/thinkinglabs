---
import { resolveEntityHero } from "../lib/entity-hero.ts";
import EntityDetail from "../components/EntityDetail.astro";
import type { EntityRelationGroup } from "../components/EntityDetail.astro";
import EntityFacts from "../components/EntityFacts.astro";
import type { ObservationDetail } from "../types";

interface Props {
  observation: ObservationDetail;
}

const { observation } = Astro.props;
const heroImage = resolveEntityHero("observations", observation.slug);

const relations: EntityRelationGroup[] =
  observation.related.length > 0
    ? [
        {
          label: "Related",
          links: observation.related.map((rel) => ({
            href: rel.href ?? "#",
            title: rel.title,
            ...(rel.value !== undefined ? { value: rel.value } : {}),
          })),
        },
      ]
    : [];
---

<EntityDetail
  title={observation.observation}
  dates={[{ label: `observed ${observation.observed}` }]}
  tags={observation.tags}
  heroImage={heroImage}
  relations={relations}
>
  <EntityFacts slot="meta" facts={[{ label: "Source", value: observation.source }]} />

  <div class="tl-lede">
    <p class="tl-eyebrow">Context</p>
    <p class="tl-lede-text">{observation.context}</p>
  </div>

  {observation.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
</EntityDetail>

<style>
  .tl-lede {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-block: 1.5em;
  }

  .tl-eyebrow {
    margin: 0;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  .tl-lede-text {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.4;
  }
</style>
