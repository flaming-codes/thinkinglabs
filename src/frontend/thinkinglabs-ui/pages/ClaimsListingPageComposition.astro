---
import AppShell from "../components/AppShell.astro";
import ConfidenceMeter from "../components/ConfidenceMeter.astro";
import StatusTag from "../components/StatusTag.astro";
import type { ClaimSummary } from "../types";

interface Props {
  claims: ClaimSummary[];
  totalCount?: number;
}

const { claims, totalCount = 47 } = Astro.props;

const toneByStatus = {
  active: "active",
  deprecated: "deprecated",
  superseded: "superseded",
} as const;
---

<AppShell activeNav="Index">
  <section class="tl-page-head">
    <div class="tl-eyebrow">Claims · /claims</div>
    <div class="tl-page-head-grid">
      <h1>Claims.</h1>
      <p>
        Atomic structured assertions. Each carries confidence in [0,1], linked evidence, opposing
        views, and a last-reviewed date.
      </p>
    </div>
  </section>

  <section class="tl-filter-row">
    <div>
      <span class="is-active">All</span>
      <span>Active</span>
      <span>Deprecated</span>
      <span>Superseded</span>
    </div>
    <div>
      <span>Sort: reviewed</span>
      <span>{claims.length} of {totalCount}</span>
    </div>
  </section>

  <section>
    {claims.map((claim, index) => (
      <article class="tl-claims-row">
        <div class="tl-mono">{String(index + 1).padStart(3, "0")}</div>
        <div>
          <h3>{claim.href ? <a href={claim.href}>{claim.title}</a> : claim.title}</h3>
          <div class="tl-claims-meta-row">
            <StatusTag label={claim.status} tone={toneByStatus[claim.status]} />
            <span class="tl-mono">reviewed {claim.reviewed}</span>
            <span class="tl-mono">{claim.evidence} ev · {claim.opposing} opp</span>
          </div>
        </div>
        <ConfidenceMeter value={claim.conf} previous={claim.prev} compact />
        <div class="tl-mono is-right">{claim.href ? <a href={claim.href}>↗</a> : "↗"}</div>
      </article>
    ))}
  </section>
</AppShell>
