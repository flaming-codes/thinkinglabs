---
import EntityIndexPageComposition from "./EntityIndexPageComposition.astro";
import type { ClaimSummary, EntityIndexPage } from "../types";

interface Props {
  claims: ClaimSummary[];
  totalCount?: number;
}

const { claims, totalCount = claims.length } = Astro.props;
const active = claims.filter((claim) => claim.status === "active").length;
const evidence = claims.reduce((sum, claim) => sum + claim.evidence, 0);
const avgConf =
  claims.length > 0
    ? claims.reduce((sum, claim) => sum + claim.conf, 0) / claims.length
    : 0;

const page: EntityIndexPage = {
  slug: "claims",
  eyebrow: "/claims",
  title: "Claims.",
  deck: "Atomic assertions with confidence, evidence, opposing views, and a review date. This is the ledger layer: small enough to audit, explicit enough to update.",
  count: `${claims.length} of ${totalCount} visible`,
  stats: [
    { label: "Active", value: String(active), sub: "currently defended" },
    { label: "Mean conf", value: avgConf > 0 ? avgConf.toFixed(2) : "-", sub: "across visible claims" },
    { label: "Evidence", value: String(evidence), sub: "linked support items" },
  ],
  sections: [
    {
      label: "Reviewed first",
      title: "Claims on file.",
      rows: claims.map((claim, index) => ({
        kicker: String(index + 1).padStart(3, "0"),
        title: claim.title,
        href: claim.href,
        summary: claim.tags.join(" / ") || claim.status,
        meta: [`status ${claim.status}`, `reviewed ${claim.reviewed}`, `${claim.evidence} ev`, `${claim.opposing} opp`],
        value: claim.conf.toFixed(2),
        valueLabel: "confidence",
      })),
    },
  ],
  footer: "A claim is allowed to be boring. It is not allowed to hide what would make it weaker.",
};
---

<EntityIndexPageComposition page={page} />
