---
import heroImage from "@/assets/hero.png";
import EntityDetail from "../components/EntityDetail.astro";
import EntityFacts from "../components/EntityFacts.astro";
import EntitySection from "../components/EntitySection.astro";
import type { ClaimDetail } from "../types";

interface Props {
  claim: ClaimDetail;
}

const { claim } = Astro.props;
const claimStatement = claim.title.trim();
const proseParagraphs = claim.body.filter((paragraph) => paragraph.trim() !== claimStatement);

const facts = [
  { label: "Confidence", value: claim.conf.toFixed(2) },
  { label: "Status", value: claim.status },
];

const hasEvidence = claim.evidence.length > 0;
const hasOpposing = claim.opposing.length > 0;
---

<EntityDetail
  title={claim.title}
  dates={[{ label: `reviewed ${claim.reviewed}` }]}
  tags={claim.tags}
  heroImage={heroImage}
>
  <EntityFacts slot="meta" facts={facts} />

  {proseParagraphs.map((paragraph) => <p>{paragraph}</p>)}

  <Fragment slot="aside">
    <EntitySection label="Confidence over time">
      {claim.history.map((item) => (
        <div class="tl-tuple">
          <span class="tl-tuple-value">{item.conf.toFixed(2)}</span>
          <span class="opacity-50">{item.date}</span>
          <span>{item.note}</span>
        </div>
      ))}
    </EntitySection>

    {hasEvidence && (
      <EntitySection label="Evidence" note={`${claim.evidence.length} linked`}>
        {claim.evidence.map((item) => (
          <div class="tl-rel">
            <span class="opacity-50">{item.kind}</span>
            <span>
              {item.href ? (
                <a class="no-underline opacity-90 transition-opacity hover:opacity-100" href={item.href}>
                  {item.title}
                </a>
              ) : (
                item.title
              )}
            </span>
          </div>
        ))}
      </EntitySection>
    )}

    {hasOpposing && (
      <EntitySection label="Opposing views">
        {claim.opposing.map((item) => (
          <p class="tl-quote">“{item.title}”</p>
        ))}
      </EntitySection>
    )}
  </Fragment>
</EntityDetail>

<style>
  .tl-tuple {
    display: grid;
    grid-template-columns: 3.5rem 8rem minmax(0, 1fr);
    gap: 1rem;
    align-items: baseline;
  }

  .tl-tuple-value {
    font-weight: 600;
  }

  .tl-rel {
    display: grid;
    grid-template-columns: 6rem minmax(0, 1fr);
    gap: 1rem;
    align-items: baseline;
  }

  .tl-quote {
    margin: 0;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .tl-tuple,
    .tl-rel {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
