---
import AppShell from "../components/AppShell.astro";
import EntityConicGradient from "../components/EntityConicGradient.astro";
import StatusTag from "../components/StatusTag.astro";
import type { ClaimDetail } from "../types";

interface Props {
  claim: ClaimDetail;
}

const { claim } = Astro.props;
const claimStatement = claim.title.trim();
const proseParagraphs = claim.body.filter(
  (paragraph) => paragraph.trim() !== claimStatement,
);
---

<AppShell activeNav="Index">
  <article class="tl-claim-detail-simple" data-selected-label={claim.title} data-entity="claims">
    <header class="tl-claim-simple-hero">
      <EntityConicGradient class="tl-claim-gradient" entity="claims" />
      <div class="tl-claim-copy">
        <p class="tl-mono">Claim detail</p>
        <h1>{claimStatement}</h1>
      </div>
    </header>

    <section class="tl-claim-kpis" aria-label="Claim summary">
      <article class="tl-claim-kpi is-primary">
        <span class="tl-claim-kpi-value">{claim.conf.toFixed(2)}</span>
        <span class="tl-claim-kpi-label">Confidence</span>
      </article>
      <article class="tl-claim-kpi">
        <span class="tl-claim-kpi-value"><StatusTag label={claim.status} tone={claim.status} /></span>
        <span class="tl-claim-kpi-label">Status</span>
      </article>
      <article class="tl-claim-kpi">
        <span class="tl-claim-kpi-value">{claim.reviewed}</span>
        <span class="tl-claim-kpi-label">Reviewed</span>
      </article>
      <article class="tl-claim-kpi">
        <span class="tl-claim-kpi-value">{claim.evidence.length}</span>
        <span class="tl-claim-kpi-label">Evidence</span>
      </article>
      <article class="tl-claim-kpi">
        <span class="tl-claim-kpi-value">{claim.opposing.length}</span>
        <span class="tl-claim-kpi-label">Opposing</span>
      </article>
      {claim.tags.length > 0 ? (
        <div class="tl-claim-tag-list" aria-label="Tags">
          {claim.tags.map((tag) => <span>#{tag}</span>)}
        </div>
      ) : null}
    </section>

    {proseParagraphs.length > 0 ? (
      <section class="tl-claim-prose">
        <div class="tl-claim-prose-body">
          {proseParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>
    ) : null}

    <section class="tl-claim-section">
      <header class="tl-claim-section-header">
        <div class="tl-eyebrow">Confidence over time</div>
      </header>
      <div class="tl-history-list">
        {claim.history.map((item) => (
          <article class="tl-claim-tuple-row">
            <span class="tl-claim-tuple-value">{item.conf.toFixed(2)}</span>
            <span class="tl-claim-tuple-label">{item.date}</span>
            <span class="tl-claim-tuple-body">{item.note}</span>
          </article>
        ))}
      </div>
    </section>

    {claim.evidence.length > 0 ? (
      <section class="tl-claim-section">
        <header class="tl-claim-section-header">
          <div class="tl-eyebrow">Evidence</div>
        </header>
        <div>
          {claim.evidence.map((entry) => (
            <article class="tl-claim-tuple-row">
              <span class="tl-claim-tuple-value">{entry.kind}</span>
              <span class="tl-claim-tuple-label">Linked entry</span>
              <h3 class="tl-claim-tuple-body">
                {entry.href ? <a href={entry.href}>{entry.title}</a> : entry.title}
              </h3>
            </article>
          ))}
        </div>
      </section>
    ) : null}

    {claim.opposing.length > 0 ? (
      <section class="tl-claim-section">
        <header class="tl-claim-section-header">
          <div class="tl-eyebrow">Opposing views</div>
        </header>
        <div>
          {claim.opposing.map((entry) => (
            <article class="tl-claim-tuple-row">
              <span class="tl-claim-tuple-value">{entry.kind}</span>
              <span class="tl-claim-tuple-label">Opposing view</span>
              <p class="tl-claim-tuple-body">"{entry.title}"</p>
            </article>
          ))}
        </div>
      </section>
    ) : null}
  </article>
</AppShell>

<style>
  .tl-claim-detail-simple {
    padding: clamp(6rem, 11vh, 8rem) 20px clamp(5rem, 12vh, 8rem);
    background: var(--tl-bg);
    color: var(--tl-ink);
  }

  .tl-claim-simple-hero,
  .tl-claim-kpis,
  .tl-claim-prose,
  .tl-claim-section {
    width: min(100%, 980px);
    margin-inline: auto;
  }

  .tl-claim-simple-hero {
    display: grid;
    gap: clamp(2.25rem, 7vw, 4.75rem);
    min-height: 0;
  }

  :global(.tl-claim-gradient) {
    width: 100%;
    min-height: clamp(11rem, 31vh, 18rem);
    background: #000;
  }

  .tl-claim-copy {
    display: grid;
    gap: 18px;
    max-width: 46rem;
  }

  .tl-claim-copy h1 {
    max-width: 38ch;
    font-size: clamp(21px, 2.2vw, 31px);
    font-weight: 620;
    line-height: 1.16;
    letter-spacing: -0.015em;
  }

  .tl-claim-kpis {
    display: grid;
    grid-template-columns: minmax(10rem, 1.45fr) repeat(4, minmax(7rem, 1fr));
    gap: 18px 28px;
    align-items: end;
    margin-top: clamp(4.5rem, 12vh, 8rem);
  }

  .tl-claim-kpi {
    display: grid;
    gap: 8px;
    align-content: end;
    min-width: 0;
  }

  .tl-claim-kpi.is-primary {
    gap: 10px;
  }

  .tl-claim-kpi-value {
    display: block;
    min-width: 0;
    color: var(--tl-ink);
    font-size: clamp(16px, 1.6vw, 20px);
    font-weight: 620;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .tl-claim-kpi.is-primary .tl-claim-kpi-value {
    font-size: clamp(42px, 5.4vw, 64px);
    font-weight: 650;
    line-height: 0.9;
    letter-spacing: -0.04em;
  }

  .tl-claim-kpi-label,
  .tl-claim-tuple-label {
    color: var(--tl-muted);
    font-size: 11px;
    font-weight: 650;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .tl-claim-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 12px;
    align-items: center;
    grid-column: 1 / -1;
    color: var(--tl-muted);
    font-size: 12px;
  }

  .tl-claim-prose {
    padding-top: clamp(4rem, 11vh, 7rem);
  }

  .tl-claim-prose-body {
    max-width: 38rem;
    color: rgba(7, 9, 13, 0.74);
    font-size: 14px;
    line-height: 1.6;
  }

  .tl-claim-prose-body p + p {
    margin-top: 0.75rem;
  }

  .tl-claim-section {
    padding-top: clamp(4.5rem, 12vh, 7.5rem);
  }

  .tl-claim-section-header {
    display: flex;
    gap: 24px;
    align-items: baseline;
    padding-bottom: 18px;
  }

  .tl-history-list,
  .tl-claim-section > div {
    display: grid;
    gap: 16px;
  }

  .tl-claim-tuple-row {
    display: grid;
    grid-template-columns: minmax(4rem, 5.5rem) minmax(8rem, 10rem) minmax(0, 1fr);
    gap: 18px;
    align-items: start;
    max-width: 44rem;
    color: rgba(7, 9, 13, 0.74);
    font-size: 14px;
    line-height: 1.35;
  }

  .tl-claim-tuple-value {
    color: var(--tl-ink);
    font-size: 18px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .tl-claim-tuple-body {
    min-width: 0;
  }

  .tl-claim-tuple-row h3 {
    font-size: clamp(15px, 1.45vw, 18px);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .tl-claim-tuple-row a {
    color: inherit;
    text-decoration: none;
  }

  .tl-claim-tuple-row a:hover,
  .tl-claim-tuple-row a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .tl-claim-tuple-row p {
    font-style: italic;
  }

  @media (max-width: 767px) {
    .tl-claim-detail-simple {
      padding: 5rem 16px 3rem;
    }

    .tl-claim-kpis {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: clamp(3.5rem, 10vh, 5rem);
    }

    .tl-claim-kpi.is-primary,
    .tl-claim-tag-list {
      grid-column: 1 / -1;
    }

    .tl-claim-section {
      padding-top: clamp(4rem, 10vh, 5.5rem);
    }

    .tl-claim-tuple-row {
      grid-template-columns: minmax(3.5rem, 4.5rem) minmax(0, 1fr);
      gap: 8px 14px;
    }

    .tl-claim-tuple-body {
      grid-column: 2;
    }
  }
</style>
