---
import AppShell from "../components/AppShell.astro";
import ConfidenceMeter from "../components/ConfidenceMeter.astro";
import StatusTag from "../components/StatusTag.astro";
import type { ClaimDetail } from "../types";

interface Props {
  claim: ClaimDetail;
}

const { claim } = Astro.props;
---

<AppShell activeNav="Index">
  <section class="tl-page-head is-detail">
    <div class="tl-eyebrow">Index / Claims / {claim.id.split("/")[1]}</div>
    <div class="tl-claim-detail-head">
      <h1>{claim.title}</h1>
      <aside>
        <div class="tl-eyebrow">Confidence</div>
        <div class="tl-claim-conf-big">{claim.conf.toFixed(2)}</div>
        <ConfidenceMeter value={claim.conf} showDelta={false} />
        <div class="tl-claim-fact-list">
          <div>
            <span>status</span>
            <StatusTag label={claim.status} tone={claim.status} />
          </div>
          <div>
            <span>reviewed</span>
            <strong>{claim.reviewed}</strong>
          </div>
          <div>
            <span>evidence</span>
            <strong>{claim.evidence.length}</strong>
          </div>
          <div>
            <span>opposing</span>
            <strong>{claim.opposing.length}</strong>
          </div>
          <div>
            <span>tags</span>
            <strong>{claim.tags.join(", ")}</strong>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="tl-claim-body-grid">
    <article>
      {claim.body.map((paragraph, index) => (
        <p class="tl-claim-body-copy">
          {index === 0 ? <span class="tl-dropcap">{paragraph.charAt(0)}</span> : null}
          {index === 0 ? paragraph.slice(1) : paragraph}
        </p>
      ))}
    </article>
    <aside>
      <div class="tl-eyebrow">Confidence over time</div>
      {claim.history.map((item) => (
        <div class="tl-history-row">
          <span class="tl-mono">{item.date}</span>
          <span>{item.note}</span>
          <span class="tl-mono is-right">{item.conf.toFixed(2)}</span>
        </div>
      ))}
    </aside>
  </section>

  <section class="tl-evidence-section">
    <header class="tl-split-header is-tight">
      <div class="tl-eyebrow">§ Evidence</div>
      <div class="tl-mono">{claim.evidence.length} linked entries</div>
    </header>
      <div class="tl-evidence-grid">
        {claim.evidence.map((entry) => (
          <article class="tl-evidence-row">
            <span class="tl-mono">{entry.kind}</span>
            <h3>{entry.href ? <a href={entry.href}>{entry.title}</a> : entry.title}</h3>
          </article>
        ))}
      </div>
    </section>
</AppShell>
