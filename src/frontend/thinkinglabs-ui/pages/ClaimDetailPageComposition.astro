---
import AppShell from "../components/AppShell.astro";
import StatusTag from "../components/StatusTag.astro";
import type { ClaimDetail } from "../types";

interface Props {
  claim: ClaimDetail;
}

const { claim } = Astro.props;
const claimStatement = claim.title.trim();
const proseParagraphs = claim.body.filter(
  (paragraph) => paragraph.trim() !== claimStatement,
);
---

<AppShell activeNav="Index">
  <article class="tl-claim-detail" data-selected-label={claim.title} data-entity="claims">
    <header class="tl-claim-hero">
      <div class="tl-claim-art" aria-hidden="true"></div>
      <div class="tl-claim-title">
        <p class="tl-mono">Claim detail</p>
        <h1>{claimStatement}</h1>
        <div class="tl-claim-detail-meta">
          <StatusTag label={claim.status} tone={claim.status} />
          <span class="tl-mono">reviewed {claim.reviewed}</span>
          <span class="tl-mono">{claim.evidence.length} evidence</span>
          <span class="tl-mono">{claim.opposing.length} opposing</span>
        </div>
      </div>
    </header>

    <section class="tl-claim-confidence">
      <div class="tl-claim-confidence-figures">
        <span class="tl-eyebrow">Confidence</span>
        <span class="tl-claim-conf-big">{claim.conf.toFixed(2)}</span>
        <span
          class="tl-claim-conf-bar"
          aria-hidden="true"
          style={`--tl-claim-conf: ${Math.round(claim.conf * 100)}%`}
        ></span>
      </div>
      {claim.tags.length > 0 ? (
        <div class="tl-claim-tags" aria-label="Tags">
          {claim.tags.map((tag) => <span>#{tag}</span>)}
        </div>
      ) : null}
    </section>

    {proseParagraphs.length > 0 ? (
      <section class="tl-prose-shell">
        <div class="tl-prose-body">
          {proseParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>
    ) : null}

    <section class="tl-aside-block">
      <header class="tl-split-header is-tight">
        <div class="tl-eyebrow">Confidence over time</div>
        <div class="tl-mono">
          {claim.history.length} {claim.history.length === 1 ? "update" : "updates"}
        </div>
      </header>
      <div class="tl-history-list">
        {claim.history.map((item) => (
          <article class="tl-history-row is-wide">
            <span class="tl-mono">{item.date}</span>
            <span>{item.note}</span>
            <span class="tl-mono is-right">{item.conf.toFixed(2)}</span>
          </article>
        ))}
      </div>
    </section>

    {claim.evidence.length > 0 ? (
      <section class="tl-aside-block">
        <header class="tl-split-header is-tight">
          <div class="tl-eyebrow">Evidence</div>
          <div class="tl-mono">
            {claim.evidence.length} linked {claim.evidence.length === 1 ? "entry" : "entries"}
          </div>
        </header>
        <div>
          {claim.evidence.map((entry) => (
            <article class="tl-rel-row">
              <span class="tl-mono">{entry.kind}</span>
              <h3>{entry.href ? <a href={entry.href}>{entry.title}</a> : entry.title}</h3>
              <span class="tl-mono is-right"></span>
            </article>
          ))}
        </div>
      </section>
    ) : null}

    {claim.opposing.length > 0 ? (
      <section class="tl-aside-block">
        <header class="tl-split-header is-tight">
          <div class="tl-eyebrow">Opposing views</div>
          <div class="tl-mono">{claim.opposing.length} on file</div>
        </header>
        <div>
          {claim.opposing.map((entry) => (
            <p class="tl-quote-line">"{entry.title}"</p>
          ))}
        </div>
      </section>
    ) : null}
  </article>
</AppShell>

<style>
  .tl-claim-detail {
    padding: clamp(7rem, 13vh, 10rem) 20px clamp(7rem, 16vh, 12rem);
    background: var(--tl-bg);
    color: var(--tl-ink);
  }

  .tl-claim-hero,
  .tl-claim-confidence,
  .tl-prose-shell,
  .tl-aside-block {
    width: min(100%, 980px);
    margin-inline: auto;
  }

  .tl-claim-hero {
    display: grid;
    grid-template-columns: minmax(8rem, 0.28fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: end;
    min-height: clamp(20rem, 52vh, 32rem);
  }

  .tl-claim-art {
    align-self: stretch;
    min-height: 14rem;
    background: var(--tl-entity-detail-gradient);
  }

  .tl-claim-title {
    display: grid;
    gap: 20px;
    padding-bottom: clamp(0.5rem, 3vh, 1.5rem);
  }

  .tl-claim-title h1 {
    max-width: 32ch;
    font-size: clamp(26px, 3.1vw, 42px);
    font-weight: 620;
    line-height: 1.08;
    letter-spacing: -0.025em;
  }

  .tl-claim-detail-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    align-items: center;
  }

  .tl-claim-confidence {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.25rem, 4vw, 2.5rem) clamp(2rem, 6vw, 4rem);
    align-items: end;
    justify-content: space-between;
    margin-top: clamp(1.5rem, 4vh, 2.5rem);
    padding-bottom: clamp(1.25rem, 3vh, 2rem);
  }

  .tl-claim-confidence-figures {
    display: grid;
    grid-template-columns: auto minmax(8rem, 16rem);
    align-items: end;
    gap: 4px 22px;
  }

  .tl-claim-confidence-figures .tl-eyebrow {
    grid-column: 1 / -1;
  }

  .tl-claim-conf-big {
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 650;
    line-height: 0.88;
    letter-spacing: -0.05em;
  }

  .tl-claim-conf-bar {
    position: relative;
    display: block;
    height: 2px;
    margin-bottom: 0.55em;
    background: var(--tl-line);
  }

  .tl-claim-conf-bar::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: var(--tl-claim-conf, 0%);
    background: var(--tl-ink);
  }

  .tl-claim-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    align-items: center;
    align-self: end;
    color: var(--tl-muted);
    font-size: 13px;
  }

  .tl-prose-shell {
    padding: clamp(2.5rem, 7vh, 4.5rem) 0 0;
  }

  .tl-aside-block {
    padding-top: clamp(1.75rem, 5vh, 3rem);
  }

  .tl-history-list,
  .tl-aside-block > div {
    display: grid;
  }

  .tl-rel-row,
  .tl-history-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(7rem, 9rem) minmax(0, 1fr) auto;
    gap: 22px;
    align-items: baseline;
    padding: 24px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-rel-row h3 {
    font-size: clamp(22px, 2.6vw, 32px);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.025em;
  }

  .tl-rel-row a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .tl-rel-row a:hover,
  .tl-rel-row a:focus-visible {
    border-bottom-color: currentColor;
  }

  .tl-quote-line {
    max-width: 56ch;
    padding: 18px 0;
    color: rgba(7, 9, 13, 0.78);
    font-size: clamp(17px, 1.8vw, 21px);
    font-style: italic;
    line-height: 1.5;
    border-bottom: 1px solid var(--tl-line);
  }

  @media (max-width: 860px) {
    .tl-claim-hero {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .tl-claim-art {
      min-height: 12rem;
    }
  }

  @media (max-width: 767px) {
    .tl-claim-detail {
      padding: 5rem 16px 3rem;
    }

    .tl-rel-row,
    .tl-history-row {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 18px 0;
    }
  }
</style>
