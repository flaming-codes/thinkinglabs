---
import AppShell from "../components/AppShell.astro";
import ConfidenceMeter from "../components/ConfidenceMeter.astro";
import StatusTag from "../components/StatusTag.astro";
import type { ClaimDetail } from "../types";

interface Props {
  claim: ClaimDetail;
}

const { claim } = Astro.props;
---

<AppShell activeNav="Index">
  <article class="tl-claim-detail-page" data-selected-label={claim.title} data-entity="claims">
  <section class="tl-page-head is-detail">
    <div class="tl-claim-visual" aria-hidden="true"></div>
    <div class="tl-mono">Claim detail</div>
    <div class="tl-claim-detail-head">
      <h1>{claim.title}</h1>
      <aside>
        <div class="tl-eyebrow">Confidence</div>
        <div class="tl-claim-conf-big">{claim.conf.toFixed(2)}</div>
        <ConfidenceMeter value={claim.conf} showDelta={false} />
        <div class="tl-claim-fact-list">
          <div>
            <span>status</span>
            <StatusTag label={claim.status} tone={claim.status} />
          </div>
          <div>
            <span>reviewed</span>
            <strong>{claim.reviewed}</strong>
          </div>
          <div>
            <span>evidence</span>
            <strong>{claim.evidence.length}</strong>
          </div>
          <div>
            <span>opposing</span>
            <strong>{claim.opposing.length}</strong>
          </div>
          <div>
            <span>tags</span>
            <strong>{claim.tags.join(", ")}</strong>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="tl-claim-body-grid">
    <article>
      {claim.body.map((paragraph, index) => (
        <p class="tl-claim-body-copy">
          {index === 0 ? <span class="tl-dropcap">{paragraph.charAt(0)}</span> : null}
          {index === 0 ? paragraph.slice(1) : paragraph}
        </p>
      ))}
    </article>
    <aside>
      <div class="tl-eyebrow">Confidence over time</div>
      {claim.history.map((item) => (
        <div class="tl-history-row">
          <span class="tl-mono">{item.date}</span>
          <span>{item.note}</span>
          <span class="tl-mono is-right">{item.conf.toFixed(2)}</span>
        </div>
      ))}
    </aside>
  </section>

  <section class="tl-evidence-section">
    <header class="tl-split-header is-tight">
      <div class="tl-eyebrow">Evidence</div>
      <div class="tl-mono">{claim.evidence.length} linked entries</div>
    </header>
      <div class="tl-evidence-grid">
        {claim.evidence.map((entry) => (
          <article class="tl-evidence-row">
            <span class="tl-mono">{entry.kind}</span>
            <h3>{entry.href ? <a href={entry.href}>{entry.title}</a> : entry.title}</h3>
          </article>
        ))}
      </div>
    </section>
  </article>
</AppShell>

<style>
  .tl-claim-detail-page {
    padding-bottom: clamp(6rem, 14vh, 11rem);
  }

  .tl-claim-visual {
    width: min(100%, 18rem);
    height: clamp(3.5rem, 8vh, 5.5rem);
    margin-bottom: clamp(1.5rem, 4vh, 2.5rem);
    background: var(--tl-entity-detail-gradient);
  }

  .tl-claim-body-grid,
  .tl-evidence-section {
    width: var(--tl-center);
    margin-inline: auto;
  }

  .tl-claim-detail-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(10rem, 16rem);
    gap: 56px;
    align-items: end;
  }

  .tl-evidence-grid {
    display: grid;
  }

  .tl-evidence-row,
  .tl-history-row {
    position: relative;
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto;
    gap: 22px;
    align-items: baseline;
    padding: 30px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-evidence-row h3 {
    font-size: clamp(25px, 3vw, 38px);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  .tl-claim-conf-big {
    font-size: clamp(32px, 5vw, 70px);
    font-weight: 650;
    line-height: 0.9;
    letter-spacing: -0.05em;
  }

  .tl-evidence-section {
    padding-bottom: 0;
  }

  @media (max-width: 767px) {
    .tl-claim-body-grid,
    .tl-evidence-section {
      width: min(100% - 40px, 43.75rem);
    }

    .tl-claim-detail-head,
    .tl-evidence-row,
    .tl-history-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

</style>
