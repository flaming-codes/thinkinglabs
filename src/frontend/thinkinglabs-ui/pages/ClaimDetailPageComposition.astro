---
import AppShell from "../components/AppShell.astro";
import EntityShaderSurface from "../components/EntityShaderSurface.astro";
import StatusTag from "../components/StatusTag.astro";
import type { ClaimDetail } from "../types";

interface Props {
  claim: ClaimDetail;
}

const { claim } = Astro.props;
const claimStatement = claim.title.trim();
const proseParagraphs = claim.body.filter(
  (paragraph) => paragraph.trim() !== claimStatement,
);
---

<AppShell activeNav="Index">
  <article class="tl-claim-detail-simple" data-selected-label={claim.title} data-entity="claims">
    <header class="tl-claim-simple-hero">
      <EntityShaderSurface class="tl-claim-gradient" entity="claims" region="detail" />
      <div class="tl-claim-copy">
        <p class="tl-mono">Claim detail</p>
        <h1>{claimStatement}</h1>
        <div class="tl-claim-meta">
          <StatusTag label={claim.status} tone={claim.status} />
          <span class="tl-mono">reviewed {claim.reviewed}</span>
          <span class="tl-mono">{claim.evidence.length} evidence</span>
          <span class="tl-mono">{claim.opposing.length} opposing</span>
        </div>
      </div>
    </header>

    <section class="tl-claim-score">
      <div class="tl-claim-score-main">
        <span class="tl-eyebrow">Confidence</span>
        <span class="tl-claim-score-value">{claim.conf.toFixed(2)}</span>
      </div>
      {claim.tags.length > 0 ? (
        <div class="tl-claim-tag-list" aria-label="Tags">
          {claim.tags.map((tag) => <span>#{tag}</span>)}
        </div>
      ) : null}
    </section>

    {proseParagraphs.length > 0 ? (
      <section class="tl-claim-prose">
        <div class="tl-claim-prose-body">
          {proseParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>
    ) : null}

    <section class="tl-claim-section">
      <header class="tl-claim-section-header">
        <div class="tl-eyebrow">Confidence over time</div>
        <div class="tl-mono">
          {claim.history.length} {claim.history.length === 1 ? "update" : "updates"}
        </div>
      </header>
      <div class="tl-history-list">
        {claim.history.map((item) => (
          <article class="tl-claim-history-row">
            <span class="tl-mono">{item.date}</span>
            <span>{item.note}</span>
            <span class="tl-mono is-right">{item.conf.toFixed(2)}</span>
          </article>
        ))}
      </div>
    </section>

    {claim.evidence.length > 0 ? (
      <section class="tl-claim-section">
        <header class="tl-claim-section-header">
          <div class="tl-eyebrow">Evidence</div>
          <div class="tl-mono">
            {claim.evidence.length} linked {claim.evidence.length === 1 ? "entry" : "entries"}
          </div>
        </header>
        <div>
          {claim.evidence.map((entry) => (
            <article class="tl-claim-rel-row">
              <span class="tl-mono">{entry.kind}</span>
              <h3>{entry.href ? <a href={entry.href}>{entry.title}</a> : entry.title}</h3>
              <span class="tl-mono is-right"></span>
            </article>
          ))}
        </div>
      </section>
    ) : null}

    {claim.opposing.length > 0 ? (
      <section class="tl-claim-section">
        <header class="tl-claim-section-header">
          <div class="tl-eyebrow">Opposing views</div>
          <div class="tl-mono">{claim.opposing.length} on file</div>
        </header>
        <div>
          {claim.opposing.map((entry) => (
            <p class="tl-claim-quote-line">"{entry.title}"</p>
          ))}
        </div>
      </section>
    ) : null}
  </article>
</AppShell>

<style>
  .tl-claim-detail-simple {
    padding: clamp(6rem, 11vh, 8rem) 20px clamp(5rem, 12vh, 8rem);
    background: var(--tl-bg);
    color: var(--tl-ink);
  }

  .tl-claim-simple-hero,
  .tl-claim-score,
  .tl-claim-prose,
  .tl-claim-section {
    width: min(100%, 980px);
    margin-inline: auto;
  }

  .tl-claim-simple-hero {
    display: grid;
    gap: clamp(1.25rem, 4vw, 2.75rem);
    min-height: 0;
  }

  :global(.tl-claim-gradient) {
    width: 100%;
    min-height: clamp(11rem, 31vh, 18rem);
    background: #000;
  }

  .tl-claim-copy {
    display: grid;
    gap: 14px;
    max-width: 46rem;
  }

  .tl-claim-copy h1 {
    max-width: 38ch;
    font-size: clamp(21px, 2.2vw, 31px);
    font-weight: 620;
    line-height: 1.16;
    letter-spacing: -0.015em;
  }

  .tl-claim-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    align-items: center;
  }

  .tl-claim-score {
    display: flex;
    flex-wrap: wrap;
    gap: 14px 24px;
    align-items: baseline;
    justify-content: space-between;
    margin-top: clamp(1.5rem, 4vh, 2.25rem);
  }

  .tl-claim-score-main {
    display: flex;
    gap: 14px;
    align-items: baseline;
  }

  .tl-claim-score-value {
    order: -1;
    font-size: clamp(42px, 5.4vw, 64px);
    font-weight: 650;
    line-height: 0.9;
    letter-spacing: -0.04em;
  }

  .tl-claim-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 12px;
    align-items: center;
    align-self: end;
    color: var(--tl-muted);
    font-size: 12px;
  }

  .tl-claim-prose {
    padding: clamp(2rem, 6vh, 3.5rem) 0 0;
  }

  .tl-claim-prose-body {
    max-width: 42rem;
    color: rgba(7, 9, 13, 0.74);
    font-size: 15px;
    line-height: 1.68;
  }

  .tl-claim-prose-body p + p {
    margin-top: 0.9rem;
  }

  .tl-claim-section {
    padding-top: clamp(2rem, 6vh, 3.75rem);
  }

  .tl-claim-section-header {
    display: flex;
    gap: 24px;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 12px;
  }

  .tl-history-list,
  .tl-claim-section > div {
    display: grid;
    gap: 14px;
  }

  .tl-claim-rel-row,
  .tl-claim-history-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(6rem, 8rem) minmax(0, 1fr) auto;
    gap: 18px;
    align-items: baseline;
    padding: 0;
    color: rgba(7, 9, 13, 0.74);
    font-size: 14px;
    line-height: 1.45;
  }

  .tl-claim-rel-row h3 {
    font-size: clamp(16px, 1.55vw, 20px);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .tl-claim-rel-row a {
    color: inherit;
    text-decoration: none;
  }

  .tl-claim-rel-row a:hover,
  .tl-claim-rel-row a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .tl-claim-quote-line {
    max-width: 44rem;
    padding: 0;
    color: rgba(7, 9, 13, 0.78);
    font-size: 15px;
    font-style: italic;
    line-height: 1.55;
  }

  @media (max-width: 767px) {
    .tl-claim-detail-simple {
      padding: 5rem 16px 3rem;
    }

    .tl-claim-rel-row,
    .tl-claim-history-row {
      grid-template-columns: 1fr;
      gap: 6px;
    }

    .tl-claim-score,
    .tl-claim-score-main {
      display: grid;
      justify-content: start;
    }
  }
</style>
