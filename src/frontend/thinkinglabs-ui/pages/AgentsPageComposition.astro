---
import { existsSync } from "node:fs";
import { resolve } from "node:path";
import AppShell from "../components/AppShell.astro";
import { GITHUB_URL } from "../../../lib/site.ts";

interface Resource {
  uri: string;
  description: string;
}

interface Tool {
  name: string;
  title: string;
  description: string;
}

const staticResources: Resource[] = [
  { uri: "thinkinglabs://thoughts", description: "Rough-draft prose; the unstructured side of the corpus." },
  { uri: "thinkinglabs://claims", description: "Atomic structured assertions with confidence in [0,1]." },
  { uri: "thinkinglabs://claims/recent", description: "The most recent claim revisions." },
  { uri: "thinkinglabs://projects", description: "Active and archived projects with state and links." },
  { uri: "thinkinglabs://projects/active", description: "Just the live ones." },
  { uri: "thinkinglabs://decisions", description: "Decisions made and the reversals that followed." },
  { uri: "thinkinglabs://decisions/recent", description: "Latest decisions and reversals." },
  { uri: "thinkinglabs://predictions", description: "Dated predictions, all states." },
  { uri: "thinkinglabs://predictions/pending", description: "Predictions still waiting on reality." },
  { uri: "thinkinglabs://predictions/resolved", description: "Predictions graded against the world." },
  { uri: "thinkinglabs://predictions/calibration", description: "Stated confidence vs realized accuracy." },
  { uri: "thinkinglabs://inputs", description: "Things I've read, watched, or listened to." },
  { uri: "thinkinglabs://inputs/recent", description: "The latest inputs." },
  { uri: "thinkinglabs://questions", description: "Open questions I'm tracking." },
  { uri: "thinkinglabs://current_focus", description: "What I'm actively working on right now." },
];

const templateResources: Resource[] = [
  { uri: "thinkinglabs://claims/by-tag/{tag}", description: "All claims under a single tag." },
  { uri: "thinkinglabs://{kind}/{slug}", description: "A single object by slug — claims, thoughts, projects, decisions, predictions, inputs, questions, posts, changed-my-mind." },
];

const metaResources: Resource[] = [
  { uri: "thinkinglabs://schema/version", description: "MCP schema version for consumers that pin contracts." },
  { uri: "thinkinglabs://ai/current-models", description: "The env-resolved model refs by capability tier." },
];

const tools: Tool[] = [
  { name: "query_view", title: "Query public view", description: "Filter one public view by free text, tags, and limit." },
  { name: "contact.precheck", title: "Precheck contact intent", description: "Check a proposed inquiry against the public contact policy before sending." },
  { name: "contact.send", title: "Prepare contact handoff", description: "Validate a message and return the public email handoff. The server does not send mail." },
  { name: "subscribe_brain_diff", title: "Subscribe to brain diff", description: "Return public feed URLs and optionally recent deterministic entries from git history." },
  { name: "question.submit", title: "Submit answer to open question", description: "Write a structured reader answer into the submissions queue for later triage." },
];

const apis: { url: string; description: string }[] = [
  { url: "/api/claims.json", description: "All claims with confidence, status, evidence." },
  { url: "/api/thoughts.json", description: "All draft thoughts with their derived claims." },
  { url: "/api/inputs.json", description: "Read/watch/listen log with citations." },
  { url: "/api/projects.json", description: "Project metadata and current state." },
  { url: "/api/predictions.json", description: "Predictions with stated confidence and resolution." },
  { url: "/api/decisions.json", description: "Decisions made and their reversals." },
  { url: "/api/questions.json", description: "Open questions with submission count." },
  { url: "/api/posts.json", description: "Long-form essays with metadata." },
  { url: "/api/changed-my-mind.json", description: "Public reversals with before/after." },
];

const publicFileExists = (path: string) => existsSync(resolve(process.cwd(), "public", path));
const optionalFeeds: { url: string; file: string; description: string }[] = [
  {
    url: "/feed/brain-diff.xml",
    file: "feed/brain-diff.xml",
    description: "Substantive changes across all kinds (Atom).",
  },
  {
    url: "/feed/brain-diff.json",
    file: "feed/brain-diff.json",
    description: "Same brain-diff, JSON Feed 1.1.",
  },
];
const feeds: { url: string; description: string }[] = [
  ...optionalFeeds.filter((feed) => publicFileExists(feed.file)),
  { url: "/feed/predictions-resolved.json", description: "Predictions transitioning out of pending." },
  { url: "/feed/claims-revised.json", description: "Claims with non-active status or supersedes links." },
  { url: "/feed/decisions-reversed.json", description: "Decisions marked reversed, superseded, or with a `reverses` link." },
];
---

<AppShell activeNav="Agents">
  <section class="tl-page-head is-spacious">
    <div class="tl-eyebrow">/agents</div>
    <h1>For agents.</h1>
    <p class="tl-page-sub">
        A markdown corpus exposed as machine-readable surfaces — an index, a remote MCP endpoint,
        JSON APIs, and feeds — so language models, scrapers, and your own scripts can read this site
        without parsing HTML or cloning the repo.
    </p>
  </section>

  <section class="tl-agents-thesis">
    <div class="tl-eyebrow">Why bother</div>
    <p>
      The site is a by-product of a markdown repo, not the other way round. If an agent wants the
      same view a human gets, it should not have to scrape a layout. Every page below has a
      structured analogue, regenerated on every build, addressable by URI, and stable enough to
      pin against.
    </p>
  </section>

  <section>
    <header class="tl-about-section-head is-compact">
      <div class="tl-eyebrow">01 / llms.txt</div>
      <h2>
        An index of every
        <br />
        public surface.
      </h2>
    </header>
    <div class="tl-agents-prose">
      <p>
        <a class="tl-agents-link" href="/llms.txt">/llms.txt</a> is a single text file that lists
        every page, listing, detail pattern, JSON API, data file, and feed on the site, grouped
        by section. It is regenerated at build time from the same surface inventory the top
        navigation uses, so it never drifts.
      </p>
      <p class="is-muted">
        Hand it to a model as a starting point and it will know what is here without crawling.
      </p>
    </div>
  </section>

  <section>
    <header class="tl-about-section-head is-compact">
      <div class="tl-eyebrow">02 / MCP server</div>
      <h2>
        One server,
        <br />
        two transports.
      </h2>
    </header>
    <div class="tl-agents-prose">
      <p>
        Built on
        <a class="tl-agents-link" href="https://modelcontextprotocol.io">Model Context Protocol</a>
        and <code>@modelcontextprotocol/sdk</code>. The same factory backs a stdio entrypoint
        (<code>servers/thinkinglabs-mcp/</code>) and a remote
        <strong>Streamable HTTP</strong> entrypoint (<code>servers/thinkinglabs-mcp-http/</code>),
        so the resources, tools, and store-fallback semantics are identical regardless of how you
        connect. Schema version <code>0.1.0</code>; public-only; auth disabled.
      </p>
    </div>

    <div class="tl-agents-list">
      <article class="tl-agents-row">
        <code class="tl-agents-uri">https://mcp.thinkinglabs.run/mcp</code>
        <p>
          Remote endpoint. Streamable HTTP transport in stateless mode — every POST is one JSON
          request, one JSON response. No clone required.
        </p>
      </article>
      <article class="tl-agents-row">
        <code class="tl-agents-uri">pnpm mcp:thinkinglabs -- --repo-root &lt;path&gt;</code>
        <p>Local stdio entrypoint. Reads from your checkout; useful when iterating on the corpus.</p>
      </article>
    </div>

    <div class="tl-agents-subhead">
      <div class="tl-eyebrow">Static views</div>
      <div class="tl-mono is-right">{staticResources.length} resources</div>
    </div>
    <div class="tl-agents-list">
      {staticResources.map((res) => (
        <article class="tl-agents-row">
          <code class="tl-agents-uri">{res.uri}</code>
          <p>{res.description}</p>
        </article>
      ))}
    </div>

    <div class="tl-agents-subhead">
      <div class="tl-eyebrow">Templates</div>
      <div class="tl-mono is-right">parameterised</div>
    </div>
    <div class="tl-agents-list">
      {templateResources.map((res) => (
        <article class="tl-agents-row">
          <code class="tl-agents-uri">{res.uri}</code>
          <p>{res.description}</p>
        </article>
      ))}
    </div>

    <div class="tl-agents-subhead">
      <div class="tl-eyebrow">Meta</div>
      <div class="tl-mono is-right">contracts &amp; models</div>
    </div>
    <div class="tl-agents-list">
      {metaResources.map((res) => (
        <article class="tl-agents-row">
          <code class="tl-agents-uri">{res.uri}</code>
          <p>{res.description}</p>
        </article>
      ))}
    </div>

    <div class="tl-agents-subhead">
      <div class="tl-eyebrow">Tools</div>
      <div class="tl-mono is-right">{tools.length} callable</div>
    </div>
    <div class="tl-agents-list">
      {tools.map((tool) => (
        <article class="tl-agents-row">
          <code class="tl-agents-uri">{tool.name}</code>
          <div>
            <h3 class="tl-agents-tool-title">{tool.title}</h3>
            <p>{tool.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <header class="tl-about-section-head is-compact">
      <div class="tl-eyebrow">03 / JSON APIs</div>
      <h2>
        One endpoint per kind,
        <br />
        no auth.
      </h2>
    </header>
    <div class="tl-agents-prose">
      <p>
        Every listed kind also has a flat JSON dump at
        <code>/api/&lt;kind&gt;.json</code>. Useful when you want the full set in one round-trip
        instead of paging an MCP view.
      </p>
    </div>
    <div class="tl-agents-list">
      {apis.map((api) => (
        <article class="tl-agents-row">
          <code class="tl-agents-uri"><a href={api.url}>{api.url}</a></code>
          <p>{api.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <header class="tl-about-section-head is-compact">
      <div class="tl-eyebrow">04 / feeds</div>
      <h2>
        Subscribe to the
        <br />
        deltas.
      </h2>
    </header>
    <div class="tl-agents-prose">
      <p>
        The deterministic feeds are regenerated on every build. Brain-diff feeds are added to the
        public surface list when the local artifact pipeline has generated them.
      </p>
    </div>
    <div class="tl-agents-list">
      {feeds.map((feed) => (
        <article class="tl-agents-row">
          <code class="tl-agents-uri"><a href={feed.url}>{feed.url}</a></code>
          <p>{feed.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <header class="tl-about-section-head is-compact">
      <div class="tl-eyebrow">05 / connect</div>
      <h2>
        Wire it up
        <br />
        without cloning.
      </h2>
    </header>
    <div class="tl-agents-prose">
      <p>
        For most agents, the remote URL is enough. Hand it to any MCP-aware client and the
        handshake takes care of everything. The local stdio entrypoint is here for cases where you
        want to point the server at a different checkout.
      </p>
    </div>
    <div class="tl-agents-code-block">
      <div class="tl-eyebrow">Remote — Claude Desktop / Claude Code</div>
      <pre><code>{`{
  "mcpServers": {
    "thinkinglabs": {
      "url": "https://mcp.thinkinglabs.run/mcp"
    }
  }
}`}</code></pre>
    </div>
    <div class="tl-agents-code-block">
      <div class="tl-eyebrow">Remote — programmatic (TypeScript SDK)</div>
      <pre><code>{`import { Client } from "@modelcontextprotocol/sdk/client/index.js";
import { StreamableHTTPClientTransport } from "@modelcontextprotocol/sdk/client/streamableHttp.js";

const client = new Client({ name: "demo", version: "0.0.1" });
await client.connect(
  new StreamableHTTPClientTransport(new URL("https://mcp.thinkinglabs.run/mcp"))
);`}</code></pre>
    </div>
    <div class="tl-agents-code-block">
      <div class="tl-eyebrow">Local — stdio against your own checkout</div>
      <pre><code>{`git clone ${GITHUB_URL}.git
cd thinkinglabs
pnpm install
pnpm mcp:thinkinglabs -- --repo-root .`}</code></pre>
    </div>
    <div class="tl-agents-prose">
      <p class="is-muted">
        For agents that just need a starting URL, point them at
        <a class="tl-agents-link" href="/llms.txt">/llms.txt</a> and let them fan out from there.
      </p>
    </div>
  </section>
</AppShell>

<style>
  .tl-agents-thesis,
  .tl-agents-list {
    width: var(--tl-center);
    margin-inline: auto;
  }

  .tl-agents-thesis p {
    color: var(--tl-muted);
    font-size: 15px;
    line-height: 1.65;
  }

  .tl-agents-prose {
    color: rgba(7, 9, 13, 0.76);
    font-size: 17px;
    line-height: 1.78;
  }

  .tl-about-section-head,
  .tl-agents-subhead {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    padding: 0 0 18px;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-about-section-head.is-compact {
    padding-top: 64px;
  }

  .tl-agents-list {
    display: grid;
  }

  .tl-agents-row {
    position: relative;
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto;
    gap: 22px;
    align-items: baseline;
    padding: 30px 0;
    border-bottom: 1px solid var(--tl-line);
  }

  .tl-agents-tool-title,
  .tl-about-section-head h2 {
    font-size: clamp(25px, 3vw, 38px);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  .tl-agents-code-block {
    background: var(--tl-panel);
    box-shadow: var(--tl-shadow);
    padding: clamp(1.1rem, 3vw, 2rem);
  }

  .tl-agents-uri {
    font-family: var(--tl-font);
    font-size: 0.88em;
  }

  @media (max-width: 767px) {
    .tl-agents-thesis,
    .tl-agents-list {
      width: min(100% - 40px, 43.75rem);
    }

    .tl-agents-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
