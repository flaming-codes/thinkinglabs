---
import EntityIndexPageComposition from "./EntityIndexPageComposition.astro";
import type { EntityIndexPage, PredictionsView } from "../types";

interface Props {
  view: PredictionsView;
}

const { view } = Astro.props;

const page: EntityIndexPage = {
  slug: "predictions",
  eyebrow: "/predictions",
  title: "Predictions.",
  deck: "Forecasts with a date, a number, and a resolution rule. The point is not to sound certain; it is to become measurable.",
  count: `${view.open.length} open / ${view.resolved.length} resolved`,
  stats: view.stats,
  sections: [
    {
      label: "Open",
      title: "Currently held.",
      rows: view.open.map((prediction) => ({
        kicker: `${prediction.days}d`,
        title: prediction.title,
        href: prediction.href,
        summary: prediction.topic,
        meta: [`resolves ${prediction.due}`, "open"],
        value: prediction.conf.toFixed(2),
        valueLabel: "confidence",
      })),
    },
    {
      label: "Resolved",
      title: "Already settled.",
      rows: view.resolved.map((prediction) => ({
        kicker: prediction.outcome ?? "done",
        title: prediction.title,
        href: prediction.href,
        summary: prediction.topic,
        meta: [`resolved ${prediction.resolvedDate ?? prediction.due}`, `was ${prediction.conf.toFixed(2)}`],
        value: prediction.outcome ?? "-",
        valueLabel: "outcome",
      })),
    },
    {
      label: "Embedded tool",
      title: "Private calibration sandbox.",
      body: [
        "The calibration logger is a frontend-only widget. Its JSON payload is prerendered at build time; it is not a live API, not connected to Ollama or OpenAI, and it does not write to the repository or proposal queue.",
        "A visitor can enter a confidence value and true/false outcome, click Record, and see their local entry count. Entries stay in that browser's localStorage under me.embed.prediction-calibration-logger.v1.",
        "Those entries do not sync across devices, change public calibration metrics, submit data to the site, create predictions, or trigger an LLM.",
      ],
    },
  ],
  footer: "A prediction resolves only against the rule written before the outcome was known.",
};
---

<EntityIndexPageComposition page={page} />
