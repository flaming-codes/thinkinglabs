---
interface Props {
  activeNav?: "Index" | "Now" | "Calibration" | "Brain-diff" | "About";
}

const { activeNav = "Index" } = Astro.props;
const navItems: Array<Props["activeNav"]> = ["Index", "Now", "Calibration", "Brain-diff", "About"];
---

<header class="tl-header">
  <div class="tl-brand">
    <span class="tl-brand-mark"><span class="tl-brand-mark-inner"></span></span>
    <span class="tl-brand-text">thinkinglabs</span>
  </div>
  <nav class="tl-nav" aria-label="Primary navigation">
    {navItems.map((item) => (
      <a href="#" class:list={["tl-nav-item", item !== activeNav && "is-muted"]}>
        {item}
      </a>
    ))}
  </nav>
  <a href="#" class="tl-cta">Get in touch ↗</a>
</header>
