---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import "../frontend/thinkinglabs-ui/styles.css";
import "../styles/view-transitions.css";
import JsonLd from "../components/JsonLd.astro";
import PwaHead from "../components/PwaHead.astro";
import { absoluteFeedLinks, logoUrl, metadataTitle, ogImageUrl } from "../lib/seo.ts";
import { buildPageGraph, canonicalUrl, type StructuredData } from "../lib/structured-data.ts";
import { SITE_NAME } from "../lib/site.ts";

interface Props {
  title: string;
  description?: string | undefined;
  structuredData?: StructuredData | undefined;
  ogType?: "website" | "article" | "profile";
  robots?: string | undefined;
  allowScroll?: boolean | undefined;
}

const { title, description, structuredData, ogType = "website", robots, allowScroll = false } = Astro.props;
const site = Astro.site ?? new URL(Astro.url.origin);
const canonical = canonicalUrl(Astro.url.pathname, site);
const image = ogImageUrl(Astro.url.pathname, site);
const logo = logoUrl(site);
const titleMeta = metadataTitle(title);
const imageAlt = `${titleMeta} social card`;
const feeds = absoluteFeedLinks(site);
const jsonLd = buildPageGraph({ site, url: canonical, title: titleMeta, description, structuredData });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <PwaHead />
    <title>{titleMeta}</title>
    {description ? <meta name="description" content={description} /> : null}
    {robots ? <meta name="robots" content={robots} /> : null}
    <link rel="canonical" href={canonical} />
    {feeds.map((feed) => <link rel="alternate" type={feed.type} title={feed.title} href={feed.href} />)}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={titleMeta} />
    {description ? <meta property="og:description" content={description} /> : null}
    <meta property="og:url" content={canonical} />
    <meta property="og:logo" content={logo} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titleMeta} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <Font cssVariable="--font-golos-text" preload />
    <JsonLd data={jsonLd} />
    <ClientRouter />
  </head>
  <body data-tl-allow-scroll={allowScroll ? "true" : undefined}>
    <a href="#main-content" class="tl-skip-link">Skip to main content</a>
    <slot />
  </body>
</html>

<style>
  /* Visually hidden until focused. The first focusable element on every page so
     keyboard users can jump past the navigation straight to the main landmark.
     Sits above every layer token (header is 60, the nav overlay is 50). */
  .tl-skip-link {
    position: fixed;
    z-index: 100;
    top: 0;
    left: 0;
    padding: 0.75rem 1rem;
    background: var(--tl-bg);
    color: var(--tl-ink);
    font-family: var(--tl-font);
    font-size: var(--tl-type-metadata-size);
    text-decoration: none;
    border: 1px solid var(--tl-line);
    border-radius: 0 0 var(--tl-radius-md) 0;
    transform: translateY(-150%);
    transition: transform var(--tl-motion-fast) var(--tl-ease-standard);
  }

  .tl-skip-link:focus-visible,
  .tl-skip-link:focus {
    transform: translateY(0);
    outline: 2px solid var(--tl-focus);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .tl-skip-link {
      transition: none;
    }
  }
</style>
