---
import "../frontend/thinkinglabs-ui/styles.css";
import JsonLd from "../components/JsonLd.astro";
import PwaHead from "../components/PwaHead.astro";
import { absoluteFeedLinks, ogImageUrl } from "../lib/seo.ts";
import { buildPageGraph, canonicalUrl, type StructuredData } from "../lib/structured-data.ts";
import { SITE_NAME } from "../lib/site.ts";

interface Props {
  title: string;
  description?: string | undefined;
  structuredData?: StructuredData | undefined;
  ogType?: "website" | "article" | "profile";
  robots?: string | undefined;
}

const { title, description, structuredData, ogType = "website", robots } = Astro.props;
const site = Astro.site ?? new URL(Astro.url.origin);
const canonical = canonicalUrl(Astro.url.pathname, site);
const image = ogImageUrl(Astro.url.pathname, site);
const imageAlt = `${title} social card`;
const feeds = absoluteFeedLinks(site);
const jsonLd = buildPageGraph({ site, url: canonical, title, description, structuredData });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <PwaHead />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    {robots ? <meta name="robots" content={robots} /> : null}
    <link rel="canonical" href={canonical} />
    {feeds.map((feed) => <link rel="alternate" type={feed.type} title={feed.title} href={feed.href} />)}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    {description ? <meta property="og:description" content={description} /> : null}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Linefont:wght@4..1000&display=block"
    />
    <JsonLd data={jsonLd} />
  </head>
  <body>
    <slot />
  </body>
</html>
