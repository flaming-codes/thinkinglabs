---
import { NAV_SURFACES } from "../lib/surfaces.ts";
import JsonLd from "../components/JsonLd.astro";
import { buildPageGraph, canonicalUrl, type StructuredData } from "../lib/structured-data.ts";

interface Props {
  title: string;
  description?: string | undefined;
  structuredData?: StructuredData | undefined;
  ogType?: "website" | "article" | "profile";
}

const { title, description, structuredData, ogType = "website" } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const site = Astro.site ?? new URL(Astro.url.origin);
const canonical = canonicalUrl(Astro.url.pathname, site);
const jsonLd = buildPageGraph({ site, url: canonical, title, description, structuredData });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Tom — wild.as" />
    <meta property="og:title" content={title} />
    {description ? <meta property="og:description" content={description} /> : null}
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    <JsonLd data={jsonLd} />
    <style is:global>
      :root {
        --fg: #1b1b1b;
        --muted: #666;
        --bg: #fdfcf8;
        --line: #e6e3da;
        --accent: #2b5cff;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        font-size: 16px;
        line-height: 1.55;
      }
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 4rem;
      }
      header.site {
        border-bottom: 1px solid var(--line);
      }
      header.site .inner {
        max-width: 720px;
        margin: 0 auto;
        padding: 1rem 1.25rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 1rem;
        align-items: baseline;
      }
      header.site a { color: var(--fg); text-decoration: none; }
      header.site a.brand { font-weight: 600; margin-right: auto; }
      header.site a.nav { color: var(--muted); font-size: 0.92rem; }
      header.site a.nav[aria-current="page"] { color: var(--fg); }
      h1 { font-size: 1.6rem; margin: 0 0 1rem; }
      h2 { font-size: 1.15rem; margin: 2rem 0 0.5rem; }
      a { color: var(--accent); }
      ul.list { list-style: none; padding: 0; margin: 0; }
      ul.list > li { padding: 0.6rem 0; border-bottom: 1px solid var(--line); }
      ul.list > li:last-child { border-bottom: none; }
      .meta { color: var(--muted); font-size: 0.88rem; }
      dl.meta-block { display: grid; grid-template-columns: max-content 1fr; gap: 0.15rem 0.75rem; margin: 0 0 1.25rem; font-size: 0.92rem; }
      dl.meta-block dt { color: var(--muted); }
      dl.meta-block dd { margin: 0; }
      .empty { color: var(--muted); font-style: italic; padding: 1rem 0; }
      .pill {
        display: inline-block;
        padding: 0.05rem 0.45rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        font-size: 0.78rem;
        line-height: 1.4;
        color: var(--muted);
      }
      .pill[data-status="alive"], .pill[data-status="active"], .pill[data-status="open"], .pill[data-status="standing"] { color: #1f7a1f; border-color: #cfe9cf; }
      .pill[data-status="dormant"], .pill[data-status="deprecated"], .pill[data-status="partial"] { color: #a06600; border-color: #f0d9a8; }
      .pill[data-status="shipped"] { color: #1f4ea0; border-color: #cfd9f0; }
      .pill[data-status="abandoned"], .pill[data-status="reversed"], .pill[data-status="superseded"], .pill[data-status="closed"] { color: #888; border-color: #ddd; }
      .claim-history { border-collapse: collapse; font-size: 0.88rem; margin: 0.5rem 0 1.5rem; width: 100%; }
      .claim-history th { text-align: left; color: var(--muted); font-weight: normal; border-bottom: 1px solid var(--line); padding: 0.25rem 0.5rem 0.25rem 0; }
      .claim-history td { padding: 0.2rem 0.5rem 0.2rem 0; border-bottom: 1px solid var(--line); vertical-align: middle; }
      .claim-history tr:last-child td { border-bottom: none; }
      .tags { display: inline-flex; flex-wrap: wrap; gap: 0.3rem; }
      .tags > .tag { font-size: 0.78rem; color: var(--muted); }
      .banner { padding: 0.6rem 0.8rem; border: 1px solid var(--line); border-radius: 4px; background: #fff8e6; margin: 1rem 0; font-size: 0.92rem; }
      .freshness-pill {
        display: inline-block;
        margin-left: 0.5rem;
        padding: 0.05rem 0.45rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: normal;
        line-height: 1.4;
        vertical-align: middle;
        color: var(--muted);
      }
      .freshness-pill[data-state="green"] { color: #1f7a1f; border-color: #cfe9cf; }
      .freshness-pill[data-state="amber"] { color: #a06600; border-color: #f0d9a8; }
      .freshness-pill[data-state="red"] { color: #a02020; border-color: #f0c8c8; }
      article :global(p), article :global(li) { margin: 0.5rem 0; }
      svg.calibration { max-width: 100%; height: auto; }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="inner">
        <a href="/" class="brand">Tom — wild.as</a>
        {NAV_SURFACES.map((s) => (
          <a class="nav" href={s.url} aria-current={path === s.url ? "page" : undefined}>{s.title}</a>
        ))}
      </div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
