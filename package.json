{
  "name": "thinkinglabs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf .astro dist node_modules/.astro",
    "clean:og-cache": "rimraf .cache/og-images",
    "clean:local": "pnpm clean && pnpm clean:og-cache",
    "dev": "astro dev",
    "prebuild": "pnpm clean && pnpm build:llms-txt && pnpm build:feeds",
    "build": "astro check && astro build",
    "postbuild": "pnpm build:index",
    "build:llms-txt": "tsx scripts/build-llms-txt.ts",
    "build:feeds": "tsx scripts/build-feeds.ts",
    "build:index": "tsx scripts/build-index.ts",
    "check:structured-data": "tsx scripts/check-structured-data.ts",
    "check:llm-key": "tsx scripts/check-llm-key.ts",
    "semantic:check": "semantic-layer check",
    "semantic:index": "semantic-layer index && vp fmt vault/HIERARCHY.md vault/.semantic-layer/code-refs.json --write",
    "preview": "astro preview",
    "setup:e2e": "playwright install chromium",
    "test:e2e": "pnpm build && playwright test",
    "brain-diff": "tsx scripts/brain-diff.ts",
    "brain-diff:offline": "pnpm brain-diff --no-llm",
    "brain-diff:scored": "pnpm check:llm-key && pnpm brain-diff",
    "mcp:thinkinglabs": "tsx servers/thinkinglabs-mcp/cli.ts",
    "mcp:thinkinglabs:http": "tsx servers/thinkinglabs-mcp-http/cli.ts",
    "derive-claims": "tsx scripts/derive-claims.ts",
    "review-stale-claims": "tsx scripts/review-stale-claims.ts",
    "dormant-flip": "tsx scripts/dormant-flip.ts",
    "freshness-review": "tsx scripts/freshness-review.ts",
    "resolve-predictions": "tsx scripts/resolve-predictions.ts",
    "review-decisions": "tsx scripts/review-decisions.ts",
    "review-proposals": "tsx scripts/review-proposals.ts",
    "triage-questions": "tsx scripts/triage-questions.ts",
    "linkedin:post": "tsx scripts/linkedin-post.ts",
    "typecheck": "astro check",
    "lint": "vp lint",
    "format": "vp fmt",
    "check": "vp check",
    "test": "vp test run",
    "artifacts": "pnpm artifacts:offline",
    "artifacts:offline": "pnpm brain-diff:offline && pnpm build",
    "artifacts:scored": "pnpm brain-diff:scored && pnpm build",
    "verify": "pnpm clean && pnpm typecheck && pnpm check && pnpm semantic:check && pnpm semantic:index && pnpm build && pnpm check:structured-data && pnpm test",
    "verify:full": "pnpm verify && pnpm test:e2e",
    "prepare": "vp config"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@fontsource/golos-text": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@resvg/resvg-js": "^2.6.2",
    "ai": "^6.0.193",
    "astro": "^6.4.2",
    "better-sqlite3": "^12.10.0",
    "d3-force-3d": "^3.0.6",
    "gray-matter": "^4.0.3",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "three": "^0.184.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "7.2.0",
    "@madebywild/agent-harness-framework": "^1.10.1",
    "@madebywild/semantic-layer": "0.3.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.1",
    "@types/three": "^0.184.1",
    "node-gyp": "^12.3.0",
    "remark-parse": "^11.0.0",
    "rimraf": "^6.1.3",
    "schema-dts": "^2.0.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.23"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.23"
    }
  }
}
