{
  "name": "me",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "rimraf .astro dist node_modules/.astro",
    "dev": "astro dev",
    "prebuild": "pnpm clean && pnpm build:llms-txt",
    "build": "astro check && astro build",
    "build:fixtures": "tsx scripts/build-fixtures.ts",
    "build:llms-txt": "tsx scripts/build-llms-txt.ts",
    "build:index": "tsx scripts/build-index.ts",
    "brain-diff": "tsx scripts/brain-diff.ts",
    "mcp:me": "tsx servers/me-mcp/cli.ts",
    "derive-claims": "tsx scripts/derive-claims.ts",
    "review-stale-claims": "tsx scripts/review-stale-claims.ts",
    "dormant-flip": "tsx scripts/dormant-flip.ts",
    "freshness-review": "tsx scripts/freshness-review.ts",
    "resolve-predictions": "tsx scripts/resolve-predictions.ts",
    "review-decisions": "tsx scripts/review-decisions.ts",
    "review-proposals": "tsx scripts/review-proposals.ts",
    "triage-questions": "tsx scripts/triage-questions.ts",
    "typecheck": "astro check",
    "test": "vitest run",
    "verify": "pnpm clean && pnpm typecheck && pnpm build && pnpm build:index && pnpm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "astro": "^6.2.1",
    "better-sqlite3": "^12.4.1",
    "gray-matter": "^4.0.3",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.0",
    "remark-parse": "^11.0.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
