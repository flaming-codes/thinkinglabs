{
  "name": "thinkinglabs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf .astro dist node_modules/.astro",
    "dev": "astro dev",
    "prebuild": "pnpm clean && pnpm build:llms-txt && pnpm build:feeds",
    "build": "astro check && astro build",
    "build:fixtures": "tsx scripts/build-fixtures.ts",
    "build:llms-txt": "tsx scripts/build-llms-txt.ts",
    "build:feeds": "tsx scripts/build-feeds.ts",
    "build:index": "tsx scripts/build-index.ts",
    "check:structured-data:empty": "tsx scripts/check-structured-data.ts --mode=empty",
    "check:structured-data:fixtures": "tsx scripts/check-structured-data.ts --mode=fixtures",
    "check:llm-key": "tsx scripts/check-llm-key.ts",
    "preview": "astro preview",
    "setup:e2e": "playwright install chromium",
    "test:e2e": "pnpm build:fixtures && playwright test",
    "brain-diff": "tsx scripts/brain-diff.ts",
    "brain-diff:offline": "pnpm brain-diff --no-llm",
    "brain-diff:scored": "pnpm check:llm-key && pnpm brain-diff",
    "mcp:thinkinglabs": "tsx servers/thinkinglabs-mcp/cli.ts",
    "derive-claims": "tsx scripts/derive-claims.ts",
    "review-stale-claims": "tsx scripts/review-stale-claims.ts",
    "dormant-flip": "tsx scripts/dormant-flip.ts",
    "freshness-review": "tsx scripts/freshness-review.ts",
    "resolve-predictions": "tsx scripts/resolve-predictions.ts",
    "review-decisions": "tsx scripts/review-decisions.ts",
    "review-proposals": "tsx scripts/review-proposals.ts",
    "triage-questions": "tsx scripts/triage-questions.ts",
    "typecheck": "astro check",
    "lint": "vp lint",
    "format": "vp fmt",
    "check": "vp check",
    "test": "vp test run",
    "artifacts": "pnpm artifacts:offline",
    "artifacts:offline": "pnpm brain-diff:offline && pnpm build && pnpm build:index",
    "artifacts:scored": "pnpm brain-diff:scored && pnpm build && pnpm build:index",
    "verify:empty": "pnpm clean && pnpm typecheck && pnpm check && pnpm build && pnpm check:structured-data:empty && pnpm build:index && pnpm test",
    "verify:fixtures": "pnpm clean && pnpm typecheck && pnpm check && pnpm build:fixtures && pnpm check:structured-data:fixtures",
    "verify": "pnpm verify:empty && pnpm verify:fixtures",
    "verify:full": "pnpm verify && pnpm test:e2e",
    "prepare": "vp config"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.55",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.173",
    "astro": "^6.2.1",
    "better-sqlite3": "^12.4.1",
    "gray-matter": "^4.0.3",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.48.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.0",
    "remark-parse": "^11.0.0",
    "rimraf": "^6.1.3",
    "schema-dts": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
